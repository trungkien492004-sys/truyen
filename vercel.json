{
  "version": 2,
  "regions": ["icn1"],
  "builds": [
    {
      "src": "app.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["views/**", "public/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app.js"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/daily-reward",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/sync-donghentai",
      "schedule": "0 2 * * *"
    }
  ]
}
