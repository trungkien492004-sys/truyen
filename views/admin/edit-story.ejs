            if (confirm(`Bạn có chắc chắn muốn xoá ${ids.length} chương đã chọn? Hành động này không thể hoàn tác!`)) {
                btnDeleteSelected.disabled = true;
                btnDeleteSelected.textContent = '⏳ Đang xoá...';
                deleteChapters(ids, 'selected');
            }
        });
    }

    if (btnDeleteAll) {
        btnDeleteAll.addEventListener('click', () => {
            if (confirm('CẢNH BÁO NGUY HIỂM: Bạn có chắc chắn muốn XÓA TOÀN BỘ chương của bộ truyện này không? Hành động này sẽ xoá sạch mọi dữ liệu chương!')) {
                btnDeleteAll.disabled = true;
                btnDeleteAll.textContent = '⏳ Đang xoá...';
                deleteChapters(null, 'all');
            }
        });
    }

    // Xóa một chương đơn lẻ
    document.querySelectorAll('.btn-delete-single').forEach(btn => {
        btn.addEventListener('click', () => {
            const id = btn.getAttribute('data-id');
            const title = btn.getAttribute('data-title');
            if (confirm(`Bạn có chắc chắn muốn xoá chương "${title}" không?`)) {
                btn.disabled = true;
                btn.textContent = '⏳...';
                deleteChapters([id], 'selected');
            }
        });
    });
