<%- include('../partials/header') %>

<div style="margin-bottom: 1.5rem;">
    <a href="/admin" style="color: var(--text-secondary); font-size: 0.9rem;">&larr; Quay lại Trang quản trị</a>
</div>

<div class="form-container" style="max-width: 700px;">
    <h2 class="section-title">✏️ Chỉnh Sửa Bộ Truyện</h2>
    
    <% if (success) { %>
        <div class="alert alert-success"><%= success %></div>
    <% } %>

    <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form action="/admin/story/edit/<%= story.id %>" method="POST" enctype="multipart/form-data">
        <div class="form-group">
            <label for="title">Tên Truyện *</label>
            <input type="text" id="title" name="title" value="<%= story.title %>" required>
        </div>

        <div class="form-group">
            <label for="author">Tác Giả</label>
            <input type="text" id="author" name="author" value="<%= story.author %>">
        </div>

        <div class="form-group">
            <label for="commissioned_by">Người đặt viết truyện (nếu có)</label>
            <input type="text" id="commissioned_by" name="commissioned_by" value="<%= story.commissioned_by || '' %>" placeholder="Ví dụ: Độc giả Nguyễn Văn A">
        </div>

        <div class="form-group">
            <label>Ảnh Bìa Hiện Tại</label>
            <div style="display: flex; align-items: center; gap: 1.5rem; background: var(--bg-primary); padding: 1rem; border-radius: 8px; border: 1px solid var(--border-color);">
                <img src="<%= story.cover_url %>" alt="Cover" style="width: 80px; height: 110px; object-fit: cover; border-radius: 6px; border: 1px solid var(--border-color);">
                <div>
                    <label for="cover" style="font-weight: normal; cursor: pointer;" class="btn btn-secondary">Thay đổi ảnh bìa</label>
                    <input type="file" id="cover" name="cover" accept="image/*" style="display: none;">
                    <span id="file-name" style="font-size: 0.85rem; color: var(--text-secondary); margin-left: 0.5rem; display: block; margin-top: 0.5rem;">Chưa chọn tệp mới</span>
                </div>
            </div>
        </div>

        <div class="form-group">
            <label>Thể Loại Truyện (Chọn nhiều thể loại)</label>
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 0.8rem; margin-top: 0.5rem; background: var(--bg-primary); padding: 1rem; border-radius: 8px; border: 1px solid var(--border-color);">
                <% genres.forEach(genre => { %>
                    <% const isChecked = linkedGenreIds.includes(genre.id); %>
                    <label style="display: flex; align-items: center; gap: 0.5rem; font-weight: normal; cursor: pointer; font-size: 0.9rem;">
                        <input type="checkbox" name="genres" value="<%= genre.id %>" <%= isChecked ? 'checked' : '' %>>
                        <%= genre.name %>
                    </label>
                <% }) %>
            </div>
        </div>

        <div class="form-group">
            <label for="description">Tóm Tắt Nội Dung</label>
            <textarea id="description" name="description" rows="6"><%= story.description %></textarea>
        </div>

        <button type="submit" class="btn btn-primary" style="width: 100%; padding: 0.8rem; font-size: 1rem; margin-top: 1rem;">CẬP NHẬT THÔNG TIN TRUYỆN</button>
    </form>
</div>

<hr style="margin: 3rem 0; border: none; border-top: 1px dashed var(--border-color);">

<div class="form-container" style="max-width: 700px; margin-top: 2rem;">
    <h2 class="section-title">⚡ Đăng Chương Mới Cho Bộ Truyện Này</h2>
    
    <form action="/admin/chapter/add" method="POST" enctype="multipart/form-data">
        <!-- Story ID mặc định cho bộ truyện này -->
        <input type="hidden" name="story_id" value="<%= story.id %>">
        <!-- Đường dẫn redirect về đây sau khi lưu thành công -->
        <input type="hidden" name="redirect_to" value="/admin/story/edit/<%= story.id %>">

        <!-- CHỌN PHƯƠNG THỨC ĐĂNG -->
        <div class="form-group" style="margin-bottom: 2rem;">
            <label>Phương thức đăng chương *</label>
            <div style="display: flex; gap: 2rem; margin-top: 0.5rem; background: var(--bg-primary); padding: 1rem; border-radius: 8px; border: 1px solid var(--border-color);">
                <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-weight: 500;">
                    <input type="radio" name="publish_method" value="manual" checked>
                    Đăng thủ công (Nhập tay / Chèn HTML)
                </label>
                <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-weight: 500;">
                    <input type="radio" name="publish_method" value="bulk">
                    Tải tệp tin tự động (.txt, .docx)
                </label>
            </div>
        </div>

        <!-- KHỐI FORM 1: ĐĂNG THỦ CÔNG (MANUAL) -->
        <div id="form-manual">
            <div style="display: grid; grid-template-columns: 1fr 3fr; gap: 1rem;">
                <div class="form-group">
                    <label for="chapter_number">Số Chương *</label>
                    <input type="number" id="chapter_number" name="chapter_number" min="1" step="any" placeholder="Ví dụ: 1">
                </div>
                <div class="form-group">
                    <label for="title">Tiêu Đề Chương *</label>
                    <input type="text" id="title" name="title" placeholder="Ví dụ: Buổi sáng định mệnh">
                </div>
            </div>

            <div class="form-group">
                <label for="content">Nội Dung Chương (Hỗ trợ Text hoặc thẻ ảnh HTML) *</label>
                <textarea id="content" name="content" rows="10" placeholder="Để đan xen chữ và hình ảnh, bạn có thể viết nội dung dạng HTML:
<p>Nội dung đoạn chữ thứ nhất...</p>
<img src='/uploads/ten-anh-da-up.png' alt='Ảnh minh họa'>
<p>Nội dung đoạn chữ tiếp theo...</p>"></textarea>
            </div>
        </div>

        <!-- KHỐI FORM 2: TỰ ĐỘNG TÁCH CHƯƠNG (BULK) -->
        <div id="form-bulk" style="display: none;">
            <div style="background: rgba(59, 130, 246, 0.08); border-left: 4px solid var(--accent-color); padding: 1rem; border-radius: 0 8px 8px 0; margin-bottom: 1.5rem; font-size: 0.9rem; line-height: 1.5;">
                <strong>💡 Hướng dẫn tải tệp tin truyện:</strong><br>
                * **Tải lên hàng loạt**: Bạn có thể chọn và tải lên **nhiều file cùng một lúc**.<br>
                * **File Word (.docx)**: Trích xuất toàn bộ văn bản và **ảnh nhúng** đan xen bên trong.<br>
                * **File Văn bản (.txt)**: Trích xuất nội dung chữ thuần.<br>
                * **Quy tắc**: Nhận diện chương bằng từ khóa đầu dòng như: <code>Chương [Số]</code>, <code>Chap [Số]</code>. Nếu nội dung file không chứa từ khóa đánh số chương, hệ thống sẽ **tự động xem cả file là 1 chương** và đặt tên chương theo tên file (Mặc định Ngoại truyện).
            </div>

            <div class="form-group">
                <label for="txtfile">Tải lên một hoặc nhiều tệp tin truyện *</label>
                <input type="file" id="txtfile" name="txtfile" accept=".txt,.docx" multiple>
                <span style="font-size: 0.8rem; color: var(--text-secondary); margin-top: 0.3rem; display: block;">Để chọn nhiều tệp, hãy giữ phím Ctrl (hoặc Cmd) khi chọn tệp.</span>
            </div>

            <div class="form-group" style="display: flex; align-items: center; gap: 0.5rem; margin-top: 0.8rem;">
                <input type="checkbox" id="include_images_edit" name="include_images_edit" checked style="width: auto; margin: 0; cursor: pointer;">
                <label for="include_images_edit" style="margin: 0; font-size: 0.9rem; font-weight: normal; cursor: pointer; color: var(--text-primary);">
                    Tải ảnh nhúng trong file Word lên hệ thống (Bỏ tích nếu chỉ muốn lấy chữ)
                </label>
            </div>
        </div>

        <button type="submit" class="btn btn-primary" style="width: 100%; padding: 0.8rem; font-size: 1rem; margin-top: 1rem;">BẮT ĐẦU ĐĂNG CHƯƠNG</button>
    </form>
</div>

<hr style="margin: 3rem 0; border: none; border-top: 1px dashed var(--border-color);">

<!-- DANH SÁCH CHƯƠNG HIỆN CÓ VÀ CÁC THAO TÁC SỬA / XÓA HÀNG LOẠT -->
<div class="form-container" style="max-width: 700px; margin-top: 2rem;">
    <h2 class="section-title">📚 Danh Sách Chương Hiện Có</h2>

    <% if (chapters.length === 0) { %>
        <p style="color: var(--text-secondary); text-align: center; padding: 2rem 0;">Chưa có chương nào được đăng cho bộ truyện này.</p>
    <% } else { %>
        <!-- Thanh công cụ xóa hàng loạt -->
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; background: var(--bg-primary); padding: 0.8rem; border-radius: 8px; border: 1px solid var(--border-color);">
            <label style="display: flex; align-items: center; gap: 0.5rem; font-weight: normal; cursor: pointer; margin: 0; font-size: 0.95rem; color: var(--text-primary);">
                <input type="checkbox" id="select-all-chapters" style="width: auto; margin: 0; cursor: pointer;">
                Chọn tất cả
            </label>
            <div style="display: flex; gap: 0.8rem;">
                <button type="button" id="btn-delete-selected" class="btn btn-secondary" style="background: rgba(239, 68, 68, 0.15); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.3); padding: 0.4rem 0.8rem; font-size: 0.9rem;" disabled>
                    🗑️ Xoá đã chọn (<span id="selected-count">0</span>)
                </button>
                <button type="button" id="btn-delete-all" class="btn btn-secondary" style="background: rgba(239, 68, 68, 0.8); color: #fff; border: none; padding: 0.4rem 0.8rem; font-size: 0.9rem; cursor: pointer;">
                    💥 Xoá tất cả
                </button>
            </div>
        </div>

        <!-- Bảng danh sách chương -->
        <div style="max-height: 400px; overflow-y: auto; background: var(--bg-primary); border-radius: 8px; border: 1px solid var(--border-color);">
            <table style="width: 100%; border-collapse: collapse; text-align: left;">
                <thead>
                    <tr style="border-bottom: 1px solid var(--border-color); background: rgba(255, 255, 255, 0.02); position: sticky; top: 0; z-index: 10;">
                        <th style="padding: 0.8rem; width: 40px; background: var(--bg-primary);"></th>
                        <th style="padding: 0.8rem; width: 100px; background: var(--bg-primary);">Số</th>
                        <th style="padding: 0.8rem; background: var(--bg-primary);">Tiêu Đề Chương</th>
                        <th style="padding: 0.8rem; text-align: right; width: 130px; background: var(--bg-primary);">Hành Động</th>
                    </tr>
                </thead>
                <tbody>
                    <% chapters.forEach(chap => { %>
                        <tr style="border-bottom: 1px solid var(--border-color); font-size: 0.9rem;" class="chapter-row">
                            <td style="padding: 0.8rem; text-align: center;">
                                <input type="checkbox" class="chapter-checkbox" value="<%= chap.id %>" style="width: auto; margin: 0; cursor: pointer;">
                            </td>
                            <td style="padding: 0.8rem; font-weight: bold; color: var(--accent-color);">
                                <%= chap.chapter_number %>
                            </td>
                            <td style="padding: 0.8rem; color: var(--text-primary);">
                                <%= chap.title %>
                            </td>
                            <td style="padding: 0.8rem; text-align: right;">
                                <a href="/admin/chapter/edit/<%= chap.id %>?redirect_to=/admin/story/edit/<%= story.id %>" class="btn btn-secondary" style="padding: 0.2rem 0.5rem; font-size: 0.8rem; margin-right: 0.2rem; display: inline-block;">
                                    ✏️ Sửa
                                </a>
                                <button type="button" class="btn btn-secondary btn-delete-single" data-id="<%= chap.id %>" data-title="<%= chap.title %>" style="background: rgba(239, 68, 68, 0.1); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.2); padding: 0.2rem 0.5rem; font-size: 0.8rem; cursor: pointer;">
                                    🗑️ Xoá
                                </button>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } %>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/mammoth/1.6.0/mammoth.browser.min.js"></script>

<script>
    // Hiển thị tên tệp ảnh khi được chọn mới
    const fileInput = document.getElementById('cover');
    const fileNameDisplay = document.getElementById('file-name');
    if (fileInput && fileNameDisplay) {
        fileInput.addEventListener('change', (e) => {
            if (e.target.files.length > 0) {
                fileNameDisplay.textContent = e.target.files[0].name;
            } else {
                fileNameDisplay.textContent = 'Chưa chọn tệp mới';
            }
        });
    }

    // Logic ẩn/hiện form đăng chương dựa trên phương thức đăng
    const methodRadios = document.querySelectorAll('input[name="publish_method"]');
    const formManual = document.getElementById('form-manual');
    const formBulk = document.getElementById('form-bulk');
    
    // Các trường bắt buộc cho manual
    const chapNumInput = document.getElementById('chapter_number');
    const chapTitleInput = document.getElementById('title');
    const chapContentInput = document.getElementById('content');
    const bulkFileInput = document.getElementById('txtfile');

    function toggleForms() {
        const selectedMethod = document.querySelector('input[name="publish_method"]:checked').value;
        if (selectedMethod === 'manual') {
            formManual.style.display = 'block';
            formBulk.style.display = 'none';
            // Cập nhật thuộc tính required
            if (chapNumInput) chapNumInput.required = true;
            if (chapTitleInput) chapTitleInput.required = true;
            if (chapContentInput) chapContentInput.required = true;
            if (bulkFileInput) bulkFileInput.required = false;
        } else {
            formManual.style.display = 'none';
            formBulk.style.display = 'block';
            // Cập nhật thuộc tính required
            if (chapNumInput) chapNumInput.required = false;
            if (chapTitleInput) chapTitleInput.required = false;
            if (chapContentInput) chapContentInput.required = false;
            if (bulkFileInput) bulkFileInput.required = true;
        }
    }

    methodRadios.forEach(radio => {
        radio.addEventListener('change', toggleForms);
    });

    // Chạy khi khởi động trang
    toggleForms();

    // INTERCEPT FORM SUBMIT ĐĂNG CHƯƠNG ĐỂ XỬ LÝ PHÍA TRÌNH DUYỆT (TRÁNH LỖI VERCEL 4.5MB PAYLOAD)
    const chapterForm = document.querySelector('form[action="/admin/chapter/add"]');
    if (chapterForm) {
        chapterForm.addEventListener('submit', async (e) => {
            const selectedMethod = document.querySelector('input[name="publish_method"]:checked').value;
            if (selectedMethod === 'bulk') {
                e.preventDefault(); // Ngăn submit form mặc định

                const submitBtn = chapterForm.querySelector('button[type="submit"]');
                const originalBtnText = submitBtn.textContent;
                submitBtn.disabled = true;
                submitBtn.textContent = '⏳ Đang xử lý file và tải ảnh lên...';

                try {
                    const storyId = chapterForm.querySelector('input[name="story_id"]').value;
                    const redirectTo = chapterForm.querySelector('input[name="redirect_to"]').value;
                    const files = bulkFileInput.files;
                    if (!files || files.length === 0) {
                        alert('Vui lòng chọn tệp tin truyện.');
                        submitBtn.disabled = false;
                        submitBtn.textContent = originalBtnText;
                        return;
                    }

                    const processedFiles = [];

                    for (let file of files) {
                        const isDocx = file.name.endsWith('.docx');
                        if (isDocx) {
                            const arrayBuffer = await file.arrayBuffer();
                            const result = await mammoth.convertToHtml({ arrayBuffer: arrayBuffer });
                            let html = result.value;

                            // Parse ảnh và upload thẳng lên Supabase hoặc xoá ảnh
                            const parser = new DOMParser();
                            const doc = parser.parseFromString(html, 'text/html');
                            const imgs = doc.querySelectorAll('img');

                            const includeImages = document.getElementById('include_images_edit').checked;

                            if (includeImages) {
                                if (imgs.length > 0) {
                                    submitBtn.textContent = `⏳ Đang tải ${imgs.length} ảnh trong file lên Supabase...`;
                                }

                                for (let img of imgs) {
                                    const src = img.getAttribute('src');
                                    if (src && src.startsWith('data:')) {
                                        const blob = dataURLtoBlob(src);
                                        const publicUrl = await uploadBlobToSupabase(blob, blob.type);
                                        img.setAttribute('src', publicUrl);
                                    }
                                }
                            } else {
                                // Xoá ảnh khỏi tài liệu
                                imgs.forEach(img => img.remove());
                            }

                            html = doc.body.innerHTML;
                            processedFiles.push({
                                name: file.name,
                                type: 'docx',
                                content: html
                            });

                        } else {
                            // Txt file
                            const text = await file.text();
                            processedFiles.push({
                                name: file.name,
                                type: 'txt',
                                content: text
                            });
                        }
                    }

                    // Gửi JSON lên server
                    submitBtn.textContent = '⏳ Đang lưu dữ liệu chương vào database...';
                    const response = await fetch('/admin/chapter/add-json', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            story_id: storyId,
                            files: processedFiles
                        })
                    });

                    let resData;
                    const contentType = response.headers.get('content-type');
                    if (contentType && contentType.includes('application/json')) {
                        resData = await response.json();
                    } else {
                        const text = await response.text();
                        if (response.status === 413) {
                            throw new Error('Dung lượng tệp truyện hoặc ảnh gửi đi quá lớn (Vượt quá 4.5 MB giới hạn của Vercel). Vui lòng thử chia nhỏ file ra đăng làm nhiều lần.');
                        }
                        throw new Error(`Lỗi từ máy chủ (${response.status}): ${text.substring(0, 150)}...`);
                    }

                    if (resData.success) {
                        window.location.href = redirectTo + '?success=' + encodeURIComponent(resData.message);
                    } else {
                        alert('Lỗi đăng chương: ' + resData.error);
                        submitBtn.disabled = false;
                        submitBtn.textContent = originalBtnText;
                    }

                } catch (err) {
                    console.error(err);
                    alert('Có lỗi xảy ra: ' + err.message);
                    submitBtn.disabled = false;
                    submitBtn.textContent = originalBtnText;
                }
            }
        });
    }

    // Hàm chuyển đổi ảnh base64 thành Blob
    function dataURLtoBlob(dataurl) {
        var arr = dataurl.split(','), mime = arr[0].match(/:(.*?);/)[1],
            bstr = atob(arr[1]), n = bstr.length, u8arr = new Uint8Array(n);
        while(n--){
            u8arr[n] = bstr.charCodeAt(n);
        }
        return new Blob([u8arr], {type:mime});
    }

    // Hàm upload blob thẳng lên Supabase Storage từ Browser
    async function uploadBlobToSupabase(blob, mimeType) {
        const fileExt = mimeType === 'image/jpeg' ? '.jpg' : '.png';
        const fileName = `word-img-${Date.now()}-${Math.round(Math.random() * 1E9)}${fileExt}`;
        
        const supabaseUrl = 'https://xlaqupbqiwpoprywnkgi.supabase.co';
        const anonKey = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InhsYXF1cGJxaXdwb3ByeXdua2dpIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODM1ODkxNDcsImV4cCI6MjA5OTE2NTE0N30.v0NZKDhVb4ysx03cmx_aQn6aGBMCO6lWzBUN6--JKB0';

        const response = await fetch(`${supabaseUrl}/storage/v1/object/uploads/${fileName}`, {
            method: 'POST',
            headers: {
                'Authorization': `Bearer ${anonKey}`,
                'apikey': anonKey,
                'Content-Type': mimeType
            },
            body: blob
        });

        if (!response.ok) {
            const errText = await response.text();
            throw new Error(`Upload ảnh thất bại: ${errText}`);
        }

        return `${supabaseUrl}/storage/v1/object/public/uploads/${fileName}`;
    }

    // --- LOGIC XỬ LÝ CHỌN VÀ XÓA HÀNG LOẠT CHƯƠNG ---
    const selectAllCheckbox = document.getElementById('select-all-chapters');
    const chapterCheckboxes = document.querySelectorAll('.chapter-checkbox');
    const btnDeleteSelected = document.getElementById('btn-delete-selected');
    const btnDeleteAll = document.getElementById('btn-delete-all');
    const selectedCountSpan = document.getElementById('selected-count');

    function updateDeleteSelectedButton() {
        const checkedCount = document.querySelectorAll('.chapter-checkbox:checked').length;
        if (selectedCountSpan) selectedCountSpan.textContent = checkedCount;
        if (btnDeleteSelected) {
            btnDeleteSelected.disabled = checkedCount === 0;
            if (checkedCount > 0) {
                btnDeleteSelected.style.background = 'rgba(239, 68, 68, 0.25)';
                btnDeleteSelected.style.cursor = 'pointer';
            } else {
                btnDeleteSelected.style.background = 'rgba(239, 68, 68, 0.15)';
                btnDeleteSelected.style.cursor = 'not-allowed';
            }
        }
    }

    if (selectAllCheckbox) {
        selectAllCheckbox.addEventListener('change', () => {
            chapterCheckboxes.forEach(cb => {
                cb.checked = selectAllCheckbox.checked;
            });
            updateDeleteSelectedButton();
        });
    }

    chapterCheckboxes.forEach(cb => {
        cb.addEventListener('change', () => {
            if (!cb.checked && selectAllCheckbox) {
                selectAllCheckbox.checked = false;
            }
            if (selectAllCheckbox && document.querySelectorAll('.chapter-checkbox:checked').length === chapterCheckboxes.length) {
                selectAllCheckbox.checked = true;
            }
            updateDeleteSelectedButton();
        });
    });

    // Hàm gọi API xóa chương
    async function deleteChapters(ids, action) {
        try {
            const response = await fetch('/admin/chapter/delete-bulk', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    ids: ids,
                    action: action,
                    story_id: '<%= story.id %>'
                })
            });

            const resData = await response.json();
            if (resData.success) {
                window.location.href = '/admin/story/edit/<%= story.id %>?success=' + encodeURIComponent(resData.message);
            } else {
                alert('Lỗi: ' + resData.error);
                // Reset state
                if (btnDeleteSelected) {
                    btnDeleteSelected.disabled = false;
                    btnDeleteSelected.textContent = `🗑️ Xoá đã chọn`;
                }
                if (btnDeleteAll) {
                    btnDeleteAll.disabled = false;
                    btnDeleteAll.textContent = `💥 Xoá tất cả`;
                }
            }
        } catch (err) {
            console.error(err);
            alert('Lỗi kết nối máy chủ: ' + err.message);
        }
    }

    if (btnDeleteSelected) {
        btnDeleteSelected.addEventListener('click', () => {
            const checkedBoxes = document.querySelectorAll('.chapter-checkbox:checked');
            const ids = Array.from(checkedBoxes).map(cb => cb.value);
            if (ids.length === 0) return;

            if (confirm(`Bạn có chắc chắn muốn xoá ${ids.length} chương đã chọn? Hành động này không thể hoàn tác!`)) {
                btnDeleteSelected.disabled = true;
                btnDeleteSelected.textContent = '⏳ Đang xoá...';
                deleteChapters(ids, 'selected');
            }
        });
    }

    if (btnDeleteAll) {
        btnDeleteAll.addEventListener('click', () => {
            if (confirm('CẢNH BÁO NGUY HIỂM: Bạn có chắc chắn muốn XÓA TOÀN BỘ chương của bộ truyện này không? Hành động này sẽ xoá sạch mọi dữ liệu chương!')) {
                btnDeleteAll.disabled = true;
                btnDeleteAll.textContent = '⏳ Đang xoá...';
                deleteChapters(null, 'all');
            }
        });
    }

    // Xóa một chương đơn lẻ
    document.querySelectorAll('.btn-delete-single').forEach(btn => {
        btn.addEventListener('click', () => {
            const id = btn.getAttribute('data-id');
            const title = btn.getAttribute('data-title');
            if (confirm(`Bạn có chắc chắn muốn xoá chương "${title}" không?`)) {
                btn.disabled = true;
                btn.textContent = '⏳...';
                deleteChapters([id], 'selected');
            }
        });
    });
</script>

