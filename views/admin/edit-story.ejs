<%- include('../partials/header') %>

<div style="margin-bottom: 1.5rem; display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap;">
    <a href="/admin" style="color: var(--text-secondary); font-size: 0.9rem;">&larr; Quay lại Trang quản trị</a>
    <a href="/admin/story/download-epub/<%= story.id %>" class="btn btn-secondary" style="padding: 0.4rem 0.8rem; font-size: 0.85rem; background: rgba(16, 185, 129, 0.1); border-color: rgba(16, 185, 129, 0.2); color: #10b981; border-radius: 6px; text-decoration: none; display: inline-flex; align-items: center; gap: 0.3rem;">
        📥 Tải File EPUB
    </a>
</div>

<div class="form-container" style="max-width: 700px;">
    <h2 class="section-title">✏️ Chỉnh Sửa Bộ Truyện</h2>
    
    <% if (success) { %>
        <div class="alert alert-success"><%= success %></div>
    <% } %>

    <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form action="/admin/story/edit/<%= story.id %>" method="POST" enctype="multipart/form-data">
        <div class="form-group">
            <label for="title">Tên Truyện *</label>
            <input type="text" id="title" name="title" value="<%= story.title %>" required>
        </div>

        <div class="form-group">
            <label for="author">Tác Giả</label>
            <input type="text" id="author" name="author" value="<%= story.author %>">
        </div>

        <div class="form-group">
            <label for="commissioned_by">Người đặt viết truyện (nếu có)</label>
            <input type="text" id="commissioned_by" name="commissioned_by" value="<%= story.commissioned_by || '' %>" placeholder="Ví dụ: Độc giả Nguyễn Văn A">
        </div>

        <div class="form-group">
            <label for="status">Trạng Thái Truyện</label>
            <select id="status" name="status" style="width: 100%; padding: 0.8rem 1rem; background: var(--bg-primary); border: 1px solid var(--border-color); color: var(--text-primary); border-radius: 8px; font-size: 1rem; outline: none;">
                <option value="ongoing" <%= (story.status || 'ongoing') === 'ongoing' ? 'selected' : '' %>>🔄 Đang tiến hành</option>
                <option value="completed" <%= story.status === 'completed' ? 'selected' : '' %>>✅ Đã hoàn thành</option>
            </select>
        </div>

        <div class="form-group">
            <label for="story_type">Loại Truyện</label>
            <select id="story_type" name="story_type" style="width: 100%; padding: 0.8rem 1rem; background: var(--bg-primary); border: 1px solid var(--border-color); color: var(--text-primary); border-radius: 8px; font-size: 1rem; outline: none;">
                <option value="novel" <%= (story.story_type || 'novel') === 'novel' ? 'selected' : '' %>>📄 Truyện chữ</option>
                <option value="comic" <%= story.story_type === 'comic' ? 'selected' : '' %>>🖼️ Truyện tranh</option>
            </select>
        </div>

        <div class="form-group">
            <label>Ảnh Bìa Hiện Tại</label>
            <div style="display: flex; align-items: center; gap: 1.5rem; background: var(--bg-primary); padding: 1rem; border-radius: 8px; border: 1px solid var(--border-color);">
                <img src="<%= story.cover_url %>" alt="Cover" style="width: 80px; height: 110px; object-fit: cover; border-radius: 6px; border: 1px solid var(--border-color);">
                <div>
                    <label for="cover" style="font-weight: normal; cursor: pointer;" class="btn btn-secondary">Thay đổi ảnh bìa</label>
                    <input type="file" id="cover" name="cover" accept="image/*" style="display: none;">
                    <span id="file-name" style="font-size: 0.85rem; color: var(--text-secondary); margin-left: 0.5rem; display: block; margin-top: 0.5rem;">Chưa chọn tệp mới</span>
                </div>
            </div>
        </div>

        <div class="form-group">
            <label>Thể Loại Truyện (Chọn nhiều thể loại)</label>
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 0.8rem; margin-top: 0.5rem; background: var(--bg-primary); padding: 1rem; border-radius: 8px; border: 1px solid var(--border-color);">
                <% genres.forEach(genre => { %>
                    <% const isChecked = linkedGenreIds.includes(genre.id); %>
                    <label style="display: flex; align-items: center; gap: 0.5rem; font-weight: normal; cursor: pointer; font-size: 0.9rem;">
                        <input type="checkbox" name="genres" value="<%= genre.id %>" <%= isChecked ? 'checked' : '' %>>
                        <%= genre.name %>
                    </label>
                <% }) %>
            </div>
        </div>

        <div class="form-group">
            <label for="description">Tóm Tắt Nội Dung</label>
            <textarea id="description" name="description" rows="6"><%= story.description %></textarea>
        </div>

        <button type="submit" class="btn btn-primary" style="width: 100%; padding: 0.8rem; font-size: 1rem; margin-top: 1rem;">CẬP NHẬT THÔNG TIN TRUYỆN</button>
    </form>
</div>

<hr style="margin: 3rem 0; border: none; border-top: 1px dashed var(--border-color);">

<div class="form-container" style="max-width: 700px; margin-top: 2rem;">
    <h2 class="section-title">⚡ Đăng Chương Mới Cho Bộ Truyện Này</h2>
    
    <form action="/admin/chapter/add" method="POST" enctype="multipart/form-data">
        <!-- Story ID mặc định cho bộ truyện này -->
        <input type="hidden" name="story_id" value="<%= story.id %>">
        <!-- Đường dẫn redirect về đây sau khi lưu thành công -->
        <input type="hidden" name="redirect_to" value="/admin/story/edit/<%= story.id %>">

        <!-- CHỌN PHƯƠNG THỨC ĐĂNG -->
        <div class="form-group" style="margin-bottom: 2rem;">
            <label>Phương thức đăng chương *</label>
            <div style="display: flex; gap: 1.5rem; flex-wrap: wrap; margin-top: 0.5rem; background: var(--bg-primary); padding: 1rem; border-radius: 8px; border: 1px solid var(--border-color);">
                <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-weight: 500;">
                    <input type="radio" name="publish_method" value="manual" checked>
                    Đăng thủ công (Nhập tay / Chèn HTML)
                </label>
                <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-weight: 500;">
                    <input type="radio" name="publish_method" value="bulk">
                    Tải tệp tin tự động (.txt, .docx)
                </label>
                <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-weight: 500;">
                    <input type="radio" name="publish_method" value="pdf">
                    📕 Tải PDF (tách chương)
                </label>
                <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-weight: 500;">
                    <input type="radio" name="publish_method" value="epub">
                    📗 Tải EPUB (tách chương)
                </label>
            </div>
        </div>

        <!-- KHỐI FORM 1: ĐĂNG THỦ CÔNG (MANUAL) -->
        <div id="form-manual">
            <div style="display: grid; grid-template-columns: 1fr 3fr; gap: 1rem;">
                <div class="form-group">
                    <label for="chapter_number">Số Chương *</label>
                    <input type="number" id="chapter_number" name="chapter_number" min="1" step="any" placeholder="Ví dụ: 1">
                </div>
                <div class="form-group">
                    <label for="title">Tiêu Đề Chương *</label>
                    <input type="text" id="title" name="title" placeholder="Ví dụ: Buổi sáng định mệnh">
                </div>
            </div>

            <div class="form-group">
                <label for="content">Nội Dung Chương (Hỗ trợ Text hoặc thẻ ảnh HTML) *</label>
                <textarea id="content" name="content" rows="10" placeholder="Để đan xen chữ và hình ảnh, bạn có thể viết nội dung dạng HTML:
<p>Nội dung đoạn chữ thứ nhất...</p>
<img src='/uploads/ten-anh-da-up.png' alt='Ảnh minh họa'>
<p>Nội dung đoạn chữ tiếp theo...</p>"></textarea>
            </div>
        </div>

        <!-- KHỐI FORM 2: TỰ ĐỘNG TÁCH CHƯƠNG (BULK) -->
        <div id="form-bulk" style="display: none;">
            <div style="background: rgba(59, 130, 246, 0.08); border-left: 4px solid var(--accent-color); padding: 1rem; border-radius: 0 8px 8px 0; margin-bottom: 1.5rem; font-size: 0.9rem; line-height: 1.5;">
                <strong>💡 Hướng dẫn tải tệp tin truyện:</strong><br>
                * **Tải lên hàng loạt**: Bạn có thể chọn và tải lên **nhiều file cùng một lúc**.<br>
                * **File Word (.docx)**: Trích xuất toàn bộ văn bản và **ảnh nhúng** đan xen bên trong.<br>
                * **File Văn bản (.txt)**: Trích xuất nội dung chữ thuần.<br>
                * **Quy tắc**: Nhận diện chương bằng từ khóa đầu dòng như: <code>Chương [Số]</code>, <code>Chap [Số]</code>. Nếu nội dung file không chứa từ khóa đánh số chương, hệ thống sẽ **tự động xem cả file là 1 chương** và đặt tên chương theo tên file (Mặc định Ngoại truyện).
            </div>

            <div class="form-group">
                <label for="txtfile">Tải lên một hoặc nhiều tệp tin truyện *</label>
                <input type="file" id="txtfile" name="txtfile" accept=".txt,.docx" multiple>
                <span style="font-size: 0.8rem; color: var(--text-secondary); margin-top: 0.3rem; display: block;">Để chọn nhiều tệp, hãy giữ phím Ctrl (hoặc Cmd) khi chọn tệp.</span>
            </div>

            <div class="form-group" style="display: flex; align-items: center; gap: 0.5rem; margin-top: 0.8rem;">
                <input type="checkbox" id="include_images_edit" name="include_images_edit" checked style="width: auto; margin: 0; cursor: pointer;">
                <label for="include_images_edit" style="margin: 0; font-size: 0.9rem; font-weight: normal; cursor: pointer; color: var(--text-primary);">
                    Tải ảnh nhúng trong file Word lên hệ thống (Bỏ tích nếu chỉ muốn lấy chữ)
                </label>
            </div>
        </div>

        <!-- KHỐI FORM 3: UPLOAD PDF TỰ ĐỘNG TÁCH CHƯƠNG -->
        <div id="form-pdf" style="display: none;">
            <div style="background: rgba(239, 68, 68, 0.07); border-left: 4px solid #ef4444; padding: 1rem; border-radius: 0 8px 8px 0; margin-bottom: 1.5rem; font-size: 0.9rem; line-height: 1.8;">
                <strong>📕 Hướng dẫn upload PDF tự động tách chương:</strong><br>
                • Hệ thống sẽ đọc nội dung PDF và <b>tự động tách thành nhiều chương riêng biệt</b>.<br>
                • Nhận diện đầu chương qua các từ khóa đầu dòng: <code>Chương 1</code>, <code>Chapter 5</code>...
            </div>
            <div class="form-group">
                <label for="pdffile">Chọn file PDF *</label>
                <input type="file" id="pdffile" name="pdffile" accept=".pdf">
                <div id="pdf-status-msg" style="font-size: 0.85rem; margin-top: 0.5rem; font-weight: 500; display: none;"></div>
            </div>
        </div>

        <!-- KHỐI FORM 4: UPLOAD EPUB TỰ ĐỘNG TÁCH CHƯƠNG -->
        <div id="form-epub" style="display: none;">
            <div style="background: rgba(16, 185, 129, 0.07); border-left: 4px solid #10b981; padding: 1rem; border-radius: 0 8px 8px 0; margin-bottom: 1.5rem; font-size: 0.9rem; line-height: 1.8;">
                <strong>📗 Hướng dẫn upload EPUB tự động tách chương:</strong><br>
                • Hệ thống sẽ đọc toàn bộ nội dung sách EPUB và <b>tự động tách thành nhiều chương riêng biệt</b>.<br>
                • Tải hình ảnh tự động lên Supabase.
            </div>
            <div class="form-group">
                <label for="epubfile">Chọn file EPUB *</label>
                <input type="file" id="epubfile" name="epubfile" accept=".epub">
                <div id="epub-status-msg" style="font-size: 0.85rem; margin-top: 0.5rem; font-weight: 500; display: none;"></div>
            </div>
        </div>

        <button type="submit" class="btn btn-primary" style="width: 100%; padding: 0.8rem; font-size: 1rem; margin-top: 1rem;">BẮT ĐẦU ĐĂNG CHƯƠNG</button>
    </form>
</div>

<hr style="margin: 3rem 0; border: none; border-top: 1px dashed var(--border-color);">

<!-- DANH SÁCH CHƯƠNG HIỆN CÓ VÀ CÁC THAO TÁC SỬA / XÓA HÀNG LOẠT -->
<div class="form-container" style="max-width: 700px; margin-top: 2rem;">
    <h2 class="section-title">📚 Danh Sách Chương Hiện Có</h2>

    <% if (chapters.length === 0) { %>
        <p style="color: var(--text-secondary); text-align: center; padding: 2rem 0;">Chưa có chương nào được đăng cho bộ truyện này.</p>
    <% } else { %>
        <!-- Thanh công cụ xóa hàng loạt -->
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; background: var(--bg-primary); padding: 0.8rem; border-radius: 8px; border: 1px solid var(--border-color);">
            <label style="display: flex; align-items: center; gap: 0.5rem; font-weight: normal; cursor: pointer; margin: 0; font-size: 0.95rem; color: var(--text-primary);">
                <input type="checkbox" id="select-all-chapters" style="width: auto; margin: 0; cursor: pointer;">
                Chọn tất cả
            </label>
            <div style="display: flex; gap: 0.8rem;">
                <button type="button" id="btn-delete-selected" class="btn btn-secondary" style="background: rgba(239, 68, 68, 0.15); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.3); padding: 0.4rem 0.8rem; font-size: 0.9rem;" disabled>
                    🗑️ Xoá đã chọn (<span id="selected-count">0</span>)
                </button>
                <button type="button" id="btn-delete-all" class="btn btn-secondary" style="background: rgba(239, 68, 68, 0.8); color: #fff; border: none; padding: 0.4rem 0.8rem; font-size: 0.9rem; cursor: pointer;">
                    💥 Xoá tất cả
                </button>
            </div>
        </div>

        <!-- Bảng danh sách chương -->
        <div style="max-height: 400px; overflow-y: auto; background: var(--bg-primary); border-radius: 8px; border: 1px solid var(--border-color);">
            <table style="width: 100%; border-collapse: collapse; text-align: left;">
                <thead>
                    <tr style="border-bottom: 1px solid var(--border-color); background: rgba(255, 255, 255, 0.02); position: sticky; top: 0; z-index: 10;">
                        <th style="padding: 0.8rem; width: 40px; background: var(--bg-primary);"></th>
                        <th style="padding: 0.8rem; width: 100px; background: var(--bg-primary);">Số</th>
                        <th style="padding: 0.8rem; background: var(--bg-primary);">Tiêu Đề Chương</th>
                        <th style="padding: 0.8rem; text-align: right; width: 130px; background: var(--bg-primary);">Hành Động</th>
                    </tr>
                </thead>
                <tbody>
                    <% chapters.forEach(chap => { %>
                        <tr style="border-bottom: 1px solid var(--border-color); font-size: 0.9rem;" class="chapter-row">
                            <td style="padding: 0.8rem; text-align: center;">
                                <input type="checkbox" class="chapter-checkbox" value="<%= chap.id %>" style="width: auto; margin: 0; cursor: pointer;">
                            </td>
                            <td style="padding: 0.8rem; font-weight: bold; color: var(--accent-color);">
                                <%= chap.chapter_number %>
                            </td>
                            <td style="padding: 0.8rem; color: var(--text-primary);">
                                <%= chap.title %>
                            </td>
                            <td style="padding: 0.8rem; text-align: right;">
                                <a href="/admin/chapter/edit/<%= chap.id %>?redirect_to=/admin/story/edit/<%= story.id %>" class="btn btn-secondary" style="padding: 0.2rem 0.5rem; font-size: 0.8rem; margin-right: 0.2rem; display: inline-block;">
                                    ✏️ Sửa
                                </a>
                                <button type="button" class="btn btn-secondary btn-delete-single" data-id="<%= chap.id %>" data-title="<%= chap.title %>" style="background: rgba(239, 68, 68, 0.1); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.2); padding: 0.2rem 0.5rem; font-size: 0.8rem; cursor: pointer;">
                                    🗑️ Xoá
                                </button>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } %>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/mammoth/1.6.0/mammoth.browser.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
<script>
    pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.worker.min.js';
</script>

<script>
    // Hiển thị tên tệp ảnh khi được chọn mới
    const fileInput = document.getElementById('cover');
    const fileNameDisplay = document.getElementById('file-name');
    if (fileInput && fileNameDisplay) {
        fileInput.addEventListener('change', (e) => {
            if (e.target.files.length > 0) {
                fileNameDisplay.textContent = e.target.files[0].name;
            } else {
                fileNameDisplay.textContent = 'Chưa chọn tệp mới';
            }
        });
    }

    // Logic ẩn/hiện form đăng chương dựa trên phương thức đăng
    const methodRadios = document.querySelectorAll('input[name="publish_method"]');
    const formManual = document.getElementById('form-manual');
    const formBulk = document.getElementById('form-bulk');
    const formPdf = document.getElementById('form-pdf');
    const formEpub = document.getElementById('form-epub');
    
    // Các trường bắt buộc
    const chapNumInput = document.getElementById('chapter_number');
    const chapTitleInput = document.getElementById('title');
    const chapContentInput = document.getElementById('content');
    const bulkFileInput = document.getElementById('txtfile');
    const pdfFileInput = document.getElementById('pdffile');
    const epubFileInput = document.getElementById('epubfile');

    function toggleForms() {
        const selectedMethod = document.querySelector('input[name="publish_method"]:checked').value;
        
        formManual.style.display = selectedMethod === 'manual' ? 'block' : 'none';
        formBulk.style.display   = selectedMethod === 'bulk'   ? 'block' : 'none';
        formPdf.style.display    = selectedMethod === 'pdf'    ? 'block' : 'none';
        formEpub.style.display   = selectedMethod === 'epub'   ? 'block' : 'none';

        if (chapNumInput) chapNumInput.required = selectedMethod === 'manual';
        if (chapTitleInput) chapTitleInput.required = selectedMethod === 'manual';
        if (chapContentInput) chapContentInput.required = selectedMethod === 'manual';
        if (bulkFileInput) bulkFileInput.required = selectedMethod === 'bulk';
        if (pdfFileInput) pdfFileInput.required = selectedMethod === 'pdf';
        if (epubFileInput) epubFileInput.required = selectedMethod === 'epub';
    }

    methodRadios.forEach(radio => {
        radio.addEventListener('change', toggleForms);
    });

    // Chạy khi khởi động trang
    toggleForms();

    // Caching variables and FileReader helper
    function readFileAsArrayBuffer(file) {
        return new Promise((resolve, reject) => {
            const reader = new FileReader();
            reader.onload = () => resolve(reader.result);
            reader.onerror = () => reject(reader.error || new Error('Không thể đọc tệp tin.'));
            reader.readAsArrayBuffer(file);
        });
    }

    let cachedEpubArrayBuffer = null;
    let cachedPdfArrayBuffer = null;

    if (epubFileInput) {
        epubFileInput.addEventListener('change', async () => {
            const file = epubFileInput.files[0];
            const msgEl = document.getElementById('epub-status-msg');
            if (msgEl) {
                msgEl.style.display = 'block';
                msgEl.style.color = 'var(--text-secondary)';
                msgEl.textContent = '⏳ Đang nạp tệp vào bộ nhớ RAM...';
            }
            if (file) {
                try {
                    cachedEpubArrayBuffer = await readFileAsArrayBuffer(file);
                    if (msgEl) {
                        msgEl.style.color = '#10b981';
                        msgEl.innerHTML = `✅ Tệp đã nạp vào bộ nhớ RAM thành công (${(file.size / (1024 * 1024)).toFixed(2)} MB). Sẵn sàng đăng!`;
                    }
                    console.log('EPUB pre-loaded successfully.');
                } catch (err) {
                    console.error('Failed to pre-load EPUB:', err);
                    if (msgEl) {
                        msgEl.style.color = '#ef4444';
                        msgEl.innerHTML = `❌ Lỗi đọc tệp: ${err.message}. Vui lòng thử lại hoặc dùng trình duyệt khác.`;
                    }
                }
            } else {
                cachedEpubArrayBuffer = null;
                if (msgEl) msgEl.style.display = 'none';
            }
        });
    }

    if (pdfFileInput) {
        pdfFileInput.addEventListener('change', async () => {
            const file = pdfFileInput.files[0];
            const msgEl = document.getElementById('pdf-status-msg');
            if (msgEl) {
                msgEl.style.display = 'block';
                msgEl.style.color = 'var(--text-secondary)';
                msgEl.textContent = '⏳ Đang nạp tệp vào bộ nhớ RAM...';
            }
            if (file) {
                try {
                    cachedPdfArrayBuffer = await readFileAsArrayBuffer(file);
                    if (msgEl) {
                        msgEl.style.color = '#10b981';
                        msgEl.innerHTML = `✅ Tệp đã nạp vào bộ nhớ RAM thành công (${(file.size / (1024 * 1024)).toFixed(2)} MB). Sẵn sàng đăng!`;
                    }
                    console.log('PDF pre-loaded successfully.');
                } catch (err) {
                    console.error('Failed to pre-load PDF:', err);
                    if (msgEl) {
                        msgEl.style.color = '#ef4444';
                        msgEl.innerHTML = `❌ Lỗi đọc tệp: ${err.message}. Vui lòng thử lại hoặc dùng trình duyệt khác.`;
                    }
                }
            } else {
                cachedPdfArrayBuffer = null;
                if (msgEl) msgEl.style.display = 'none';
            }
        });
    }

    // EPUB helper functions
    function resolveRelativePath(basePath, relativePath) {
        const parts = basePath.split('/');
        parts.pop();
        const relParts = relativePath.split('/');
        for (const part of relParts) {
            if (part === '.') continue;
            if (part === '..') {
                parts.pop();
            } else {
                parts.push(part);
            }
        }
        return parts.join('/');
    }

    async function extractTextAndImages(doc, zip, xhtmlPath, submitBtn) {
        let result = '';
        async function traverse(node) {
            if (node.nodeType === 3) {
                result += node.nodeValue;
            } else if (node.nodeType === 1) {
                const tagName = node.tagName.toLowerCase();
                if (tagName === 'style' || tagName === 'script') return;
                
                if (tagName === 'img') {
                    const src = node.getAttribute('src');
                    if (src) {
                        try {
                            const resolvedPath = resolveRelativePath(xhtmlPath, src);
                            const imgFile = zip.file(resolvedPath) || zip.file(decodeURIComponent(resolvedPath));
                            if (imgFile) {
                                const ext = resolvedPath.split('.').pop().toLowerCase();
                                const mimeType = ext === 'jpg' || ext === 'jpeg' ? 'image/jpeg' : ext === 'gif' ? 'image/gif' : 'image/png';
                                submitBtn.textContent = `⏳ Đang tải ảnh ${resolvedPath} lên Supabase...`;
                                const blob = await imgFile.async('blob');
                                const publicUrl = await uploadBlobToSupabase(blob, mimeType);
                                result += `\n<img src="${publicUrl}" alt="Ảnh minh họa" style="max-width:100%; display:block; margin:1rem auto; border-radius:8px;">\n`;
                            }
                        } catch (err) {
                            console.error('Lỗi xử lý ảnh trong EPUB:', err);
                        }
                    }
                    return;
                }
                if (tagName === 'image' && node.getAttribute('xlink:href')) {
                    const href = node.getAttribute('xlink:href');
                    try {
                        const resolvedPath = resolveRelativePath(xhtmlPath, href);
                        const imgFile = zip.file(resolvedPath) || zip.file(decodeURIComponent(resolvedPath));
                        if (imgFile) {
                            const ext = resolvedPath.split('.').pop().toLowerCase();
                            const mimeType = ext === 'jpg' || ext === 'jpeg' ? 'image/jpeg' : ext === 'gif' ? 'image/gif' : 'image/png';
                            submitBtn.textContent = `⏳ Đang tải ảnh ${resolvedPath} lên Supabase...`;
                            const blob = await imgFile.async('blob');
                            const publicUrl = await uploadBlobToSupabase(blob, mimeType);
                            result += `\n<img src="${publicUrl}" alt="Ảnh minh họa" style="max-width:100%; display:block; margin:1rem auto; border-radius:8px;">\n`;
                        }
                    } catch (err) {
                        console.error('Lỗi xử lý ảnh SVG trong EPUB:', err);
                    }
                    return;
                }
                for (const child of node.childNodes) {
                    await traverse(child);
                }
                if (['p', 'div', 'br', 'h1', 'h2', 'h3', 'h4', 'h5', 'h6', 'li', 'tr'].includes(tagName)) {
                    result += '\n';
                }
            }
        }
        await traverse(doc.body || doc.documentElement);
        return result;
    }

    async function extractEpubChapters(file, submitBtn) {
        const arrayBuffer = cachedEpubArrayBuffer || await readFileAsArrayBuffer(file);
        const zip = await JSZip.loadAsync(arrayBuffer);
        const containerXmlFile = zip.file('META-INF/container.xml');
        if (!containerXmlFile) throw new Error('File EPUB thiếu container.xml');
        const containerXml = await containerXmlFile.async('string');
        const opfPathMatch = containerXml.match(/full-path="([^"]+)"/);
        if (!opfPathMatch) throw new Error('Không tìm thấy content.opf');
        const opfPath = opfPathMatch[1];
        const opfDir = opfPath.includes('/') ? opfPath.substring(0, opfPath.lastIndexOf('/') + 1) : '';

        const opfFile = zip.file(opfPath);
        if (!opfFile) throw new Error('Không đọc được content.opf');
        const opfXml = await opfFile.async('string');
        const manifest = {};
        const manifestRegex = /<item\s+[^>]*id="([^"]+)"[^>]*href="([^"]+)"[^>]*\/?>/g;
        let mm;
        while ((mm = manifestRegex.exec(opfXml)) !== null) {
            manifest[mm[1]] = mm[2];
        }
        const manifestRegex2 = /<item\s+[^>]*href="([^"]+)"[^>]*id="([^"]+)"[^>]*\/?>/g;
        while ((mm = manifestRegex2.exec(opfXml)) !== null) {
            manifest[mm[2]] = mm[1];
        }

        const spineIds = [];
        const spineRegex = /<itemref\s+[^>]*idref="([^"]+)"/g;
        let sm;
        while ((sm = spineRegex.exec(opfXml)) !== null) {
            spineIds.push(sm[1]);
        }
        const orderedHrefs = spineIds.map(id => manifest[id]).filter(Boolean);
        if (orderedHrefs.length === 0) throw new Error('Không đọc được spine trong EPUB.');

        let chapters = [];
        let chapCount = 1;
        for (let i = 0; i < orderedHrefs.length; i++) {
            submitBtn.textContent = `⏳ Đang đọc phần ${i + 1}/${orderedHrefs.length} của EPUB...`;
            const href = orderedHrefs[i];
            const fullHref = (opfDir + href).replace(/\\/g, '/');
            const zipFile = zip.file(fullHref) || zip.file(decodeURIComponent(fullHref));
            if (!zipFile) continue;

            const xhtml = await zipFile.async('string');
            const parser = new DOMParser();
            const doc = parser.parseFromString(xhtml, 'text/html');
            
            // Lấy tiêu đề của chương từ h1, h2, h3 hoặc title
            let title = '';
            const heading = doc.querySelector('h1, h2, h3, title');
            if (heading) {
                title = heading.textContent.trim();
            }
            
            // Làm sạch tiêu đề
            if (!title || title.toLowerCase() === 'untitled' || title.toLowerCase().includes('thông tin chung')) {
                // Bỏ qua các trang metadata hoặc thông tin chung nếu nội dung quá ngắn
                const bodyTextLength = doc.body.textContent.trim().length;
                if (bodyTextLength < 200 && (title.toLowerCase().includes('thông tin chung') || title.toLowerCase().includes('giới thiệu') || title.toLowerCase().includes('mục lục') || title.toLowerCase().includes('tác giả'))) {
                    console.log(`Bỏ qua trang metadata: ${href}`);
                    continue;
                }
                title = `Chương ${chapCount}`;
            }
            
            // Trích xuất nội dung HTML (đã giải quyết hình ảnh)
            const bodyHtml = await extractTextAndImages(doc, zip, fullHref, submitBtn);
            
            // Format nội dung thành HTML sạch
            const formattedContent = bodyHtml.split('\n')
                .filter(line => line.trim().length > 0)
                .map(line => line.trim().startsWith('<img') ? line : `<p>${line}</p>`)
                .join('');
            
            if (formattedContent.trim().length > 0) {
                chapters.push({
                    name: `${title}.txt`,
                    type: 'txt',
                    content: formattedContent
                });
                chapCount++;
            }
        }
        return chapters;
    }

    // Helper to strip lone surrogates
    function stripLoneSurrogates(str) {
        if (!str) return str;
        return str
            .replace(/[\uD800-\uDBFF](?![\uDC00-\uDFFF])|(?:[^\uD800-\uDBFF]|^)[\uDC00-\uDFFF]/g, '')
            .replace(/\u0000/g, '')
            .replace(/[\u0000-\u0008\u000B\u000C\u000E-\u001F]/g, '');
    }

    function extractPageTextByLines(textContent) {
        const items = textContent.items;
        if (items.length === 0) return '';
        const lineMap = new Map();
        for (const item of items) {
            const y = Math.round(item.transform[5]);
            if (!lineMap.has(y)) lineMap.set(y, []);
            lineMap.get(y).push(item);
        }
        const sortedYs = Array.from(lineMap.keys()).sort((a, b) => b - a);
        const lines = sortedYs.map(y => {
            const lineItems = lineMap.get(y).sort((a, b) => a.transform[4] - b.transform[4]);
            return lineItems.map(it => it.str).join('').trim();
        });
        return stripLoneSurrogates(lines.filter(l => l.length > 0).join('\n'));
    }

    // INTERCEPT FORM SUBMIT ĐĂNG CHƯƠNG ĐỂ XỬ LÝ PHÍA TRÌNH DUYỆT (TRÁNH LỖI VERCEL 4.5MB PAYLOAD)
    const chapterForm = document.querySelector('form[action="/admin/chapter/add"]');
    function splitTextIntoChapters(rawText, fileName) {
        const chapterHeaderRegex = /^(?:Chương|CHƯƠNG|Chap|CHAP|Chapter|CHAPTER|Phần|PHẦN|Part|PART)\s*\.?\s*(\d+(?:\.\d+)?)(?:[:\s,\-–]+(.*))?$/im;
        const lines = rawText.split('\n');
        const chapters = [];
        let currentChapter = null;
        let currentLines = [];

        for (let i = 0; i < lines.length; i++) {
            const line = lines[i].trim();
            if (!line) continue;
            const match = line.match(chapterHeaderRegex);

            if (match) {
                if (currentChapter !== null) {
                    chapters.push({
                        name: currentChapter.title + '.txt',
                        type: 'txt',
                        content: currentLines.map(l => `<p>${l}</p>`).join('')
                    });
                }
                const chapNum = parseFloat(match[1]);
                const chapTitle = match[2] ? match[2].trim() : '';
                currentChapter = {
                    title: chapTitle ? `Chương ${chapNum}: ${chapTitle}` : `Chương ${chapNum}`
                };
                currentLines = [];
            } else if (currentChapter !== null) {
                currentLines.push(line);
            }
        }

        if (currentChapter !== null && currentLines.length > 0) {
            chapters.push({
                name: currentChapter.title + '.txt',
                type: 'txt',
                content: currentLines.map(l => `<p>${l}</p>`).join('')
            });
        }
        
        if (chapters.length === 0) {
            chapters.push({
                name: fileName.replace(/\.pdf$/i, '.txt'),
                type: 'txt',
                content: lines.filter(l => l.trim()).map(l => `<p>${l.trim()}</p>`).join('')
            });
        }
        
        return chapters;
    }

    async function uploadInBatches(storyId, processedFiles, submitBtn) {
        let successCount = 0;
        const MAX_RETRIES = 3;
        const MAX_PAYLOAD_SIZE = 2 * 1024 * 1024; // Giới hạn an toàn 2MB tránh lỗi 413 Payload Too Large của Vercel (4.5MB)
        
        let i = 0;
        while (i < processedFiles.length) {
            let batch = [];
            let currentSize = 0;
            
            // Gom nhóm động dựa trên kích thước chuỗi JSON thực tế của từng chương
            while (i < processedFiles.length && batch.length < 15) {
                const f = processedFiles[i];
                const cleanedContent = typeof f.content === 'string' ? stripLoneSurrogates(f.content) : f.content;
                const fileItem = { ...f, content: cleanedContent };
                const itemSize = JSON.stringify(fileItem).length;
                
                // Nếu thêm chương này vào làm lô vượt quá 2MB, dừng gom và gửi lô hiện tại trước
                if (batch.length > 0 && currentSize + itemSize > MAX_PAYLOAD_SIZE) {
                    break;
                }
                
                batch.push(fileItem);
                currentSize += itemSize;
                i++;
            }
            
            let lastError = null;
            let ok = false;

            for (let attempt = 1; attempt <= MAX_RETRIES && !ok; attempt++) {
                const retryLabel = attempt > 1 ? ` (thử lại lần ${attempt}/${MAX_RETRIES})` : '';
                submitBtn.textContent = `⏳ Đang lưu database (${successCount + 1} - ${successCount + batch.length} / ${processedFiles.length})${retryLabel}...`;

                try {
                    const response = await fetch('/admin/chapter/add-json', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ story_id: storyId, files: batch })
                    });

                    let data;
                    if (response.headers.get('content-type')?.includes('application/json')) {
                        data = await response.json();
                    } else {
                        const txt = await response.text();
                        throw new Error('Lỗi máy chủ (' + response.status + '): ' + txt.substring(0, 200));
                    }

                    if (!data.success) throw new Error(data.error);

                    ok = true;
                    successCount += batch.length;
                } catch (err) {
                    lastError = err;
                    if (attempt < MAX_RETRIES) {
                        await new Promise(r => setTimeout(r, 1500)); // Chờ 1.5s trước khi thử lại
                    }
                }
            }

            if (!ok) {
                throw new Error(
                    `Đã thử ${MAX_RETRIES} lần vẫn lỗi ở lô chương từ thứ ${successCount + 1}: ${lastError ? lastError.message : 'Không rõ nguyên nhân'}. ` +
                    `${successCount} chương trước đó đã lưu thành công - có thể bật "Đăng tiếp thông minh" và đăng lại tệp tin để tiếp tục.`
                );
            }
        }
        return successCount;
    }

    if (chapterForm) {
        chapterForm.addEventListener('submit', async (e) => {
            const selectedMethod = document.querySelector('input[name="publish_method"]:checked').value;
            if (selectedMethod === 'bulk' || selectedMethod === 'pdf' || selectedMethod === 'epub') {
                e.preventDefault();
 
                const submitBtn = chapterForm.querySelector('button[type="submit"]');
                const originalBtnText = submitBtn.textContent;
                submitBtn.disabled = true;
 
                try {
                    const storyId = chapterForm.querySelector('input[name="story_id"]').value;
                    const redirectTo = chapterForm.querySelector('input[name="redirect_to"]').value;
                    let processedFiles = [];
 
                    if (selectedMethod === 'bulk') {
                        submitBtn.textContent = '⏳ Đang xử lý file và tải ảnh lên...';
                        const files = bulkFileInput.files;
                        if (!files || files.length === 0) {
                            alert('Vui lòng chọn tệp tin truyện.');
                            submitBtn.disabled = false;
                            submitBtn.textContent = originalBtnText;
                            return;
                        }
                        for (let file of files) {
                            const isDocx = file.name.endsWith('.docx');
                            if (isDocx) {
                                const arrayBuffer = await readFileAsArrayBuffer(file);
                                const result = await mammoth.convertToHtml({ arrayBuffer: arrayBuffer });
                                let html = result.value;
                                const parser = new DOMParser();
                                const doc = parser.parseFromString(html, 'text/html');
                                const imgs = doc.querySelectorAll('img');
                                const includeImages = document.getElementById('include_images_edit').checked;
 
                                if (includeImages) {
                                    if (imgs.length > 0) {
                                        submitBtn.textContent = `⏳ Đang tải ${imgs.length} ảnh trong file lên Supabase...`;
                                    }
                                    for (let img of imgs) {
                                        const src = img.getAttribute('src');
                                        if (src && src.startsWith('data:')) {
                                            const blob = dataURLtoBlob(src);
                                            const publicUrl = await uploadBlobToSupabase(blob, blob.type);
                                            img.setAttribute('src', publicUrl);
                                        }
                                    }
                                } else {
                                    imgs.forEach(img => img.remove());
                                }
                                html = doc.body.innerHTML;
                                processedFiles.push({ name: file.name, type: 'docx', content: html });
                            } else {
                                const text = await file.text();
                                const splitted = splitTextIntoChapters(text, file.name);
                                processedFiles.push(...splitted);
                            }
                        }
                    } else if (selectedMethod === 'pdf') {
                        submitBtn.textContent = '⏳ Đang đọc PDF trên trình duyệt...';
                        const file = pdfFileInput.files[0];
                        if (!file) {
                            alert('Vui lòng chọn file PDF.');
                            submitBtn.disabled = false;
                            submitBtn.textContent = originalBtnText;
                            return;
                        }
                        const arrayBuffer = cachedPdfArrayBuffer || await readFileAsArrayBuffer(file);
                        const pdf = await pdfjsLib.getDocument({ data: arrayBuffer }).promise;
                        let fullText = '';
                        for (let i = 1; i <= pdf.numPages; i++) {
                            submitBtn.textContent = `⏳ Đang đọc trang ${i}/${pdf.numPages}...`;
                            const page = await pdf.getPage(i);
                            const textContent = await page.getTextContent();
                            fullText += extractPageTextByLines(textContent) + '\n';
                        }
                        processedFiles = splitTextIntoChapters(fullText, file.name);
                    } else if (selectedMethod === 'epub') {
                        submitBtn.textContent = '⏳ Đang đọc EPUB trên trình duyệt...';
                        const file = epubFileInput.files[0];
                        if (!file) {
                            alert('Vui lòng chọn file EPUB.');
                            submitBtn.disabled = false;
                            submitBtn.textContent = originalBtnText;
                            return;
                        }
                        processedFiles = await extractEpubChapters(file, submitBtn);
                    }
 
                    await uploadInBatches(storyId, processedFiles, submitBtn);
                    window.location.href = redirectTo + '?success=' + encodeURIComponent(`Đã tải lên ${processedFiles.length} chương thành công`);

                } catch (err) {
                    console.error(err);
                    alert('Có lỗi xảy ra: ' + err.message);
                    submitBtn.disabled = false;
                    submitBtn.textContent = originalBtnText;
                }
            }
        });
    }

    // Hàm chuyển đổi ảnh base64 thành Blob
    function dataURLtoBlob(dataurl) {
        var arr = dataurl.split(','), mime = arr[0].match(/:(.*?);/)[1],
            bstr = atob(arr[1]), n = bstr.length, u8arr = new Uint8Array(n);
        while(n--){
            u8arr[n] = bstr.charCodeAt(n);
        }
        return new Blob([u8arr], {type:mime});
    }

    // Hàm upload blob thẳng lên Supabase Storage từ Browser
    async function uploadBlobToSupabase(blob, mimeType) {
        const fileExt = mimeType === 'image/jpeg' ? '.jpg' : '.png';
        const fileName = `word-img-${Date.now()}-${Math.round(Math.random() * 1E9)}${fileExt}`;
        
        const supabaseUrl = 'https://xlaqupbqiwpoprywnkgi.supabase.co';
        const anonKey = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InhsYXF1cGJxaXdwb3ByeXdua2dpIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODM1ODkxNDcsImV4cCI6MjA5OTE2NTE0N30.v0NZKDhVb4ysx03cmx_aQn6aGBMCO6lWzBUN6--JKB0';

        const response = await fetch(`${supabaseUrl}/storage/v1/object/uploads/${fileName}`, {
            method: 'POST',
            headers: {
                'Authorization': `Bearer ${anonKey}`,
                'apikey': anonKey,
                'Content-Type': mimeType
            },
            body: blob
        });

        if (!response.ok) {
            const errText = await response.text();
            throw new Error(`Upload ảnh thất bại: ${errText}`);
        }

        return `${supabaseUrl}/storage/v1/object/public/uploads/${fileName}`;
    }

    // --- LOGIC XỬ LÝ CHỌN VÀ XÓA HÀNG LOẠT CHƯƠNG ---
    const selectAllCheckbox = document.getElementById('select-all-chapters');
    const chapterCheckboxes = document.querySelectorAll('.chapter-checkbox');
    const btnDeleteSelected = document.getElementById('btn-delete-selected');
    const btnDeleteAll = document.getElementById('btn-delete-all');
