    function updateDeleteSelectedButton() {
        const checkedCount = document.querySelectorAll('.chapter-checkbox:checked').length;
        if (selectedCountSpan) selectedCountSpan.textContent = checkedCount;
        if (btnDeleteSelected) {
            btnDeleteSelected.disabled = checkedCount === 0;
            if (checkedCount > 0) {
                btnDeleteSelected.style.background = 'rgba(239, 68, 68, 0.25)';
                btnDeleteSelected.style.cursor = 'pointer';
            } else {
                btnDeleteSelected.style.background = 'rgba(239, 68, 68, 0.15)';
                btnDeleteSelected.style.cursor = 'not-allowed';
            }
        }
    }

    if (selectAllCheckbox) {
        selectAllCheckbox.addEventListener('change', () => {
            chapterCheckboxes.forEach(cb => {
                cb.checked = selectAllCheckbox.checked;
            });
            updateDeleteSelectedButton();
        });
