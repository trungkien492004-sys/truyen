    // Hàm gọi API xóa chương
    async function deleteChapters(ids, action) {
        try {
            const response = await fetch('/admin/chapter/delete-bulk', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    ids: ids,
                    action: action,
                    story_id: '<%= story.id %>'
                })
            });

            const resData = await response.json();
            if (resData.success) {
                window.location.href = '/admin/story/edit/<%= story.id %>?success=' + encodeURIComponent(resData.message);
            } else {
                alert('Lỗi: ' + resData.error);
                // Reset state
                if (btnDeleteSelected) {
                    btnDeleteSelected.disabled = false;
                    btnDeleteSelected.textContent = `🗑️ Xoá đã chọn`;
                }
                if (btnDeleteAll) {
                    btnDeleteAll.disabled = false;
                    btnDeleteAll.textContent = `💥 Xoá tất cả`;
                }
            }
        } catch (err) {
            console.error(err);
            alert('Lỗi kết nối máy chủ: ' + err.message);
        }
    }

    if (btnDeleteSelected) {
        btnDeleteSelected.addEventListener('click', () => {
            const checkedBoxes = document.querySelectorAll('.chapter-checkbox:checked');
            const ids = Array.from(checkedBoxes).map(cb => cb.value);
