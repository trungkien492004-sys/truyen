<%- include('../partials/header') %>

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem;">
    <h1 class="section-title" style="margin-bottom: 0;">🛠️ Bảng Điều Khiển Quản Trị</h1>
    <div style="display: flex; flex-wrap: wrap; gap: 0.8rem;">
        <a href="/admin/story/add" class="btn btn-primary">➕ Đăng bộ truyện mới</a>
        <button id="btn-sync-donghentai" class="btn btn-secondary" style="background: rgba(16, 185, 129, 0.15); border-color: rgba(16, 185, 129, 0.4); color: #10b981; font-weight: 600;">🔄 Quét Cập Nhật DongHentai</button>
        <a href="/admin/chapter/add" class="btn btn-secondary">⚡ Đăng chương truyện</a>
        <a href="/admin/genres" class="btn btn-secondary">🏷️ Thể loại</a>
        <a href="/admin/banners" class="btn btn-secondary">📺 Quản lý Banner</a>
        <a href="/admin/requests" class="btn btn-secondary" style="background: rgba(245, 158, 11, 0.1); border-color: rgba(245, 158, 11, 0.3); color: #f59e0b;">💬 Yêu cầu độc giả</a>
        <a href="/admin/comments" class="btn btn-secondary" style="background: rgba(139, 92, 246, 0.1); border-color: rgba(139, 92, 246, 0.3); color: #a78bfa;">💬 Bình luận & User</a>
        <a href="/admin/ranks" class="btn btn-secondary" style="background: rgba(16, 185, 129, 0.1); border-color: rgba(16, 185, 129, 0.3); color: #10b981;">🏆 Thiết lập Rank cấp bậc</a>
        <a href="/admin/shop" class="btn btn-secondary" style="background: rgba(236, 72, 153, 0.1); border-color: rgba(236, 72, 153, 0.3); color: #ec4899;">🛒 Quản lý Cửa hàng EXP</a>
    </div>
</div>

<!-- KHỐI CÀO TRUYỆN DONGHENTAI THỦ CÔNG QUA URL/SLUG -->
<div class="admin-box" style="margin-bottom: 2rem; border-left: 4px solid var(--accent-color); background: rgba(99, 102, 241, 0.05); padding: 1.5rem; border-radius: 0 16px 16px 0;">
    <h3 style="margin-top: 0; margin-bottom: 0.8rem; font-size: 1.15rem; color: var(--text-primary); display: flex; align-items: center; gap: 0.5rem;">🕷️ Cào Truyện Tranh DongHentai Thủ Công</h3>
    <p style="font-size: 0.85rem; color: var(--text-secondary); margin: 0 0 1.2rem 0;">Dán link truyện hoặc gõ slug (Ví dụ: <code>https://donghentai.xyz/manga/su-hoan-doi-bat-ngo</code> hoặc chỉ cần gõ <code>su-hoan-doi-bat-ngo</code>) để tự động tạo truyện và tải chương về DB.</p>
    <div style="display: flex; gap: 0.8rem; max-width: 650px; flex-wrap: wrap;">
        <input type="text" id="input-crawl-slug" placeholder="Dán link DongHentai hoặc nhập slug truyện..." style="flex: 1; min-width: 250px; padding: 0.7rem 1rem; background: var(--bg-primary); border: 1px solid var(--border-color); color: var(--text-primary); border-radius: 8px; font-size: 0.95rem; outline: none; box-sizing: border-box;">
        <button id="btn-crawl-manual" class="btn btn-primary" style="padding: 0.7rem 1.5rem; font-size: 0.95rem; font-weight: bold; min-width: 140px;">🚀 Cào Ngay</button>
    </div>
</div>

<!-- Khối hiển thị số liệu thống kê nhanh -->
<div class="admin-stats">
    <div class="stat-card">
        <span class="stat-value"><%= stats.stories %></span>
        <span class="stat-label">Truyện đã đăng</span>
    </div>
    <div class="stat-card">
        <span class="stat-value"><%= stats.chapters %></span>
        <span class="stat-label">Tổng số chương</span>
    </div>
    <div class="stat-card">
        <span class="stat-value"><%= stats.views %></span>
        <span class="stat-label">Tổng lượt đọc truyện</span>
    </div>
    <div class="stat-card">
        <span class="stat-value"><%= stats.requests %></span>
        <span class="stat-label">Yêu cầu từ độc giả</span>
    </div>
</div>

<!-- Danh sách truyện đã đăng -->
<div class="admin-box" style="margin-top: 2rem;">
    <h2 class="section-title" style="font-size: 1.4rem; margin-bottom: 0.5rem;">Danh Sách Các Bộ Truyện</h2>
    
    <!-- Ô tìm kiếm truyện trong admin -->
    <div style="margin-bottom: 1.5rem; max-width: 450px;">
        <input type="text" id="admin-story-search" placeholder="🔍 Gõ từ khóa tìm nhanh truyện (tên, tác giả, người đặt)..." 
            style="width: 100%; padding: 0.7rem 1rem; background: var(--bg-primary); border: 1px solid var(--border-color); color: var(--text-primary); border-radius: 8px; font-size: 0.9rem; outline: none; box-sizing: border-box;">
    </div>
    
    <% if (stories.length === 0) { %>
        <p style="color: var(--text-secondary); text-align: center; padding: 2rem 0;">Chưa có bộ truyện nào được tạo. Hãy bấm vào "Đăng bộ truyện mới" để bắt đầu.</p>
    <% } else { %>
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Bìa</th>
                    <th>Tên Truyện</th>
                    <th>Tác Giả</th>
                    <th>Người Đặt</th>
                    <th>Ngày Đăng</th>
                    <th>Hành Động</th>
                </tr>
            </thead>
            <tbody>
                <% stories.forEach(story => { %>
                    <tr>
                        <td>
                            <img src="<%= story.cover_url %>" alt="Cover" style="width: 40px; height: 50px; object-fit: cover; border-radius: 4px;">
                        </td>
                        <td>
                            <strong><%= story.title %></strong>
                        </td>
                        <td><%= story.author %></td>
                        <td>
                            <% if (story.commissioned_by) { %>
                                <span style="font-size: 0.85rem; color: #10b981; background: rgba(16, 185, 129, 0.1); padding: 0.2rem 0.5rem; border-radius: 4px;"><%= story.commissioned_by %></span>
                            <% } else { %>
                                <span style="color: var(--text-secondary); font-size: 0.85rem;">-</span>
                            <% } %>
                        </td>
                        <td><%= new Date(story.created_at).toLocaleDateString('vi-VN') %></td>
                        <td>
                            <div style="display: flex; gap: 0.5rem; align-items: center;">
                                <a href="/story/<%= story.id %>" class="btn btn-secondary" style="padding: 0.3rem 0.6rem; font-size: 0.8rem;" target="_blank">Xem</a>
                                <a href="/admin/story/edit/<%= story.id %>" class="btn btn-secondary" style="padding: 0.3rem 0.6rem; font-size: 0.8rem; background: rgba(59, 130, 246, 0.1); border-color: rgba(59, 130, 246, 0.2); color: var(--accent-color);">Sửa</a>
                                <a href="/admin/story/download-epub/<%= story.id %>" class="btn btn-secondary" style="padding: 0.3rem 0.6rem; font-size: 0.8rem; background: rgba(16, 185, 129, 0.1); border-color: rgba(16, 185, 129, 0.2); color: #10b981;">Tải EPUB</a>
                                <% if (user && (user.role === 'admin' || user.role === 'sp_admin')) { %>
                                <form action="/admin/story/delete/<%= story.id %>" method="POST" onsubmit="return confirm('Bạn có chắc chắn muốn xóa bộ truyện này không? Tất cả các chương truyện, lượt đọc và thể loại liên kết của bộ truyện này sẽ bị xóa vĩnh viễn!');" style="display: inline; margin: 0;">
                                    <button type="submit" class="btn btn-danger" style="padding: 0.3rem 0.6rem; font-size: 0.8rem; border-radius: 4px;">Xóa</button>
                                </form>
                                <% } %>
                            </div>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    <% } %>
</div>

<script>
    const searchInput = document.getElementById('admin-story-search');
    if (searchInput) {
        searchInput.addEventListener('input', function() {
            const query = this.value.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").trim();
            const rows = document.querySelectorAll('.admin-table tbody tr');
            
            rows.forEach(row => {
                const titleCell = row.querySelector('td:nth-child(2)');
                const authorCell = row.querySelector('td:nth-child(3)');
                const commissionedCell = row.querySelector('td:nth-child(4)');
                
                const title = titleCell ? titleCell.textContent.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "") : '';
                const author = authorCell ? authorCell.textContent.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "") : '';
                const commissioned = commissionedCell ? commissionedCell.textContent.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "") : '';
                
                if (title.includes(query) || author.includes(query) || commissioned.includes(query)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        });
    }

    const btnSync = document.getElementById('btn-sync-donghentai');
    if (btnSync) {
        btnSync.addEventListener('click', async function() {
            if (!confirm('Bạn có muốn kích hoạt quét tự động các bộ truyện & chương vừa cập nhật mới nhất từ DongHentai không? (Truyện 0 chương sẽ bị loại bỏ hoàn toàn)')) {
                return;
            }
            btnSync.disabled = true;
            btnSync.textContent = '⏳ Đang quét & đồng bộ...';
            try {
                const res = await fetch('/api/cron/sync-donghentai?pages=3');
                const data = await res.json();
                alert('✅ ' + data.message + '\nTiến trình đang chạy ngầm trên server.');
            } catch(e) {
                alert('❌ Lỗi kích hoạt quét: ' + e.message);
            } finally {
                btnSync.disabled = false;
                btnSync.textContent = '🔄 Quét Cập Nhật DongHentai';
            }
        });
    }
    // Xử lý cào truyện tranh thủ công bằng Slug/Link
    const btnCrawlManual = document.getElementById('btn-crawl-manual');
    const inputCrawlSlug = document.getElementById('input-crawl-slug');
    if (btnCrawlManual && inputCrawlSlug) {
        btnCrawlManual.addEventListener('click', async function() {
            let val = inputCrawlSlug.value.trim();
            if (!val) {
                alert('Vui lòng nhập slug hoặc dán link truyện DongHentai!');
                return;
            }
            
            // Nếu người dùng dán link đầy đủ (ví dụ: https://donghentai.xyz/manga/ten-truyen), trích xuất slug
            if (val.includes('/manga/')) {
                const parts = val.split('/manga/');
                val = parts[parts.length - 1].replace(/\/$/, ''); // Lấy phần cuối và bỏ gạch chéo cuối nếu có
            } else if (val.includes('donghentai.')) {
                // Hỗ trợ link định dạng khác
                const parts = val.split('/');
                val = parts[parts.length - 1] || parts[parts.length - 2];
            }

            btnCrawlManual.disabled = true;
            btnCrawlManual.textContent = '⏳ Đang cào...';

            try {
                const res = await fetch('/admin/story/crawl-manual', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ slug: val })
                });
                const data = await res.json();
                if (data.success) {
                    alert('✅ ' + data.message);
                    location.reload();
                } else {
                    alert('❌ Lỗi cào truyện: ' + (data.error || 'Lỗi không xác định'));
                }
            } catch(e) {
                alert('❌ Lỗi hệ thống: ' + e.message);
            } finally {
                btnCrawlManual.disabled = false;
                btnCrawlManual.textContent = '🚀 Cào Ngay';
            }
        });
    }
</script>

<%- include('../partials/footer') %>
