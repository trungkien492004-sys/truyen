<%- include('../partials/header') %>

<div style="margin-bottom: 1.5rem;">
    <a href="/admin" style="color: var(--text-secondary); font-size: 0.9rem;">&larr; Quay lại Trang quản trị</a>
</div>

<div class="form-container" style="max-width: 700px;">
    <h2 class="section-title">⚡ Tách Chương Tự Động Từ File Văn Bản / Word</h2>
    
    <% if (success) { %>
        <div class="alert alert-success"><%= success %></div>
    <% } %>

    <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
    <% } %>

    <div style="background: rgba(59, 130, 246, 0.08); border-left: 4px solid var(--accent-color); padding: 1rem; border-radius: 0 8px 8px 0; margin-bottom: 2rem; font-size: 0.9rem; line-height: 1.5;">
        <strong>💡 Định dạng tệp tin được hỗ trợ:</strong><br>
        1. **File Word (.docx)**: Hỗ trợ trích xuất toàn bộ văn bản và **hình ảnh nhúng bên trong**. Hình ảnh sẽ tự động được lưu và hiển thị đan xen chữ.<br>
        2. **File Văn Bản (.txt)**: Chỉ hỗ trợ nội dung chữ thuần.<br><br>
        <strong>Quy tắc nhận diện chương:</strong><br>
        Đầu mỗi chương phải bắt đầu bằng tiêu đề dòng dạng: <code>Chương [Số]</code>, <code>Chap [Số]</code> hoặc <code>Chapter [Số]</code> ở đầu dòng.<br>
        *(Ví dụ: <strong>Chương 1: Khởi đầu mới</strong> hoặc <strong>Chap 2 - Bí cảnh</strong>)*
    </div>

    <% if (stories.length === 0) { %>
        <div class="alert alert-error">Chưa có bộ truyện nào. Vui lòng tạo bộ truyện trước.</div>
        <a href="/admin/story/add" class="btn btn-primary" style="width: 100%;">Tạo bộ truyện mới ngay</a>
    <% } else { %>
        <form action="/admin/chapter/add-bulk" method="POST" enctype="multipart/form-data">
            <div class="form-group">
                <label for="story_id">Chọn Bộ Truyện Đọc *</label>
                <select id="story_id" name="story_id" style="width: 100%; padding: 0.8rem 1rem; background: var(--bg-primary); border: 1px solid var(--border-color); color: var(--text-primary); border-radius: 8px; font-size: 1rem; outline: none;" required>
                    <option value="">-- Chọn truyện --</option>
                    <% stories.forEach(story => { %>
                        <option value="<%= story.id %>"><%= story.title %></option>
                    <% }) %>
                </select>
            </div>

            <div class="form-group">
                <label for="txtfile">Tải lên file văn bản (.txt) hoặc file Word (.docx) *</label>
                <input type="file" id="txtfile" name="txtfile" accept=".txt,.docx" required>
                <span style="font-size: 0.8rem; color: var(--text-secondary); margin-top: 0.3rem;">Hỗ trợ tệp tin định dạng .txt (UTF-8) hoặc .docx (Word có chứa chữ và hình ảnh nhúng).</span>
            </div>

            <button type="submit" class="btn btn-primary" style="width: 100%; padding: 0.8rem; font-size: 1rem; margin-top: 1rem;">BẮT ĐẦU TÁCH CHƯƠNG VÀ LƯU</button>
        </form>
    <% } %>
</div>

<%- include('../partials/footer') %>
