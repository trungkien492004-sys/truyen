<%- include('../partials/header') %>

<div style="margin-bottom: 1.5rem;">
    <a href="/admin" style="color: var(--text-secondary); font-size: 0.9rem;">&larr; Quay lại Trang quản trị</a>
</div>

<div class="form-container" style="max-width: 700px;">
    <h2 class="section-title">⚡ Tách Chương Tự Động Từ File Văn Bản</h2>
    
    <% if (success) { %>
        <div class="alert alert-success"><%= success %></div>
    <% } %>

    <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
    <% } %>

    <div style="background: rgba(59, 130, 246, 0.08); border-left: 4px solid var(--accent-color); padding: 1rem; border-radius: 0 8px 8px 0; margin-bottom: 2rem; font-size: 0.9rem; line-height: 1.5;">
        <strong>💡 Hướng dẫn định dạng file text (.txt):</strong><br>
        Để hệ thống tách chương chính xác, file của bạn phải bắt đầu tiêu đề chương ở đầu dòng có cấu trúc dạng:<br>
        <code>Chương [Số] [Dấu cách hoặc Dấu gạch ngang] [Tên chương nếu có]</code> hoặc <code>Chap [Số]: [Tên chương]</code><br><br>
        <strong>Ví dụ nội dung file hợp lệ:</strong>
        <pre style="background: var(--bg-primary); padding: 0.8rem; border-radius: 4px; border: 1px solid var(--border-color); overflow-x: auto; margin-top: 0.5rem; font-size: 0.8rem;">
Chương 1: Sự trỗi dậy
Nội dung của chương thứ nhất ở đây...
Mã viết dòng thứ hai...

Chương 2 - Gặp gỡ hồng nhan
Nội dung chương hai viết tiếp ở đây...
        </pre>
    </div>

    <% if (stories.length === 0) { %>
        <div class="alert alert-error">Chưa có bộ truyện nào. Vui lòng tạo bộ truyện trước.</div>
        <a href="/admin/story/add" class="btn btn-primary" style="width: 100%;">Tạo bộ truyện mới ngay</a>
    <% } else { %>
        <form action="/admin/chapter/add-bulk" method="POST" enctype="multipart/form-data">
            <div class="form-group">
                <label for="story_id">Chọn Bộ Truyện Đọc *</label>
                <select id="story_id" name="story_id" style="width: 100%; padding: 0.8rem 1rem; background: var(--bg-primary); border: 1px solid var(--border-color); color: var(--text-primary); border-radius: 8px; font-size: 1rem; outline: none;" required>
                    <option value="">-- Chọn truyện --</option>
                    <% stories.forEach(story => { %>
                        <option value="<%= story.id %>"><%= story.title %></option>
                    <% }) %>
                </select>
            </div>

            <div class="form-group">
                <label for="txtfile">Upload File Văn Bản (.txt) *</label>
                <input type="file" id="txtfile" name="txtfile" accept=".txt" required>
                <span style="font-size: 0.8rem; color: var(--text-secondary); margin-top: 0.3rem;">Chấp nhận file định dạng đuôi .txt đã mã hóa UTF-8 để không bị lỗi font chữ tiếng Việt.</span>
            </div>

            <button type="submit" class="btn btn-primary" style="width: 100%; padding: 0.8rem; font-size: 1rem; margin-top: 1rem;">BẮT ĐẦU TÁCH CHƯƠNG VÀ LƯU</button>
        </form>
    <% } %>
</div>

<%- include('../partials/footer') %>
