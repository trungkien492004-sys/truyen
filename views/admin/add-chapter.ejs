<%- include('../partials/header') %>

<div style="margin-bottom: 1.5rem;">
    <a href="/admin" style="color: var(--text-secondary); font-size: 0.9rem;">&larr; Quay lại Trang quản trị</a>
</div>

<div class="form-container" style="max-width: 750px;">
    <h2 class="section-title">⚡ Đăng Chương Truyện Mới</h2>
    
    <% if (success) { %>
        <div class="alert alert-success"><%= success %></div>
    <% } %>

    <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
    <% } %>

    <% if (stories.length === 0) { %>
        <div class="alert alert-error">Chưa có bộ truyện nào. Vui lòng tạo bộ truyện trước khi đăng chương.</div>
        <a href="/admin/story/add" class="btn btn-primary" style="width: 100%;">Tạo bộ truyện mới ngay</a>
    <% } else { %>
        <form action="/admin/chapter/add" method="POST" enctype="multipart/form-data">
            <!-- 1. CHỌN TRUYỆN -->
            <div class="form-group">
                <label for="story_id">Chọn Bộ Truyện Đọc *</label>
                <!-- Ô tìm kiếm truyện -->
                <div style="position: relative; margin-bottom: 0.5rem;">
                    <input type="text" id="story-search" placeholder="🔍 Tìm kiếm truyện theo tên..." autocomplete="off"
                        style="width: 100%; padding: 0.7rem 1rem; background: var(--bg-primary); border: 1px solid var(--border-color); color: var(--text-primary); border-radius: 8px; font-size: 0.95rem; outline: none; box-sizing: border-box;"
                        oninput="filterStories(this.value)">
                    <span id="story-search-count" style="position: absolute; right: 0.8rem; top: 50%; transform: translateY(-50%); font-size: 0.8rem; color: var(--text-secondary); pointer-events: none;"></span>
                </div>
                <select id="story_id" name="story_id" style="width: 100%; padding: 0.8rem 1rem; background: var(--bg-primary); border: 1px solid var(--border-color); color: var(--text-primary); border-radius: 8px; font-size: 1rem; outline: none;" required>
                    <option value="">-- Chọn truyện --</option>
                    <% stories.forEach(story => { %>
                        <option value="<%= story.id %>"><%= story.title %></option>
                    <% }) %>
                </select>
            </div>

            <!-- 2. PHƯƠNG THỨC ĐĂNG CHƯƠNG -->
            <div class="form-group" style="margin-bottom: 2rem;">
                <label>Phương thức đăng chương *</label>
                <div style="display: flex; flex-wrap: wrap; gap: 1.5rem; margin-top: 0.5rem; background: var(--bg-primary); padding: 1rem; border-radius: 8px; border: 1px solid var(--border-color);">
                    <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-weight: 500;">
                        <input type="radio" name="publish_method" value="manual" checked>
                        ✏️ Đăng thủ công (Nhập tay / HTML)
                    </label>
                    <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-weight: 500;">
                        <input type="radio" name="publish_method" value="bulk">
                        📄 Tải file tự động (.txt, .docx)
                    </label>
                    <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-weight: 500;">
                        <input type="radio" name="publish_method" value="pdf">
                        📕 Tải PDF (tự động tách chương)
                    </label>
                    <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-weight: 500;">
                        <input type="radio" name="publish_method" value="epub">
                        📗 Tải EPUB (tự động tách chương)
                    </label>
                </div>
            </div>

            <!-- TÙY CHỌN: ĐĂNG TIẾP THÔNG MINH (bỏ qua các chương đã có sẵn trong truyện) -->
            <div class="form-group" id="smart-continue-box" style="display: none; background: rgba(16, 185, 129, 0.08); border-left: 4px solid #10b981; padding: 1rem; border-radius: 0 8px 8px 0; margin-bottom: 1.5rem;">
                <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-weight: 500; margin: 0;">
                    <input type="checkbox" id="smart_continue" name="smart_continue" checked style="width: auto; margin: 0; cursor: pointer;">
                    🧠 Đăng tiếp thông minh: nếu file có nhiều chương hơn truyện đang có, tự động bỏ qua các chương đã đăng rồi và chỉ đăng phần còn thiếu
                </label>
                <div id="smart-continue-info" style="font-size: 0.85rem; color: var(--text-secondary); margin-top: 0.5rem;"></div>
            </div>

            <!-- KHỐI FORM 1: ĐĂNG THỦ CÔNG (MANUAL) -->
            <div id="form-manual">
                <div style="display: grid; grid-template-columns: 1fr 3fr; gap: 1rem;">
                    <div class="form-group">
                        <label for="chapter_number">Số Chương *</label>
                        <input type="number" id="chapter_number" name="chapter_number" min="1" step="any" placeholder="Ví dụ: 1">
                    </div>
                    <div class="form-group">
                        <label for="title">Tiêu Đề Chương *</label>
                        <input type="text" id="title" name="title" placeholder="Ví dụ: Buổi sáng định mệnh">
                    </div>
                </div>

                <div class="form-group">
                    <label for="content">Nội Dung Chương (Hỗ trợ Text hoặc thẻ ảnh HTML) *</label>
                    <textarea id="content" name="content" rows="12" placeholder="Để đan xen chữ và hình ảnh, bạn có thể viết nội dung dạng HTML:
<p>Nội dung đoạn chữ thứ nhất...</p>
<img src='/uploads/ten-anh-da-up.png' alt='Ảnh minh họa'>
<p>Nội dung đoạn chữ tiếp theo...</p>"></textarea>
                </div>
            </div>

            <!-- KHỐI FORM 2: TỰ ĐỘNG TÁCH CHƯƠNG (BULK - .txt/.docx) -->
            <div id="form-bulk" style="display: none;">
                <div style="background: rgba(59, 130, 246, 0.08); border-left: 4px solid var(--accent-color); padding: 1rem; border-radius: 0 8px 8px 0; margin-bottom: 1.5rem; font-size: 0.9rem; line-height: 1.8;">
                    <strong>💡 Hướng dẫn tải tệp tin truyện:</strong><br>
                    • <b>Tải lên hàng loạt</b>: Bạn có thể chọn nhiều file cùng lúc (giữ Ctrl/Cmd).<br>
                    • <b>File Word (.docx)</b>: Trích xuất toàn bộ văn bản và ảnh nhúng đan xen.<br>
                    • <b>File văn bản (.txt)</b>: Trích xuất nội dung chữ thuần.<br>
                    • <b>Quy tắc đặt tên file</b>: Mỗi file = 1 chương. Nhận diện số chương qua từ khóa đầu tên file: <code>Chương 5</code>, <code>Chap 5</code>.
                </div>
                <div class="form-group">
                    <label for="txtfile">Tải lên một hoặc nhiều file truyện *</label>
                    <input type="file" id="txtfile" name="txtfile" accept=".txt,.docx" multiple required>
                    <span style="font-size: 0.8rem; color: var(--text-secondary); margin-top: 0.3rem; display: block;">Giữ phím Ctrl (hoặc Cmd) để chọn nhiều tệp cùng lúc.</span>
                </div>
                <div class="form-group" style="display: flex; align-items: center; gap: 0.5rem; margin-top: 0.8rem;">
                    <input type="checkbox" id="include_images" name="include_images" checked style="width: auto; margin: 0; cursor: pointer;">
                    <label for="include_images" style="margin: 0; font-size: 0.9rem; font-weight: normal; cursor: pointer; color: var(--text-primary);">Tải ảnh nhúng trong file Word lên hệ thống (Bỏ tích nếu chỉ muốn lấy chữ)</label>
                </div>
            </div>

            <!-- KHỐI FORM 3: UPLOAD PDF TỰ ĐỘNG TÁCH CHƯƠNG -->
            <div id="form-pdf" style="display: none;">
                <div style="background: rgba(239, 68, 68, 0.07); border-left: 4px solid #ef4444; padding: 1rem; border-radius: 0 8px 8px 0; margin-bottom: 1.5rem; font-size: 0.9rem; line-height: 1.8;">
                    <strong>📕 Hướng dẫn upload PDF tự động tách chương:</strong><br>
                    • Hệ thống sẽ đọc nội dung PDF và <b>tự động tách thành nhiều chương riêng biệt</b>.<br>
                    • Nhận diện đầu chương qua các từ khóa đầu dòng: <code>Chương 1</code>, <code>Chapter 5</code>, <code>Phần 3</code>, <code>Chap 10</code>...<br>
                    • Nếu PDF <b>không có từ khóa chương</b> → toàn bộ nội dung được đăng thành <b>1 chương duy nhất</b>.<br>
                    • Giới hạn file: <b>50MB</b>. Chỉ hỗ trợ <b>1 file PDF</b> mỗi lần upload.
                </div>
                <div class="form-group">
                    <label for="pdffile">Chọn file PDF *</label>
                    <input type="file" id="pdffile" name="pdffile" accept=".pdf">
                    <span style="font-size: 0.8rem; color: var(--text-secondary); margin-top: 0.3rem; display: block;">Hệ thống sẽ tự phân tích cấu trúc và tách chương theo tiêu đề trong PDF.</span>
                    <div id="pdf-status-msg" style="font-size: 0.85rem; margin-top: 0.5rem; font-weight: 500; display: none;"></div>
                </div>
                <div id="pdf-preview" style="display:none; background: var(--bg-primary); border: 1px solid var(--border-color); border-radius: 8px; padding: 1rem; margin-top: 1rem;">
                    <strong>📋 Xem trước các chương sẽ được tách:</strong>
                    <div id="pdf-chapters-list" style="margin-top: 0.8rem; max-height: 300px; overflow-y: auto;"></div>
                </div>
            </div>

            <!-- KHỐI FORM 4: UPLOAD EPUB TỰ ĐỘNG TÁCH CHƯƠNG -->
            <div id="form-epub" style="display: none;">
                <div style="background: rgba(16, 185, 129, 0.07); border-left: 4px solid #10b981; padding: 1rem; border-radius: 0 8px 8px 0; margin-bottom: 1.5rem; font-size: 0.9rem; line-height: 1.8;">
                    <strong>📗 Hướng dẫn upload EPUB tự động tách chương:</strong><br>
                    • Hệ thống sẽ đọc toàn bộ nội dung sách EPUB theo đúng thứ tự và <b>tự động tách thành nhiều chương riêng biệt</b>.<br>
                    • Nhận diện đầu chương qua các từ khóa: <code>Chương 1</code>, <code>Chapter 5</code>, <code>Phần 3</code>...<br>
                    • Rất phù hợp cho các file EPUB dài (hàng nghìn chương) - kết hợp cùng "Đăng tiếp thông minh" ở trên để chỉ đăng phần còn thiếu.
                </div>
                <div class="form-group">
                    <label for="epubfile">Chọn file EPUB *</label>
                    <input type="file" id="epubfile" name="epubfile" accept=".epub">
                    <span style="font-size: 0.8rem; color: var(--text-secondary); margin-top: 0.3rem; display: block;">Hệ thống sẽ tự phân tích cấu trúc sách và tách chương theo tiêu đề.</span>
                    <div id="epub-status-msg" style="font-size: 0.85rem; margin-top: 0.5rem; font-weight: 500; display: none;"></div>
                </div>
                <div id="epub-preview" style="display:none; background: var(--bg-primary); border: 1px solid var(--border-color); border-radius: 8px; padding: 1rem; margin-top: 1rem;">
                    <strong>📋 Xem trước các chương sẽ được tách:</strong>
                    <div id="epub-chapters-list" style="margin-top: 0.8rem; max-height: 300px; overflow-y: auto;"></div>
                </div>
            </div>

            <button type="submit" id="submit-btn" class="btn btn-primary" style="width: 100%; padding: 0.8rem; font-size: 1rem; margin-top: 1.5rem;">BẮT ĐẦU ĐĂNG CHƯƠNG</button>
        </form>
    <% } %>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/mammoth/1.6.0/mammoth.browser.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
<script>
    pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.worker.min.js';
</script>

<script>
    // Hàm lọc danh sách truyện theo từ khóa tìm kiếm
    function filterStories(keyword) {
        const select = document.getElementById('story_id');
        const countEl = document.getElementById('story-search-count');
        const options = Array.from(select.options);
        const kw = keyword.trim().toLowerCase();
        let visibleCount = 0;

        options.forEach(opt => {
            if (!opt.value) {
                opt.style.display = '';
                return;
            }
            const match = !kw || opt.text.toLowerCase().includes(kw);
            opt.style.display = match ? '' : 'none';
            if (match) visibleCount++;
        });

        // Nếu option đang chọn bị ẩn, reset về mặc định
        const selectedOpt = select.options[select.selectedIndex];
        if (selectedOpt && selectedOpt.style.display === 'none') {
            select.value = '';
        }

        // Hiển thị số kết quả
        countEl.textContent = kw ? `${visibleCount} kết quả` : '';
    }

    // Logic ẩn/hiện form dựa trên phương thức đăng
    const methodRadios = document.querySelectorAll('input[name="publish_method"]');
    const formManual = document.getElementById('form-manual');
    const formBulk = document.getElementById('form-bulk');
    const formPdf = document.getElementById('form-pdf');

    const chapNumInput = document.getElementById('chapter_number');
    const chapTitleInput = document.getElementById('title');
    const chapContentInput = document.getElementById('content');
    const bulkFileInput = document.getElementById('txtfile');
    const pdfFileInput = document.getElementById('pdffile');
    const formEpub = document.getElementById('form-epub');
    const epubFileInput = document.getElementById('epubfile');
    const smartContinueBox = document.getElementById('smart-continue-box');
    const smartContinueInfo = document.getElementById('smart-continue-info');

    function readFileAsArrayBuffer(file) {
        return new Promise((resolve, reject) => {
            const reader = new FileReader();
            reader.onload = () => resolve(reader.result);
            reader.onerror = () => reject(reader.error || new Error('Không thể đọc tệp tin.'));
            reader.readAsArrayBuffer(file);
        });
    }

    let cachedEpubArrayBuffer = null;
    let cachedPdfArrayBuffer = null;

    if (epubFileInput) {
        epubFileInput.addEventListener('change', async () => {
            const file = epubFileInput.files[0];
            const msgEl = document.getElementById('epub-status-msg');
            if (msgEl) {
                msgEl.style.display = 'block';
                msgEl.style.color = 'var(--text-secondary)';
                msgEl.textContent = '⏳ Đang nạp tệp vào bộ nhớ RAM...';
            }
            if (file) {
                try {
                    cachedEpubArrayBuffer = await readFileAsArrayBuffer(file);
                    if (msgEl) {
                        msgEl.style.color = '#10b981';
                        msgEl.innerHTML = `✅ Tệp đã nạp vào bộ nhớ RAM thành công (${(file.size / (1024 * 1024)).toFixed(2)} MB). Sẵn sàng đăng!`;
                    }
                    console.log('EPUB pre-loaded successfully.');
                } catch (err) {
                    console.error('Failed to pre-load EPUB:', err);
                    if (msgEl) {
                        msgEl.style.color = '#ef4444';
                        msgEl.innerHTML = `❌ Lỗi đọc tệp: ${err.message}. Vui lòng thử lại hoặc dùng trình duyệt khác.`;
                    }
                }
            } else {
                cachedEpubArrayBuffer = null;
                if (msgEl) msgEl.style.display = 'none';
            }
        });
    }

    if (pdfFileInput) {
        pdfFileInput.addEventListener('change', async () => {
            const file = pdfFileInput.files[0];
            const msgEl = document.getElementById('pdf-status-msg');
            if (msgEl) {
                msgEl.style.display = 'block';
                msgEl.style.color = 'var(--text-secondary)';
                msgEl.textContent = '⏳ Đang nạp tệp vào bộ nhớ RAM...';
            }
            if (file) {
                try {
                    cachedPdfArrayBuffer = await readFileAsArrayBuffer(file);
                    if (msgEl) {
                        msgEl.style.color = '#10b981';
                        msgEl.innerHTML = `✅ Tệp đã nạp vào bộ nhớ RAM thành công (${(file.size / (1024 * 1024)).toFixed(2)} MB). Sẵn sàng đăng!`;
                    }
                    console.log('PDF pre-loaded successfully.');
                } catch (err) {
                    console.error('Failed to pre-load PDF:', err);
                    if (msgEl) {
                        msgEl.style.color = '#ef4444';
                        msgEl.innerHTML = `❌ Lỗi đọc tệp: ${err.message}. Vui lòng thử lại hoặc dùng trình duyệt khác.`;
                    }
                }
            } else {
                cachedPdfArrayBuffer = null;
                if (msgEl) msgEl.style.display = 'none';
            }
        });
    }

    function toggleForms() {
        const m = document.querySelector('input[name="publish_method"]:checked').value;
        formManual.style.display = m === 'manual' ? 'block' : 'none';
        formBulk.style.display   = m === 'bulk'   ? 'block' : 'none';
        formPdf.style.display    = m === 'pdf'    ? 'block' : 'none';
        formEpub.style.display   = m === 'epub'   ? 'block' : 'none';

        chapNumInput.required     = m === 'manual';
        chapTitleInput.required   = m === 'manual';
        chapContentInput.required = m === 'manual';
        bulkFileInput.required    = m === 'bulk';
        pdfFileInput.required     = m === 'pdf';
        epubFileInput.required    = m === 'epub';

        // Chỉ hiện tùy chọn "Đăng tiếp thông minh" cho các luồng tự động tách nhiều chương
        smartContinueBox.style.display = (m === 'bulk' || m === 'pdf' || m === 'epub') ? 'block' : 'none';
    }

    methodRadios.forEach(r => r.addEventListener('change', toggleForms));
    toggleForms();

    // Lấy số chương lớn nhất đang có sẵn của truyện đang chọn, để tính điểm "đăng tiếp"
    async function getExistingChapterCount(storyId) {
        try {
            const resp = await fetch(`/admin/chapter/count?story_id=${storyId}`);
            const data = await resp.json();
            return data.count || 0;
        } catch (err) {
            return 0;
        }
    }

    // Lọc bỏ N chương đầu tiên nếu tick "Đăng tiếp thông minh" và số chương tách được > số chương đã có
    async function applySmartContinue(processedFiles, storyId) {
        const enabled = document.getElementById('smart_continue').checked;
        if (!enabled) return processedFiles;

        const existingCount = await getExistingChapterCount(storyId);
        if (existingCount > 0 && processedFiles.length > existingCount) {
            const skipped = processedFiles.slice(0, existingCount);
            const remaining = processedFiles.slice(existingCount);
            smartContinueInfo.innerHTML = `✅ Truyện đã có <b>${existingCount}</b> chương. Tự động bỏ qua ${skipped.length} chương đầu, chỉ đăng tiếp <b>${remaining.length}</b> chương còn thiếu (từ chương ${existingCount + 1}).`;
            return remaining;
        }
        smartContinueInfo.innerHTML = `Truyện hiện có ${existingCount} chương - không cần bỏ qua chương nào, sẽ đăng đủ ${processedFiles.length} chương tách được.`;
        return processedFiles;
    }

    const pdfPreviewBox = document.getElementById('pdf-preview');
    const pdfChaptersList = document.getElementById('pdf-chapters-list');

    // Xem trước cấu trúc tách chương ngay khi chọn file PDF (chỉ hiện tiêu đề + số đoạn văn của mỗi chương,
    // không hiển thị nội dung chi tiết - giúp kiểm tra tách đúng/sai trước khi bấm đăng)
    if (pdfFileInput) {
        pdfFileInput.addEventListener('change', async () => {
            const file = pdfFileInput.files[0];
            if (!file) {
                pdfPreviewBox.style.display = 'none';
                return;
            }

            pdfPreviewBox.style.display = 'block';
            pdfChaptersList.innerHTML = '<p style="color: var(--text-secondary); font-size: 0.9rem;">⏳ Đang phân tích cấu trúc PDF...</p>';

            try {
                const arrayBuffer = await readFileAsArrayBuffer(file);
                const pdf = await pdfjsLib.getDocument({ data: arrayBuffer }).promise;
                let fullText = '';

                for (let i = 1; i <= pdf.numPages; i++) {
                    const page = await pdf.getPage(i);
                    const textContent = await page.getTextContent();
                    fullText += extractPageTextByLines(textContent) + '\n';
                }

                const previewChapters = splitTextIntoChapters(fullText, file.name);

                if (previewChapters.length === 1 && previewChapters[0].name.replace('.txt', '') === file.name.replace(/\.pdf$/i, '')) {
                    pdfChaptersList.innerHTML = '<p style="color: var(--text-secondary); font-size: 0.9rem;">⚠️ Không phát hiện tiêu đề chương nào trong PDF này - toàn bộ nội dung sẽ được đăng thành <b>1 chương duy nhất</b>.</p>';
                } else {
                    pdfChaptersList.innerHTML = `<p style="font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 0.5rem;">Phát hiện <b>${previewChapters.length}</b> chương:</p>` +
                        previewChapters.map((ch, idx) => {
                            const paragraphCount = (ch.content.match(/<p>/g) || []).length;
                            return `<div style="padding: 0.4rem 0.6rem; border-bottom: 1px solid var(--border-color); font-size: 0.85rem;">
                                <strong>${idx + 1}.</strong> ${ch.name.replace('.txt', '')}
                                <span style="color: var(--text-secondary);"> — ${paragraphCount} đoạn văn</span>
                            </div>`;
                        }).join('');
                }
            } catch (err) {
                pdfChaptersList.innerHTML = `<p style="color: #ef4444; font-size: 0.9rem;">Lỗi khi đọc PDF: ${err.message}</p>`;
            }
        });
    }

    const epubPreviewBox = document.getElementById('epub-preview');
    const epubChaptersList = document.getElementById('epub-chapters-list');

    // Xem trước cấu trúc tách chương ngay khi chọn file EPUB
    if (epubFileInput) {
        epubFileInput.addEventListener('change', async () => {
            const file = epubFileInput.files[0];
            if (!file) {
                epubPreviewBox.style.display = 'none';
                return;
            }

            epubPreviewBox.style.display = 'block';
            epubChaptersList.innerHTML = '<p style="color: var(--text-secondary); font-size: 0.9rem;">⏳ Đang phân tích cấu trúc EPUB...</p>';

            try {
                const fakeBtn = { textContent: '' };
                const previewChapters = await extractEpubChapters(file, fakeBtn);

                if (previewChapters.length === 1) {
                    epubChaptersList.innerHTML = '<p style="color: var(--text-secondary); font-size: 0.9rem;">⚠️ Không phát hiện tiêu đề chương nào trong EPUB này - toàn bộ nội dung sẽ được đăng thành <b>1 chương duy nhất</b>.</p>';
                } else {
                    epubChaptersList.innerHTML = `<p style="font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 0.5rem;">Phát hiện <b>${previewChapters.length}</b> chương:</p>` +
                        previewChapters.slice(0, 30).map((ch, idx) => {
                            const paragraphCount = (ch.content.match(/<p>/g) || []).length;
                            return `<div style="padding: 0.4rem 0.6rem; border-bottom: 1px solid var(--border-color); font-size: 0.85rem;">
                                <strong>${idx + 1}.</strong> ${ch.name.replace('.txt', '')}
                                <span style="color: var(--text-secondary);"> — ${paragraphCount} đoạn văn</span>
                            </div>`;
                        }).join('') + (previewChapters.length > 30 ? `<p style="font-size: 0.8rem; color: var(--text-secondary); margin-top: 0.5rem;">... và ${previewChapters.length - 30} chương khác</p>` : '');
                }
            } catch (err) {
                epubChaptersList.innerHTML = `<p style="color: #ef4444; font-size: 0.9rem;">Lỗi khi đọc EPUB: ${err.message}</p>`;
            }
        });
    }

    // Regex tách chương KHÔNG yêu cầu tiêu đề đứng trọn 1 dòng riêng - nhận diện tại bất kỳ vị trí nào trong văn bản.
    // (Đồng bộ với backend routes/admin.js)
    const CHAPTER_SPLIT_PATTERN = /(?:^|[\n\r]|(?<=[.!?…”"）)\]]\s))\s*(Chương|CHƯƠNG|Chap|CHAP|Chapter|CHAPTER|Phần|PHẦN|Part|PART)\s*\.?\s*(\d+(?:\.\d+)?)\s*(?:[:.\-–,]\s*)?([^\n\r]{0,80})?/gi;

    function splitTextIntoChapters(rawText, fileName) {
        const regex = new RegExp(CHAPTER_SPLIT_PATTERN, 'gi');
        const matches = [];
        let m;
        while ((m = regex.exec(rawText)) !== null) {
            matches.push({ index: m.index, matchedText: m[0], num: parseFloat(m[2]), titleTail: (m[3] || '').trim() });
            if (m.index === regex.lastIndex) regex.lastIndex++;
        }

        if (matches.length === 0) {
            // Không tìm thấy tiêu đề chương nào -> toàn bộ nội dung là 1 chương duy nhất
            return [{
                name: fileName.replace(/\.pdf$/i, '.txt'),
                type: 'txt',
                content: rawText.split('\n').filter(l => l.trim()).map(l => `<p>${l.trim()}</p>`).join('')
            }];
        }

        const chapters = [];
        for (let i = 0; i < matches.length; i++) {
            const cur = matches[i];
            const next = matches[i + 1];
            const contentStart = cur.index + cur.matchedText.length;
            const contentEnd = next ? next.index : rawText.length;
            const rawContent = rawText.slice(contentStart, contentEnd);

            const chapNum = cur.num;
            const chapTitle = cur.titleTail && cur.titleTail.length <= 60 ? cur.titleTail : '';
            const title = chapTitle ? `Chương ${chapNum}: ${chapTitle}` : `Chương ${chapNum}`;

            const contentHtml = rawContent
                .split('\n')
                .map(l => l.trim())
                .filter(l => l.length > 0)
                .map(l => `<p>${l}</p>`)
                .join('');

            chapters.push({
                name: title + '.txt',
                type: 'txt',
                content: contentHtml
            });
        }

        return chapters;
    }

    // Loại bỏ các ký tự Unicode gây lỗi khi lưu vào database (PDF trích xuất từ font đặc biệt/lỗi
    // OCR thường sinh ra ký tự rác không hợp lệ):
    // 1. "Lone surrogate" - nửa cặp ký tự UTF-16 bị lỗi, khiến JSON.stringify() tạo \uXXXX không hợp lệ.
    // 2. NULL byte (␀) - PostgreSQL/Supabase KHÔNG BAO GIỜ chấp nhận ký tự này trong cột TEXT,
    //    đây chính là nguyên nhân thực sự gây lỗi "unsupported Unicode escape sequence" ở phía
    //    database khi insert (không phải lỗi JSON.parse như tưởng ban đầu).
    // 3. Các ký tự điều khiển C0 khác (ngoại trừ \n \r \t) - cũng thường không hợp lệ trong text thường.
    function stripLoneSurrogates(str) {
        if (!str) return str;
        return str
            .replace(/[\uD800-\uDBFF](?![\uDC00-\uDFFF])|(?:[^\uD800-\uDBFF]|^)[\uDC00-\uDFFF]/g, '')
            .replace(/␀/g, '')
            .replace(/[--]/g, '');
    }

    // Trích xuất text từ 1 trang PDF, ghép các mảnh text theo TỌA ĐỘ DÒNG THẬT (transform[5] = vị trí Y)
    // thay vì nối phẳng bằng dấu cách - tránh tình trạng dính chữ/dính đoạn khi pdf.js trả về nhiều mảnh text
    // rời rạc nằm trên các dòng khác nhau nhưng bị ghép chung thành 1 dòng logic.
    function extractPageTextByLines(textContent) {
        const items = textContent.items;
        if (items.length === 0) return '';

        // Nhóm các item theo tọa độ Y (làm tròn để cùng 1 dòng dù lệch nhẹ do font-metrics)
        const lineMap = new Map();
        for (const item of items) {
            const y = Math.round(item.transform[5]);
            if (!lineMap.has(y)) lineMap.set(y, []);
            lineMap.get(y).push(item);
        }

        // Sắp xếp các dòng từ trên xuống dưới (tọa độ Y giảm dần trong hệ toạ độ PDF = từ trên xuống)
        const sortedYs = Array.from(lineMap.keys()).sort((a, b) => b - a);

        const lines = sortedYs.map(y => {
            const lineItems = lineMap.get(y).sort((a, b) => a.transform[4] - b.transform[4]); // sắp theo tọa độ X (trái sang phải)
            return lineItems.map(it => it.str).join('').trim();
        });

        return stripLoneSurrogates(lines.filter(l => l.length > 0).join('\n'));
    }

    // Đọc file EPUB (thực chất là 1 file ZIP) bằng JSZip, lấy đúng thứ tự chương qua "spine" trong content.opf,
    // tách thẻ HTML lấy text thuần, rồi tái sử dụng splitTextIntoChapters giống hệt PDF.
    // Helper to resolve relative path inside EPUB ZIP
    function resolveRelativePath(basePath, relativePath) {
        const parts = basePath.split('/');
        parts.pop(); // remove file name
        const relParts = relativePath.split('/');
        for (const part of relParts) {
            if (part === '.') continue;
            if (part === '..') {
                parts.pop();
            } else {
                parts.push(part);
            }
        }
        return parts.join('/');
    }

    async function extractTextAndImages(doc, zip, xhtmlPath, submitBtn) {
        let result = '';
        
        async function traverse(node) {
            if (node.nodeType === 3) { // TEXT_NODE
                result += node.nodeValue;
            } else if (node.nodeType === 1) { // ELEMENT_NODE
                const tagName = node.tagName.toLowerCase();
                
                if (tagName === 'style' || tagName === 'script') {
                    return;
                }
                
                if (tagName === 'img') {
                    const src = node.getAttribute('src');
                    if (src) {
                        try {
                            const resolvedPath = resolveRelativePath(xhtmlPath, src);
                            const imgFile = zip.file(resolvedPath) || zip.file(decodeURIComponent(resolvedPath));
                            if (imgFile) {
                                const ext = resolvedPath.split('.').pop().toLowerCase();
                                const mimeType = ext === 'jpg' || ext === 'jpeg' ? 'image/jpeg' : ext === 'gif' ? 'image/gif' : 'image/png';
                                
                                submitBtn.textContent = `⏳ Đang tải ảnh ${resolvedPath} lên Supabase...`;
                                const blob = await imgFile.async('blob');
                                const publicUrl = await uploadBlobToSupabase(blob, mimeType);
                                
                                result += `\n<img src="${publicUrl}" alt="Ảnh minh họa" style="max-width:100%; display:block; margin:1rem auto; border-radius:8px;">\n`;
                            }
                        } catch (err) {
                            console.error('Lỗi xử lý ảnh trong EPUB:', err);
                        }
                    }
                    return;
                }
                
                if (tagName === 'image' && node.getAttribute('xlink:href')) {
                    const href = node.getAttribute('xlink:href');
                    try {
                        const resolvedPath = resolveRelativePath(xhtmlPath, href);
                        const imgFile = zip.file(resolvedPath) || zip.file(decodeURIComponent(resolvedPath));
                        if (imgFile) {
                            const ext = resolvedPath.split('.').pop().toLowerCase();
                            const mimeType = ext === 'jpg' || ext === 'jpeg' ? 'image/jpeg' : ext === 'gif' ? 'image/gif' : 'image/png';
                            
                            submitBtn.textContent = `⏳ Đang tải ảnh ${resolvedPath} lên Supabase...`;
                            const blob = await imgFile.async('blob');
                            const publicUrl = await uploadBlobToSupabase(blob, mimeType);
                            
                            result += `\n<img src="${publicUrl}" alt="Ảnh minh họa" style="max-width:100%; display:block; margin:1rem auto; border-radius:8px;">\n`;
                        }
                    } catch (err) {
                        console.error('Lỗi xử lý ảnh SVG trong EPUB:', err);
                    }
                    return;
                }
                
                for (const child of node.childNodes) {
                    await traverse(child);
                }
                
                if (['p', 'div', 'br', 'h1', 'h2', 'h3', 'h4', 'h5', 'h6', 'li', 'tr'].includes(tagName)) {
                    result += '\n';
                }
            }
        }
        
        await traverse(doc.body || doc.documentElement);
        return result;
    }

    // Đọc file EPUB (thực chất là 1 file ZIP) bằng JSZip, lấy đúng thứ tự chương qua "spine" trong content.opf,
    // tách thẻ HTML lấy text và ảnh, rồi tài sử dụng splitTextIntoChapters giống hệt PDF.
    async function extractEpubChapters(file, submitBtn) {
        const arrayBuffer = cachedEpubArrayBuffer || await readFileAsArrayBuffer(file);
        const zip = await JSZip.loadAsync(arrayBuffer);
        const containerXmlFile = zip.file('META-INF/container.xml');
        if (!containerXmlFile) throw new Error('File EPUB thiếu container.xml');
        const containerXml = await containerXmlFile.async('string');
        const opfPathMatch = containerXml.match(/full-path="([^"]+)"/);
        if (!opfPathMatch) throw new Error('Không tìm thấy content.opf');
        const opfPath = opfPathMatch[1];
        const opfDir = opfPath.includes('/') ? opfPath.substring(0, opfPath.lastIndexOf('/') + 1) : '';

        const opfFile = zip.file(opfPath);
        if (!opfFile) throw new Error('Không đọc được content.opf');
        const opfXml = await opfFile.async('string');
        const manifest = {};
        const manifestRegex = /<item\s+[^>]*id="([^"]+)"[^>]*href="([^"]+)"[^>]*\/?>/g;
        let mm;
        while ((mm = manifestRegex.exec(opfXml)) !== null) {
            manifest[mm[1]] = mm[2];
        }
        const manifestRegex2 = /<item\s+[^>]*href="([^"]+)"[^>]*id="([^"]+)"[^>]*\/?>/g;
        while ((mm = manifestRegex2.exec(opfXml)) !== null) {
            manifest[mm[2]] = mm[1];
        }

        const spineIds = [];
        const spineRegex = /<itemref\s+[^>]*idref="([^"]+)"/g;
        let sm;
        while ((sm = spineRegex.exec(opfXml)) !== null) {
            spineIds.push(sm[1]);
        }
        const orderedHrefs = spineIds.map(id => manifest[id]).filter(Boolean);
        if (orderedHrefs.length === 0) throw new Error('Không đọc được spine trong EPUB.');

        let chapters = [];
        let chapCount = 1;
        for (let i = 0; i < orderedHrefs.length; i++) {
            submitBtn.textContent = `⏳ Đang đọc phần ${i + 1}/${orderedHrefs.length} của EPUB...`;
            const href = orderedHrefs[i];
            const fullHref = (opfDir + href).replace(/\\/g, '/');
            const zipFile = zip.file(fullHref) || zip.file(decodeURIComponent(fullHref));
            if (!zipFile) continue;

            const xhtml = await zipFile.async('string');
            const parser = new DOMParser();
            const doc = parser.parseFromString(xhtml, 'text/html');
            
            // Xóa các thẻ không cần thiết
            const scripts = doc.querySelectorAll('script, style, nav');
            scripts.forEach(s => s.remove());

            // Kiểm tra xem file XHTML này có chứa nhiều chương con không (hỗ trợ file EPUB gộp như Hồng Hoang)
            const headings = Array.from(doc.querySelectorAll('h1, h2, h3, h4')).filter(el => {
                return /chương\s*\d+/i.test(el.textContent.trim());
            });

            if (headings.length >= 2) {
                // Tách nhiều chương từ file đơn lẻ này (dùng headings)
                for (let hIdx = 0; hIdx < headings.length; hIdx++) {
                    const headingEl = headings[hIdx];
                    const headingText = headingEl.textContent.trim();
                    
                    const contentNodes = [];
                    let next = headingEl.nextSibling;
                    while (next) {
                        const isNextHeading = ['H1','H2','H3','H4'].includes(next.nodeName.toUpperCase())
                            && /chương\s*\d+/i.test(next.textContent.trim());
                        if (isNextHeading) break;
                        
                        if (next.nodeType === 1) {
                            if (next.nodeName.toUpperCase() !== 'BR') {
                                contentNodes.push(next.outerHTML);
                            }
                        } else if (next.nodeType === 3) {
                            const txtVal = next.textContent.trim();
                            if (txtVal) {
                                contentNodes.push(`<p>${txtVal}</p>`);
                            }
                        }
                        next = next.nextSibling;
                    }

                    const formattedContent = contentNodes.join('');
                    if (formattedContent.trim().length > 0) {
                        chapters.push({
                            name: `${headingText}.txt`,
                            type: 'txt',
                            content: formattedContent
                        });
                        chapCount++;
                    }
                }
                continue;
            }

            // Trích xuất nội dung HTML/Text thô chuẩn mực (giữ ký tự xuống dòng \n và giải quyết hình ảnh)
            let bodyHtml = await extractTextAndImages(doc, zip, fullHref, submitBtn);

            // Cách 2: Nếu không dùng headings, nhưng text thô có từ 2 tiêu đề chương trở lên (như Khủng Bố Sống Lại)
            CHAPTER_SPLIT_PATTERN.lastIndex = 0; // Reset index trước khi dùng
            let matchCount = 0;
            while (CHAPTER_SPLIT_PATTERN.exec(bodyHtml) !== null) {
                matchCount++;
            }
            if (matchCount >= 2) {
                const subChapters = splitTextIntoChapters(bodyHtml, file.name);
                if (subChapters.length >= 2) {
                    subChapters.forEach(sc => {
                        chapters.push({
                            name: sc.name,
                            type: 'txt',
                            content: sc.content
                        });
                        chapCount++;
                    });
                    continue;
                }
            }

            // Lấy tiêu đề của chương từ h1, h2, h3 hoặc title
            let title = '';
            const heading = doc.querySelector('h1, h2, h3, title');
            if (heading) {
                title = heading.textContent.trim();
            }
            
            // Nếu heading rỗng, thử quét trong 300 ký tự đầu tiên của body để tìm số chương
            let detectedChapterNum = null;
            if (!title) {
                const chapNumMatch = bodyHtml.substring(0, 300).match(/(?:Chương|CHƯƠNG|Chap|CHAP|Chapter|CHAPTER)\s*(\d+(?:\.\d+)?)/i);
                if (chapNumMatch) {
                    detectedChapterNum = parseFloat(chapNumMatch[1]);
                    // Lấy dòng đầu tiên chứa Chương làm tiêu đề nháp
                    const lines = bodyHtml.split('\n').map(l => l.trim()).filter(l => l.length > 0);
                    const matchLine = lines.find(l => /(?:Chương|CHƯƠNG|Chap|CHAP|Chapter|CHAPTER)\s*\d+/i.test(l));
                    if (matchLine) {
                        title = matchLine;
                    }
                }
            } else {
                const titleMatch = title.match(/(?:Chương|CHƯƠNG|Chap|CHAP|Chapter|CHAPTER)\s*(\d+(?:\.\d+)?)/i);
                if (titleMatch) {
                    detectedChapterNum = parseFloat(titleMatch[1]);
                }
            }

            // Làm sạch tiêu đề
            if (!title || title.toLowerCase() === 'untitled' || title.toLowerCase().includes('thông tin chung')) {
                // Bỏ qua các trang metadata hoặc thông tin chung nếu nội dung quá ngắn
                const bodyTextLength = bodyHtml.length;
                if (bodyTextLength < 200 && (title.toLowerCase().includes('thông tin chung') || title.toLowerCase().includes('giới thiệu') || title.toLowerCase().includes('mục lục') || title.toLowerCase().includes('tác giả'))) {
                    console.log(`Bỏ qua trang metadata: ${href}`);
                    continue;
                }
                title = `Chương ${chapCount}`;
            }
            
            // Lọc quảng cáo thichcode
            bodyHtml = bodyHtml.replace(/<h4[^>]*>\s*Chỉnh sửa\s*:\s*<a[^>]*>.*?<\/a>\s*<\/h4>/gi, '')
                               .replace(/<h4[^>]*>\s*Chỉnh sửa\s*:\s*truyen\.thichcode\.net\s*<\/h4>/gi, '')
                               .replace(/<h4[^>]*>\s*Chỉnh sửa\s*:.*?<\/h4>/gi, '');

            // Format nội dung thành HTML sạch
            const formattedContent = bodyHtml.split('\n')
                .filter(line => line.trim().length > 0)
                .map(line => line.trim().startsWith('<img') ? line : `<p>${line}</p>`)
                .join('');
            
            if (formattedContent.trim().length > 0) {
                chapters.push({
                    name: `${title}.txt`,
                    type: 'txt',
                    content: formattedContent
                });
                chapCount++;
            }
        }
        return chapters;
    }

    async function uploadInBatches(storyId, processedFiles, submitBtn) {
        let successCount = 0;
        const MAX_RETRIES = 3;
        const MAX_PAYLOAD_SIZE = 2 * 1024 * 1024; // Giới hạn an toàn 2MB tránh lỗi 413 Payload Too Large của Vercel (4.5MB)
        
        let i = 0;
        while (i < processedFiles.length) {
            let batch = [];
            let currentSize = 0;
            
            // Gom nhóm động dựa trên kích thước chuỗi JSON thực tế của từng chương
            while (i < processedFiles.length && batch.length < 15) {
                const f = processedFiles[i];
                const cleanedContent = typeof f.content === 'string' ? stripLoneSurrogates(f.content) : f.content;
                const fileItem = { ...f, content: cleanedContent };
                const itemSize = JSON.stringify(fileItem).length;
                
                // Nếu thêm chương này vào làm lô vượt quá 2MB, dừng gom và gửi lô hiện tại trước
                if (batch.length > 0 && currentSize + itemSize > MAX_PAYLOAD_SIZE) {
                    break;
                }
                
                batch.push(fileItem);
                currentSize += itemSize;
                i++;
            }
            
            let lastError = null;
            let ok = false;

            for (let attempt = 1; attempt <= MAX_RETRIES && !ok; attempt++) {
                const retryLabel = attempt > 1 ? ` (thử lại lần ${attempt}/${MAX_RETRIES})` : '';
                submitBtn.textContent = `⏳ Đang lưu database (${successCount + 1} - ${successCount + batch.length} / ${processedFiles.length})${retryLabel}...`;

                try {
                    const response = await fetch('/admin/chapter/add-json', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ story_id: storyId, files: batch })
                    });

                    let data;
                    if (response.headers.get('content-type')?.includes('application/json')) {
                        data = await response.json();
                    } else {
                        const txt = await response.text();
                        throw new Error('Lỗi máy chủ (' + response.status + '): ' + txt.substring(0, 200));
                    }

                    if (!data.success) throw new Error(data.error);

                    ok = true;
                    successCount += batch.length;
                } catch (err) {
                    lastError = err;
                    if (attempt < MAX_RETRIES) {
                        await new Promise(r => setTimeout(r, 1500)); // Chờ 1.5s trước khi thử lại
                    }
                }
            }

            if (!ok) {
                throw new Error(
                    `Đã thử ${MAX_RETRIES} lần vẫn lỗi ở lô chương từ thứ ${successCount + 1}: ${lastError ? lastError.message : 'Không rõ nguyên nhân'}. ` +
                    `${successCount} chương trước đó đã lưu thành công - có thể bật "Đăng tiếp thông minh" và đăng lại file này để tiếp tục từ chương còn thiếu.`
                );
            }
        }
        return successCount;
    }

    // INTERCEPT FORM SUBMIT
    const form = document.querySelector('form');
    form.addEventListener('submit', async (e) => {
        const selectedMethod = document.querySelector('input[name="publish_method"]:checked').value;

        // ── PDF ───────────────────────────────────────────────
        if (selectedMethod === 'pdf') {
            e.preventDefault();
            const submitBtn = document.getElementById('submit-btn');
            submitBtn.disabled = true;
            submitBtn.textContent = '⏳ Đang đọc PDF trên trình duyệt (0%)...';
            try {
                const storyId = document.getElementById('story_id').value;
                const file = pdfFileInput.files[0];
                if (!file) {
                    alert('Vui lòng chọn file PDF.');
                    submitBtn.disabled = false;
                    submitBtn.textContent = 'BẮT ĐẦU ĐĂNG CHƯƠNG';
                    return;
                }

                const arrayBuffer = cachedPdfArrayBuffer || await readFileAsArrayBuffer(file);
                const pdf = await pdfjsLib.getDocument({ data: arrayBuffer }).promise;
                let fullText = '';
                
                for (let i = 1; i <= pdf.numPages; i++) {
                    submitBtn.textContent = `⏳ Đang đọc trang ${i}/${pdf.numPages}...`;
                    const page = await pdf.getPage(i);
                    const textContent = await page.getTextContent();
                    const pageText = extractPageTextByLines(textContent);
                    fullText += pageText + '\n';
                }

                submitBtn.textContent = '⏳ Đang xử lý text...';
                let processedFiles = splitTextIntoChapters(fullText, file.name);
                processedFiles = await applySmartContinue(processedFiles, storyId);

                await uploadInBatches(storyId, processedFiles, submitBtn);
                window.location.href = '/admin/chapter/add?success=' + encodeURIComponent(`Đã tải lên ${processedFiles.length} chương thành công`);
            } catch (err) {
                alert('Có lỗi xảy ra: ' + err.message);
                const sb = document.getElementById('submit-btn');
                sb.disabled = false;
                sb.textContent = 'BẮT ĐẦU ĐĂNG CHƯƠNG';
            }
        }

        // ── EPUB ──────────────────────────────────────────────
        else if (selectedMethod === 'epub') {
            e.preventDefault();
            const submitBtn = document.getElementById('submit-btn');
            submitBtn.disabled = true;
            submitBtn.textContent = '⏳ Đang đọc EPUB trên trình duyệt...';
            try {
                const storyId = document.getElementById('story_id').value;
                const file = epubFileInput.files[0];
                if (!file) {
                    alert('Vui lòng chọn file EPUB.');
                    submitBtn.disabled = false;
                    submitBtn.textContent = 'BẮT ĐẦU ĐĂNG CHƯƠNG';
                    return;
                }

                let processedFiles = await extractEpubChapters(file, submitBtn);
                processedFiles = await applySmartContinue(processedFiles, storyId);

                await uploadInBatches(storyId, processedFiles, submitBtn);
                window.location.href = '/admin/chapter/add?success=' + encodeURIComponent(`Đã tải lên ${processedFiles.length} chương thành công`);
            } catch (err) {
                alert('Có lỗi xảy ra: ' + err.message);
                const sb = document.getElementById('submit-btn');
                sb.disabled = false;
                sb.textContent = 'BẮT ĐẦU ĐĂNG CHƯƠNG';
            }
        }

        // ── BULK (.txt / .docx) ───────────────────────────────
        else if (selectedMethod === 'bulk') {
            e.preventDefault();
            const submitBtn = document.getElementById('submit-btn');
            const origText = submitBtn.textContent;
            submitBtn.disabled = true;
            submitBtn.textContent = '⏳ Đang xử lý file và tải ảnh lên...';
            try {
                const storyId = document.getElementById('story_id').value;
                const files = bulkFileInput.files;
                if (!files || files.length === 0) {
                    alert('Vui lòng chọn tệp tin truyện.');
                    submitBtn.disabled = false;
                    submitBtn.textContent = origText;
                    return;
                }
                const processedFiles = [];
                for (let file of files) {
                    const isDocx = file.name.endsWith('.docx');
                    if (isDocx) {
                        const arrayBuffer = await readFileAsArrayBuffer(file);
                        const result = await mammoth.convertToHtml({ arrayBuffer });
                        let html = result.value;
                        const parser = new DOMParser();
                        const doc = parser.parseFromString(html, 'text/html');
                        const imgs = doc.querySelectorAll('img');
                        const includeImages = document.getElementById('include_images').checked;
                        if (includeImages) {
                            if (imgs.length > 0) submitBtn.textContent = '⏳ Đang tải ' + imgs.length + ' ảnh lên Supabase...';
                            for (let img of imgs) {
                                const src = img.getAttribute('src');
                                if (src && src.startsWith('data:')) {
                                    const blob = dataURLtoBlob(src);
                                    const publicUrl = await uploadBlobToSupabase(blob, blob.type);
                                    img.setAttribute('src', publicUrl);
                                }
                            }
                        } else { imgs.forEach(img => img.remove()); }
                        html = doc.body.innerHTML;
                        processedFiles.push({ name: file.name, type: 'docx', content: html });
                    } else {
                        const text = await file.text();
                        const splitted = splitTextIntoChapters(text, file.name);
                        processedFiles.push(...splitted);
                    }
                }
                
                const storyIdBulk = document.getElementById('story_id').value;
                const filteredFiles = await applySmartContinue(processedFiles, storyIdBulk);

                await uploadInBatches(storyIdBulk, filteredFiles, submitBtn);
                window.location.href = '/admin/chapter/add?success=' + encodeURIComponent(`Đã tải lên ${filteredFiles.length} chương thành công`);
            } catch (err) {
                alert('Có lỗi xảy ra: ' + err.message);
                const sb = document.getElementById('submit-btn');
                sb.disabled = false;
                sb.textContent = origText;
            }
        }
    });



    // Hàm chuyển đổi ảnh base64 thành Blob
    function dataURLtoBlob(dataurl) {
        var arr = dataurl.split(','), mime = arr[0].match(/:(.*?);/)[1],
            bstr = atob(arr[1]), n = bstr.length, u8arr = new Uint8Array(n);
        while(n--){
            u8arr[n] = bstr.charCodeAt(n);
        }
        return new Blob([u8arr], {type:mime});
    }

    // Hàm upload blob thẳng lên Supabase Storage từ Browser
    async function uploadBlobToSupabase(blob, mimeType) {
        const fileExt = mimeType === 'image/jpeg' ? '.jpg' : '.png';
        const fileName = `word-img-${Date.now()}-${Math.round(Math.random() * 1E9)}${fileExt}`;
        
        const supabaseUrl = 'https://xlaqupbqiwpoprywnkgi.supabase.co';
        const anonKey = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InhsYXF1cGJxaXdwb3ByeXdua2dpIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODM1ODkxNDcsImV4cCI6MjA5OTE2NTE0N30.v0NZKDhVb4ysx03cmx_aQn6aGBMCO6lWzBUN6--JKB0';

        const response = await fetch(`${supabaseUrl}/storage/v1/object/uploads/${fileName}`, {
            method: 'POST',
            headers: {
                'Authorization': `Bearer ${anonKey}`,
                'apikey': anonKey,
                'Content-Type': mimeType
            },
            body: blob
        });

        if (!response.ok) {
            const errText = await response.text();
            throw new Error(`Upload ảnh thất bại: ${errText}`);
        }

        return `${supabaseUrl}/storage/v1/object/public/uploads/${fileName}`;
    }
</script>

