<%- include('../partials/header') %>

<div style="margin-bottom: 1.5rem;">
    <a href="/admin" style="color: var(--text-secondary); font-size: 0.9rem;">&larr; Quay lại Trang quản trị</a>
</div>

<div class="form-container" style="max-width: 750px;">
    <h2 class="section-title">⚡ Đăng Chương Truyện Mới</h2>
    
    <% if (success) { %>
        <div class="alert alert-success"><%= success %></div>
    <% } %>

    <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
    <% } %>

    <% if (stories.length === 0) { %>
        <div class="alert alert-error">Chưa có bộ truyện nào. Vui lòng tạo bộ truyện trước khi đăng chương.</div>
        <a href="/admin/story/add" class="btn btn-primary" style="width: 100%;">Tạo bộ truyện mới ngay</a>
    <% } else { %>
        <form action="/admin/chapter/add" method="POST" enctype="multipart/form-data">
            <!-- 1. CHỌN TRUYỆN -->
            <div class="form-group">
                <label for="story_id">Chọn Bộ Truyện Đọc *</label>
                <select id="story_id" name="story_id" style="width: 100%; padding: 0.8rem 1rem; background: var(--bg-primary); border: 1px solid var(--border-color); color: var(--text-primary); border-radius: 8px; font-size: 1rem; outline: none;" required>
                    <option value="">-- Chọn truyện --</option>
                    <% stories.forEach(story => { %>
                        <option value="<%= story.id %>"><%= story.title %></option>
                    <% }) %>
                </select>
            </div>

            <!-- 2. PHƯƠNG THỨC ĐĂNG CHƯƠNG -->
            <div class="form-group" style="margin-bottom: 2rem;">
                <label>Phương thức đăng chương *</label>
                <div style="display: flex; flex-wrap: wrap; gap: 1.5rem; margin-top: 0.5rem; background: var(--bg-primary); padding: 1rem; border-radius: 8px; border: 1px solid var(--border-color);">
                    <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-weight: 500;">
                        <input type="radio" name="publish_method" value="manual" checked>
                        ✏️ Đăng thủ công (Nhập tay / HTML)
                    </label>
                    <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-weight: 500;">
                        <input type="radio" name="publish_method" value="bulk">
                        📄 Tải file tự động (.txt, .docx)
                    </label>
                    <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-weight: 500;">
                        <input type="radio" name="publish_method" value="pdf">
                        📕 Tải PDF (tự động tách chương)
                    </label>
                </div>
            </div>

            <!-- KHỐI FORM 1: ĐĂNG THỦ CÔNG (MANUAL) -->
            <div id="form-manual">
                <div style="display: grid; grid-template-columns: 1fr 3fr; gap: 1rem;">
                    <div class="form-group">
                        <label for="chapter_number">Số Chương *</label>
                        <input type="number" id="chapter_number" name="chapter_number" min="1" step="any" placeholder="Ví dụ: 1">
                    </div>
                    <div class="form-group">
                        <label for="title">Tiêu Đề Chương *</label>
                        <input type="text" id="title" name="title" placeholder="Ví dụ: Buổi sáng định mệnh">
                    </div>
                </div>

                <div class="form-group">
                    <label for="content">Nội Dung Chương (Hỗ trợ Text hoặc thẻ ảnh HTML) *</label>
                    <textarea id="content" name="content" rows="12" placeholder="Để đan xen chữ và hình ảnh, bạn có thể viết nội dung dạng HTML:
<p>Nội dung đoạn chữ thứ nhất...</p>
<img src='/uploads/ten-anh-da-up.png' alt='Ảnh minh họa'>
<p>Nội dung đoạn chữ tiếp theo...</p>"></textarea>
                </div>
            </div>

            <!-- KHỐI FORM 2: TỰ ĐỘNG TÁCH CHƯƠNG (BULK - .txt/.docx) -->
            <div id="form-bulk" style="display: none;">
                <div style="background: rgba(59, 130, 246, 0.08); border-left: 4px solid var(--accent-color); padding: 1rem; border-radius: 0 8px 8px 0; margin-bottom: 1.5rem; font-size: 0.9rem; line-height: 1.8;">
                    <strong>💡 Hướng dẫn tải tệp tin truyện:</strong><br>
                    • <b>Tải lên hàng loạt</b>: Bạn có thể chọn nhiều file cùng lúc (giữ Ctrl/Cmd).<br>
                    • <b>File Word (.docx)</b>: Trích xuất toàn bộ văn bản và ảnh nhúng đan xen.<br>
                    • <b>File văn bản (.txt)</b>: Trích xuất nội dung chữ thuần.<br>
                    • <b>Quy tắc đặt tên file</b>: Mỗi file = 1 chương. Nhận diện số chương qua từ khóa đầu tên file: <code>Chương 5</code>, <code>Chap 5</code>.
                </div>
                <div class="form-group">
                    <label for="txtfile">Tải lên một hoặc nhiều file truyện *</label>
                    <input type="file" id="txtfile" name="txtfile" accept=".txt,.docx" multiple required>
                    <span style="font-size: 0.8rem; color: var(--text-secondary); margin-top: 0.3rem; display: block;">Giữ phím Ctrl (hoặc Cmd) để chọn nhiều tệp cùng lúc.</span>
                </div>
                <div class="form-group" style="display: flex; align-items: center; gap: 0.5rem; margin-top: 0.8rem;">
                    <input type="checkbox" id="include_images" name="include_images" checked style="width: auto; margin: 0; cursor: pointer;">
                    <label for="include_images" style="margin: 0; font-size: 0.9rem; font-weight: normal; cursor: pointer; color: var(--text-primary);">Tải ảnh nhúng trong file Word lên hệ thống (Bỏ tích nếu chỉ muốn lấy chữ)</label>
                </div>
            </div>

            <!-- KHỐI FORM 3: UPLOAD PDF TỰ ĐỘNG TÁCH CHƯƠNG -->
            <div id="form-pdf" style="display: none;">
                <div style="background: rgba(239, 68, 68, 0.07); border-left: 4px solid #ef4444; padding: 1rem; border-radius: 0 8px 8px 0; margin-bottom: 1.5rem; font-size: 0.9rem; line-height: 1.8;">
                    <strong>📕 Hướng dẫn upload PDF tự động tách chương:</strong><br>
                    • Hệ thống sẽ đọc nội dung PDF và <b>tự động tách thành nhiều chương riêng biệt</b>.<br>
                    • Nhận diện đầu chương qua các từ khóa đầu dòng: <code>Chương 1</code>, <code>Chapter 5</code>, <code>Phần 3</code>, <code>Chap 10</code>...<br>
                    • Nếu PDF <b>không có từ khóa chương</b> → toàn bộ nội dung được đăng thành <b>1 chương duy nhất</b>.<br>
                    • Giới hạn file: <b>50MB</b>. Chỉ hỗ trợ <b>1 file PDF</b> mỗi lần upload.
                </div>
                <div class="form-group">
                    <label for="pdffile">Chọn file PDF *</label>
                    <input type="file" id="pdffile" name="pdffile" accept=".pdf">
                    <span style="font-size: 0.8rem; color: var(--text-secondary); margin-top: 0.3rem; display: block;">Hệ thống sẽ tự phân tích cấu trúc và tách chương theo tiêu đề trong PDF.</span>
                </div>
                <div id="pdf-preview" style="display:none; background: var(--bg-primary); border: 1px solid var(--border-color); border-radius: 8px; padding: 1rem; margin-top: 1rem;">
                    <strong>📋 Xem trước các chương sẽ được tách:</strong>
                    <div id="pdf-chapters-list" style="margin-top: 0.8rem; max-height: 300px; overflow-y: auto;"></div>
                </div>
            </div>

            <button type="submit" id="submit-btn" class="btn btn-primary" style="width: 100%; padding: 0.8rem; font-size: 1rem; margin-top: 1.5rem;">BẮT ĐẦU ĐĂNG CHƯƠNG</button>
        </form>
    <% } %>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/mammoth/1.6.0/mammoth.browser.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.min.js"></script>
<script>
    pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.worker.min.js';
</script>

<script>
    // Logic ẩn/hiện form dựa trên phương thức đăng
    const methodRadios = document.querySelectorAll('input[name="publish_method"]');
    const formManual = document.getElementById('form-manual');
    const formBulk = document.getElementById('form-bulk');
    const formPdf = document.getElementById('form-pdf');

    const chapNumInput = document.getElementById('chapter_number');
    const chapTitleInput = document.getElementById('title');
    const chapContentInput = document.getElementById('content');
    const bulkFileInput = document.getElementById('txtfile');
    const pdfFileInput = document.getElementById('pdffile');

    function toggleForms() {
        const m = document.querySelector('input[name="publish_method"]:checked').value;
        formManual.style.display = m === 'manual' ? 'block' : 'none';
        formBulk.style.display   = m === 'bulk'   ? 'block' : 'none';
        formPdf.style.display    = m === 'pdf'    ? 'block' : 'none';

        chapNumInput.required     = m === 'manual';
        chapTitleInput.required   = m === 'manual';
        chapContentInput.required = m === 'manual';
        bulkFileInput.required    = m === 'bulk';
        pdfFileInput.required     = m === 'pdf';
    }

    methodRadios.forEach(r => r.addEventListener('change', toggleForms));
    toggleForms();

    const pdfPreviewBox = document.getElementById('pdf-preview');
    const pdfChaptersList = document.getElementById('pdf-chapters-list');

    // Xem trước cấu trúc tách chương ngay khi chọn file PDF (chỉ hiện tiêu đề + số đoạn văn của mỗi chương,
    // không hiển thị nội dung chi tiết - giúp kiểm tra tách đúng/sai trước khi bấm đăng)
    if (pdfFileInput) {
        pdfFileInput.addEventListener('change', async () => {
            const file = pdfFileInput.files[0];
            if (!file) {
                pdfPreviewBox.style.display = 'none';
                return;
            }

            pdfPreviewBox.style.display = 'block';
            pdfChaptersList.innerHTML = '<p style="color: var(--text-secondary); font-size: 0.9rem;">⏳ Đang phân tích cấu trúc PDF...</p>';

            try {
                const arrayBuffer = await file.arrayBuffer();
                const pdf = await pdfjsLib.getDocument({ data: arrayBuffer }).promise;
                let fullText = '';

                for (let i = 1; i <= pdf.numPages; i++) {
                    const page = await pdf.getPage(i);
                    const textContent = await page.getTextContent();
                    fullText += extractPageTextByLines(textContent) + '\n';
                }

                const previewChapters = splitTextIntoChapters(fullText, file.name);

                if (previewChapters.length === 1 && previewChapters[0].name.replace('.txt', '') === file.name.replace(/\.pdf$/i, '')) {
                    pdfChaptersList.innerHTML = '<p style="color: var(--text-secondary); font-size: 0.9rem;">⚠️ Không phát hiện tiêu đề chương nào trong PDF này - toàn bộ nội dung sẽ được đăng thành <b>1 chương duy nhất</b>.</p>';
                } else {
                    pdfChaptersList.innerHTML = `<p style="font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 0.5rem;">Phát hiện <b>${previewChapters.length}</b> chương:</p>` +
                        previewChapters.map((ch, idx) => {
                            const paragraphCount = (ch.content.match(/<p>/g) || []).length;
                            return `<div style="padding: 0.4rem 0.6rem; border-bottom: 1px solid var(--border-color); font-size: 0.85rem;">
                                <strong>${idx + 1}.</strong> ${ch.name.replace('.txt', '')}
                                <span style="color: var(--text-secondary);"> — ${paragraphCount} đoạn văn</span>
                            </div>`;
                        }).join('');
                }
            } catch (err) {
                pdfChaptersList.innerHTML = `<p style="color: #ef4444; font-size: 0.9rem;">Lỗi khi đọc PDF: ${err.message}</p>`;
            }
        });
    }

    // Regex tách chương KHÔNG yêu cầu tiêu đề đứng trọn 1 dòng riêng - nhận diện tại bất kỳ vị trí nào trong văn bản.
    // (Đồng bộ với backend routes/admin.js: nhiều PDF khi trích xuất text bị dính dòng, tiêu đề "Chương X" nằm
    // liền sát đoạn văn trước/sau, khiến regex kiểu ^...$ cũ chỉ bắt được số ít chương "may mắn" đứng riêng dòng.)
    const CHAPTER_SPLIT_PATTERN = '(?:^|[\\n\\r]|(?<=[.!?…”"）)\\]]\\s))\\s*(Chương|CHƯƠNG|Chap|CHAP|Chapter|CHAPTER|Phần|PHẦN|Part|PART)\\s*\\.?\\s*(\\d+(?:\\.\\d+)?)\\s*(?:[:.\\-–,]\\s*)?([^\\n\\r]{0,80})?';

    function splitTextIntoChapters(rawText, fileName) {
        const regex = new RegExp(CHAPTER_SPLIT_PATTERN, 'g');
        const matches = [];
        let m;
        while ((m = regex.exec(rawText)) !== null) {
            matches.push({ index: m.index, matchedText: m[0], num: parseFloat(m[2]), titleTail: (m[3] || '').trim() });
            if (m.index === regex.lastIndex) regex.lastIndex++;
        }

        if (matches.length === 0) {
            // Không tìm thấy tiêu đề chương nào -> toàn bộ nội dung là 1 chương duy nhất
            return [{
                name: fileName.replace(/\.pdf$/i, '.txt'),
                type: 'txt',
                content: rawText.split('\n').filter(l => l.trim()).map(l => `<p>${l.trim()}</p>`).join('')
            }];
        }

        const chapters = [];
        for (let i = 0; i < matches.length; i++) {
            const cur = matches[i];
            const next = matches[i + 1];
            const contentStart = cur.index + cur.matchedText.length;
            const contentEnd = next ? next.index : rawText.length;
            const rawContent = rawText.slice(contentStart, contentEnd);

            const chapNum = cur.num;
            const chapTitle = cur.titleTail && cur.titleTail.length <= 60 ? cur.titleTail : '';
            const title = chapTitle ? `Chương ${chapNum}: ${chapTitle}` : `Chương ${chapNum}`;

            const contentHtml = rawContent
                .split('\n')
                .map(l => l.trim())
                .filter(l => l.length > 0)
                .map(l => `<p>${l}</p>`)
                .join('');

            chapters.push({
                name: title + '.txt',
                type: 'txt',
                content: contentHtml
            });
        }

        return chapters;
    }

    // Trích xuất text từ 1 trang PDF, ghép các mảnh text theo TỌA ĐỘ DÒNG THẬT (transform[5] = vị trí Y)
    // thay vì nối phẳng bằng dấu cách - tránh tình trạng dính chữ/dính đoạn khi pdf.js trả về nhiều mảnh text
    // rời rạc nằm trên các dòng khác nhau nhưng bị ghép chung thành 1 dòng logic.
    function extractPageTextByLines(textContent) {
        const items = textContent.items;
        if (items.length === 0) return '';

        // Nhóm các item theo tọa độ Y (làm tròn để cùng 1 dòng dù lệch nhẹ do font-metrics)
        const lineMap = new Map();
        for (const item of items) {
            const y = Math.round(item.transform[5]);
            if (!lineMap.has(y)) lineMap.set(y, []);
            lineMap.get(y).push(item);
        }

        // Sắp xếp các dòng từ trên xuống dưới (tọa độ Y giảm dần trong hệ toạ độ PDF = từ trên xuống)
        const sortedYs = Array.from(lineMap.keys()).sort((a, b) => b - a);

        const lines = sortedYs.map(y => {
            const lineItems = lineMap.get(y).sort((a, b) => a.transform[4] - b.transform[4]); // sắp theo tọa độ X (trái sang phải)
            return lineItems.map(it => it.str).join('').trim();
        });

        return lines.filter(l => l.length > 0).join('\n');
    }

    async function uploadInBatches(storyId, processedFiles, submitBtn) {
        const BATCH_SIZE = 50; // Giới hạn 50 chương mỗi lần gửi
        let successCount = 0;
        for (let i = 0; i < processedFiles.length; i += BATCH_SIZE) {
            const batch = processedFiles.slice(i, i + BATCH_SIZE);
            submitBtn.textContent = `⏳ Đang lưu database (${i + 1} - ${i + batch.length} / ${processedFiles.length})...`;
            
            const response = await fetch('/admin/chapter/add-json', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ story_id: storyId, files: batch })
            });

            let data;
            if (response.headers.get('content-type')?.includes('application/json')) {
                data = await response.json();
            } else {
                const txt = await response.text();
                throw new Error('Lỗi máy chủ (' + response.status + '): ' + txt.substring(0, 200));
            }

            if (!data.success) {
                throw new Error(data.error);
            }
            successCount += batch.length;
        }
        return successCount;
    }

    // INTERCEPT FORM SUBMIT
    const form = document.querySelector('form');
    form.addEventListener('submit', async (e) => {
        const selectedMethod = document.querySelector('input[name="publish_method"]:checked').value;

        // ── PDF ───────────────────────────────────────────────
        if (selectedMethod === 'pdf') {
            e.preventDefault();
            const submitBtn = document.getElementById('submit-btn');
            submitBtn.disabled = true;
            submitBtn.textContent = '⏳ Đang đọc PDF trên trình duyệt (0%)...';
            try {
                const storyId = document.getElementById('story_id').value;
                const file = pdfFileInput.files[0];
                if (!file) {
                    alert('Vui lòng chọn file PDF.');
                    submitBtn.disabled = false;
                    submitBtn.textContent = 'BẮT ĐẦU ĐĂNG CHƯƠNG';
                    return;
                }

                const arrayBuffer = await file.arrayBuffer();
                const pdf = await pdfjsLib.getDocument({ data: arrayBuffer }).promise;
                let fullText = '';
                
                for (let i = 1; i <= pdf.numPages; i++) {
                    submitBtn.textContent = `⏳ Đang đọc trang ${i}/${pdf.numPages}...`;
                    const page = await pdf.getPage(i);
                    const textContent = await page.getTextContent();
                    const pageText = extractPageTextByLines(textContent);
                    fullText += pageText + '\n';
                }

                submitBtn.textContent = '⏳ Đang xử lý text...';
                const processedFiles = splitTextIntoChapters(fullText, file.name);
                
                await uploadInBatches(storyId, processedFiles, submitBtn);
                window.location.href = '/admin/chapter/add?success=' + encodeURIComponent(`Đã tải lên ${processedFiles.length} chương thành công`);
            } catch (err) {
                alert('Có lỗi xảy ra: ' + err.message);
                const sb = document.getElementById('submit-btn');
                sb.disabled = false;
                sb.textContent = 'BẮT ĐẦU ĐĂNG CHƯƠNG';
            }
        }

        // ── BULK (.txt / .docx) ───────────────────────────────
        else if (selectedMethod === 'bulk') {
            e.preventDefault();
            const submitBtn = document.getElementById('submit-btn');
            const origText = submitBtn.textContent;
            submitBtn.disabled = true;
            submitBtn.textContent = '⏳ Đang xử lý file và tải ảnh lên...';
            try {
                const storyId = document.getElementById('story_id').value;
                const files = bulkFileInput.files;
                if (!files || files.length === 0) {
                    alert('Vui lòng chọn tệp tin truyện.');
                    submitBtn.disabled = false;
                    submitBtn.textContent = origText;
                    return;
                }
                const processedFiles = [];
                for (let file of files) {
                    const isDocx = file.name.endsWith('.docx');
                    if (isDocx) {
                        const arrayBuffer = await file.arrayBuffer();
                        const result = await mammoth.convertToHtml({ arrayBuffer });
                        let html = result.value;
                        const parser = new DOMParser();
                        const doc = parser.parseFromString(html, 'text/html');
                        const imgs = doc.querySelectorAll('img');
                        const includeImages = document.getElementById('include_images').checked;
                        if (includeImages) {
                            if (imgs.length > 0) submitBtn.textContent = '⏳ Đang tải ' + imgs.length + ' ảnh lên Supabase...';
                            for (let img of imgs) {
                                const src = img.getAttribute('src');
                                if (src && src.startsWith('data:')) {
                                    const blob = dataURLtoBlob(src);
                                    const publicUrl = await uploadBlobToSupabase(blob, blob.type);
                                    img.setAttribute('src', publicUrl);
                                }
                            }
                        } else { imgs.forEach(img => img.remove()); }
                        html = doc.body.innerHTML;
                        processedFiles.push({ name: file.name, type: 'docx', content: html });
                    } else {
                        const text = await file.text();
                        const splitted = splitTextIntoChapters(text, file.name);
                        processedFiles.push(...splitted);
                    }
                }
                
                await uploadInBatches(storyId, processedFiles, submitBtn);
                window.location.href = '/admin/chapter/add?success=' + encodeURIComponent(`Đã tải lên ${processedFiles.length} chương thành công`);
            } catch (err) {
                alert('Có lỗi xảy ra: ' + err.message);
                const sb = document.getElementById('submit-btn');
                sb.disabled = false;
                sb.textContent = origText;
            }
        }
    });



    // Hàm chuyển đổi ảnh base64 thành Blob
    function dataURLtoBlob(dataurl) {
        var arr = dataurl.split(','), mime = arr[0].match(/:(.*?);/)[1],
            bstr = atob(arr[1]), n = bstr.length, u8arr = new Uint8Array(n);
        while(n--){
            u8arr[n] = bstr.charCodeAt(n);
        }
        return new Blob([u8arr], {type:mime});
    }

    // Hàm upload blob thẳng lên Supabase Storage từ Browser
    async function uploadBlobToSupabase(blob, mimeType) {
        const fileExt = mimeType === 'image/jpeg' ? '.jpg' : '.png';
        const fileName = `word-img-${Date.now()}-${Math.round(Math.random() * 1E9)}${fileExt}`;
        
        const supabaseUrl = 'https://xlaqupbqiwpoprywnkgi.supabase.co';
        const anonKey = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InhsYXF1cGJxaXdwb3ByeXdua2dpIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODM1ODkxNDcsImV4cCI6MjA5OTE2NTE0N30.v0NZKDhVb4ysx03cmx_aQn6aGBMCO6lWzBUN6--JKB0';

        const response = await fetch(`${supabaseUrl}/storage/v1/object/uploads/${fileName}`, {
            method: 'POST',
            headers: {
                'Authorization': `Bearer ${anonKey}`,
                'apikey': anonKey,
                'Content-Type': mimeType
            },
            body: blob
        });

        if (!response.ok) {
            const errText = await response.text();
            throw new Error(`Upload ảnh thất bại: ${errText}`);
        }

        return `${supabaseUrl}/storage/v1/object/public/uploads/${fileName}`;
    }
</script>

