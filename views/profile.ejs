<%- include('partials/header') %>

<div class="profile-container" style="max-width: 1000px; margin: 0 auto; padding: 2rem 1rem;">
    <!-- Profile Header/Card -->
    <div style="background: linear-gradient(135deg, rgba(30, 41, 59, 0.7) 0%, rgba(15, 23, 42, 0.9) 100%); border: 1px solid var(--border-color); border-radius: 16px; padding: 2.5rem; display: flex; flex-wrap: wrap; gap: 2rem; align-items: center; margin-bottom: 2rem; box-shadow: 0 10px 30px rgba(0,0,0,0.3); backdrop-filter: blur(10px);">
        <!-- Avatar display with title overlay (MMORPG Style) -->
        <div style="display: flex; flex-direction: column; align-items: center; gap: 0.6rem;">
            <% const equippedFrameClass = userData.equipped_frame || 'default-frame' %>
            <div class="avatar-frame <%= equippedFrameClass %>" style="width: 90px; height: 90px; padding: 4px;">
                <div class="avatar-glow"></div>
                <img id="avatar-preview" src="<%= user.avatar || '/css/silly_duck.png' %>" class="avatar-img avatar-zoomable" alt="Avatar">
                
                <!-- Badge Icon at Top Right (avatar-corner) -->
                <% if (userData.equipped_badge) { %>
                    <div class="avatar-corner" style="position: absolute; top: -5px; right: -5px; font-size: 1.2rem; background: rgba(0,0,0,0.7); border-radius: 50%; padding: 4px; z-index: 10; border: 2px solid gold; display: flex; justify-content: center; align-items: center; width: 28px; height: 28px;">
                        <%= getBadgeIcon(userData.equipped_badge) %>
                    </div>
                <% } %>
            </div>
            
            <!-- Badge Title below Avatar -->
            <% if (userData.equipped_badge) { %>
                
                <div style="display: flex; flex-direction: column; align-items: center; margin-top: -10px; z-index: 2; line-height: 1.1;">
                    <span class="game-title <%= getTitleRarityClass(userData.equipped_badge) %>" style="font-size: 0.75rem; padding: 4px 14px; white-space: nowrap;"><%= userData ? userData.equipped_badge : user.equipped_badge %></span>
                    <span style="font-size: 0.6rem; letter-spacing: 2px; text-shadow: 0 0 3px rgba(255,255,255,0.4); margin-top: 4px;"><%= getStarsByChapters(stats.chaptersRead) %></span>
                </div>
            <% } %>
        </div>

        <div style="flex: 1; min-width: 250px;">
            <form action="/profile/update" method="POST" style="display: flex; flex-direction: column; gap: 0.8rem;">
                <div style="display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; width: 100%;">
                    <div style="position: relative; display: flex; align-items: center; width: 100%; max-width: 320px;">
                        <input type="text" name="display_name" value="<%= userData.display_name %>" required style="font-size: 1.1rem; font-weight: bold; background: rgba(0,0,0,0.3); border: 1px solid var(--border-color); color: var(--text-primary); padding: 0.6rem 2.2rem 0.6rem 0.8rem; border-radius: 8px; transition: all 0.3s; width: 100%;" class="display-name-input" placeholder="Tên hiển thị">
                        <span style="position: absolute; right: 12px; color: var(--text-secondary); pointer-events: none; font-size: 0.95rem;">✏️</span>
                    </div>
                    <button type="submit" class="btn btn-secondary" style="font-size: 0.85rem; padding: 0.6rem 1.2rem; border-radius: 8px; font-weight: 600;">Lưu Thay Đổi</button>
                </div>
                
                <!-- Sửa Bio -->
                <div style="margin-top: 0.4rem; width: 100%;">
                    <textarea name="bio" placeholder="Giới thiệu bản thân (Bio)..." style="width: 100%; max-width: 500px; min-height: 80px; padding: 0.8rem 1rem; border-radius: 8px; border: 1px solid var(--border-color); background: rgba(0,0,0,0.25); color: var(--text-primary); font-size: 0.88rem; line-height: 1.4; resize: vertical; outline: none; transition: border-color 0.3s;"><%= userData.bio %></textarea>
                </div>

                <div style="display: flex; gap: 1rem; align-items: center; margin-top: 0.5rem; flex-wrap: wrap;">
                    <span style="font-size: 0.85rem; background: rgba(16, 185, 129, 0.15); color: #10b981; padding: 0.3rem 0.8rem; border-radius: 12px; font-weight: 600; border: 1px solid rgba(16, 185, 129, 0.3);" title="Hạng trên BXH Độc giả">🏆 Hạng #<%= stats.rank %></span>
                    
                    <!-- Tu Vi / Rank -->
                    <span class="badge-premium" style="font-size: 0.85rem; background: rgba(99, 102, 241, 0.15); color: var(--accent-color); font-weight: 600; border: 1px solid rgba(99, 102, 241, 0.3);">
                        <span class="badge-premium-dot"></span>
                        <span><%= stats.badge %></span>
                    </span>
                    
                    <!-- Huy hiệu tùy chỉnh (Equipped Badge) -->
                    <% if (user.equipped_badge) { %>
                        
                        <span class="game-title badge-premium <%= getTitleRarityClass(user.equipped_badge) %> <%= getTitleRarityClass(user.equipped_badge).includes('transcendent') ? 'is-transcendent' : getTitleRarityClass(user.equipped_badge).includes('mythic') ? 'is-mythic' : getTitleRarityClass(user.equipped_badge).includes('legendary') ? 'is-legendary' : '' %>" style="font-size: 0.75rem; padding: 0.3rem 0.8rem; border-radius: 12px;">
                            <span class="badge-premium-dot"></span>
                            <span><%= userData ? userData.equipped_badge : user.equipped_badge %></span>
                        </span>
                    <% } %>
                    <% if (user.role === 'admin') { %>
                        <span style="font-size: 0.85rem; background: rgba(245, 158, 11, 0.15); color: #f59e0b; padding: 0.3rem 0.8rem; border-radius: 12px; font-weight: 600; border: 1px solid rgba(245, 158, 11, 0.3);">👑 Quản trị viên</span>
                    <% } %>
                    <span style="font-size: 0.85rem; background: rgba(239, 68, 68, 0.1); color: #ef4444; padding: 0.3rem 0.8rem; border-radius: 12px; font-weight: 600; border: 1px solid rgba(239, 68, 68, 0.2);" title="Streak đọc sách">🔥 <%= stats.streak %> Ngày Streak</span>
                    
                    <!-- Nút dẫn đến EXP Shop -->
                    <a href="/shop" class="btn btn-primary" style="background: linear-gradient(135deg, #eab308, #ec4899); border: none; font-size: 0.85rem; padding: 0.4rem 1.2rem; border-radius: 8px; font-weight: bold; text-decoration: none; display: inline-flex; align-items: center; gap: 0.4rem; box-shadow: 0 4px 15px rgba(236, 72, 153, 0.3);">
                        🛒 Cửa Hàng EXP
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- Stats & Progress Section -->
    <div class="profile-grid" style="display: grid; grid-template-columns: 2fr 1fr; gap: 2rem; margin-bottom: 2rem;">
        <!-- Left Column: Level and Achievements -->
        <div>
            <!-- Level & EXP card -->
            <div style="background: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: 16px; padding: 2rem; margin-bottom: 2rem; box-shadow: 0 4px 20px rgba(0,0,0,0.15);">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                    <h3 style="margin: 0; font-size: 1.4rem;">Cấp Độ <%= stats.level %></h3>
                    <span style="font-size: 0.9rem; color: var(--text-secondary);"><%= stats.currentLevelExp %> / <%= stats.nextLevelExp %> EXP</span>
                </div>
                
                <!-- Progress Bar -->
                <div style="width: 100%; height: 12px; background: rgba(255,255,255,0.05); border-radius: 6px; overflow: hidden; border: 1px solid rgba(255,255,255,0.05);">
                    <div style="width: <%= (stats.currentLevelExp / stats.nextLevelExp) * 100 %>%; height: 100%; background: linear-gradient(90deg, var(--accent-color) 0%, #a855f7 100%); border-radius: 6px; box-shadow: 0 0 10px var(--accent-color);"></div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 1.5rem; text-align: center;">
                    <div style="background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); border-radius: 10px; padding: 1rem;">
                        <div style="font-size: 1.6rem; font-weight: bold; color: var(--accent-color);"><%= stats.exp %></div>
                        <div style="font-size: 0.8rem; color: var(--text-secondary);">Tổng EXP Tích Lũy</div>
                    </div>
                    <div style="background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); border-radius: 10px; padding: 1rem;">
                        <div style="font-size: 1.6rem; font-weight: bold; color: #10b981;"><%= stats.chaptersRead %></div>
                        <div style="font-size: 0.8rem; color: var(--text-secondary);">Số Chương Đã Đọc</div>
                    </div>
                </div>
            </div>

            <!-- Inventory Card -->
            <div style="background: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: 16px; padding: 2rem; margin-bottom: 2rem; box-shadow: 0 4px 20px rgba(0,0,0,0.15);">
                <h3 style="margin: 0 0 1.5rem 0; font-size: 1.3rem; display: flex; align-items: center; gap: 0.5rem;">
                    🎒 Kho Đồ Của Bạn
                </h3>
                
                <% if (ownedItems.length === 0) { %>
                    <p style="color: var(--text-secondary); text-align: center; padding: 1.5rem 0; font-size: 0.92rem;">
                        Kho đồ của bạn đang trống. Hãy ghé qua <a href="/shop" style="color: var(--accent-color); font-weight: bold; text-decoration: none;">Cửa Hàng EXP</a> để sắm ảnh đại diện, khung viền và huy hiệu độc quyền nhé!
                    </p>
                <% } else { %>
                    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1.2rem;">
                        <% ownedItems.forEach(item => { %>
                            <% 
                               let isEquipped = false;
                               if (item.type === 'badge') isEquipped = (userData.equipped_badge === item.value);
                               else if (item.type === 'avatar') isEquipped = (userData.equipped_avatar === item.value);
                               else if (item.type === 'frame') isEquipped = (userData.equipped_frame === item.value);
                            %>
                            <div class="inventory-card" style="background: rgba(255,255,255,0.01); border: 1px solid <%= isEquipped ? 'var(--accent-color)' : 'var(--border-color)' %>; border-radius: 12px; padding: 1.2rem; display: flex; flex-direction: column; justify-content: space-between; gap: 0.8rem; text-align: center; transition: all 0.3s; position: relative;">
                                <% if (isEquipped) { %>
                                    <span style="position: absolute; top: 8px; right: 8px; font-size: 0.62rem; font-weight: bold; background: var(--accent-color); color: #fff; padding: 0.15rem 0.4rem; border-radius: 4px; text-transform: uppercase; box-shadow: 0 2px 5px rgba(99, 102, 241, 0.4);">Đang dùng</span>
                                <% } %>
                                <div>
                                    <!-- Preview based on type -->
                                    <% if (item.type === 'badge') { %>
                                        <div style="min-height: 50px; display: flex; align-items: center; justify-content: center;">
                                            <span style="font-size: 0.82rem; color: #10b981; background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.3); padding: 0.2rem 0.6rem; border-radius: 6px; font-weight: 700;"><%= item.value %></span>
                                        </div>
                                    <% } else if (item.type === 'avatar') { %>
                                        <div style="min-height: 50px; display: flex; align-items: center; justify-content: center;">
                                            <img src="<%= item.value %>" alt="avatar" style="width: 48px; height: 48px; border-radius: 50%; object-fit: cover; border: 2px solid var(--border-color);">
                                        </div>
                                    <% } else if (item.type === 'frame') { %>
                                        <div style="min-height: 50px; display: flex; align-items: center; justify-content: center;">
                                            <div style="position: relative; width: 44px; height: 44px; border-radius: 50%; overflow: hidden; <%= item.value %>">
                                                <img src="<%= user.avatar || '/css/silly_duck.png' %>" alt="avatar" style="width: 100%; height: 100%; object-fit: cover;">
                                            </div>
                                        </div>
                                    <% } %>
                                    
                                    <h4 style="margin: 0.4rem 0 0.2rem 0; font-size: 0.95rem; font-weight: bold; color: var(--text-primary);"><%= item.name %></h4>
                                    <span style="font-size: 0.72rem; color: var(--text-secondary);"><%= item.type === 'badge' ? 'Huy hiệu chat' : item.type === 'avatar' ? 'Ảnh đại diện' : 'Khung viền' %></span>
                                </div>
                                
                                <div>
                                    <% if (isEquipped) { %>
                                        <button onclick="equipItem(<%= item.id %>, 'unequip')" class="btn btn-secondary" style="width: 100%; font-size: 0.78rem; padding: 0.4rem; border-radius: 6px;">Tháo Ra</button>
                                    <% } else { %>
                                        <button onclick="equipItem(<%= item.id %>, 'equip')" class="btn btn-primary" style="width: 100%; font-size: 0.78rem; padding: 0.4rem; border-radius: 6px; font-weight: 600;">Trang Bị</button>
                                    <% } %>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
            </div>

            <!-- Achievements Card -->
            <div style="background: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: 16px; padding: 2rem; box-shadow: 0 4px 20px rgba(0,0,0,0.15);">
                <h3 style="margin: 0 0 1.5rem 0; font-size: 1.3rem; display: flex; align-items: center; gap: 0.5rem;">
                    🏆 Huy Hiệu & Thành Tựu
                </h3>

                <% if (achievements.length === 0) { %>
                    <p style="color: var(--text-secondary); text-align: center; padding: 2rem 0; font-size: 0.95rem;">Bạn chưa mở khóa thành tựu nào. Hãy đọc thêm truyện để nhận huy hiệu nhé!</p>
                <% } else { %>
                    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1.2rem;">
                        <% achievements.forEach(ach => { %>
                            <%
                               const emoji = ach.badge_class === 'legend' ? '👑' : ach.badge_class === 'gold' ? '🥇' : ach.badge_class === 'silver' ? '🥈' : '🥉';
                               const badgeValue = `${emoji} ${ach.name}`;
                               const isEquipped = (userData.equipped_badge === badgeValue);
                            %>
                            <div class="achievement-card" style="background: rgba(255,255,255,0.02); border: 1px solid <%= isEquipped ? 'var(--accent-color)' : 'var(--border-color)' %>; border-radius: 12px; padding: 1.2rem; display: flex; flex-direction: column; gap: 0.5rem; transition: all 0.3s; position: relative; overflow: hidden;">
                                <% if (isEquipped) { %>
                                    <span style="position: absolute; top: 8px; right: 8px; font-size: 0.62rem; font-weight: bold; background: var(--accent-color); color: #fff; padding: 0.15rem 0.4rem; border-radius: 4px; text-transform: uppercase;">Đang dùng</span>
                                <% } %>
                                <div style="display: flex; justify-content: space-between; align-items: center;">
                                    <span style="font-weight: bold; font-size: 0.95rem; color: var(--text-primary);"><%= ach.name %></span>
                                    <span class="badge-icon <%= ach.badge_class %>" style="font-size: 1.1rem;">
                                        <%= emoji %>
                                    </span>
                                </div>
                                <p style="color: var(--text-secondary); font-size: 0.82rem; margin: 0; line-height: 1.4;"><%= ach.description %></p>
                                
                                <div style="margin-top: auto; padding-top: 0.6rem; display: flex; align-items: center; justify-content: space-between; gap: 0.5rem;">
                                    <span style="font-size: 0.72rem; color: rgba(255,255,255,0.25);">Mở khóa: <%= new Date(ach.unlocked_at).toLocaleDateString('vi-VN') %></span>
                                    
                                    <% if (isEquipped) { %>
                                        <button onclick="equipAchievement('<%= ach.name %>', 'unequip')" class="btn btn-secondary" style="font-size: 0.72rem; padding: 0.25rem 0.6rem; border-radius: 6px;">Tháo</button>
                                    <% } else { %>
                                        <button onclick="equipAchievement('<%= ach.name %>', 'equip')" class="btn btn-primary" style="font-size: 0.72rem; padding: 0.25rem 0.6rem; border-radius: 6px; font-weight: 600;">Gắn</button>
                                    <% } %>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- Right Column: Notifications -->
        <div>
            <div style="background: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: 16px; padding: 2rem; height: 100%; box-shadow: 0 4px 20px rgba(0,0,0,0.15); display: flex; flex-direction: column;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                    <h3 style="margin: 0; font-size: 1.3rem;">🔔 Thông Báo</h3>
                    <% if (notifications.some(n => !n.is_read)) { %>
                        <button onclick="readAllNotifications()" class="btn btn-secondary" style="font-size: 0.75rem; padding: 0.3rem 0.6rem; border-radius: 6px;">Đọc hết</button>
                    <% } %>
                </div>

                <div class="notifications-list" style="overflow-y: auto; flex: 1; display: flex; flex-direction: column; gap: 0.8rem; max-height: 480px;">
                    <% if (notifications.length === 0) { %>
                        <p style="color: var(--text-secondary); text-align: center; padding: 3rem 0; font-size: 0.9rem;">Không có thông báo nào.</p>
                    <% } else { %>
                        <% notifications.forEach(n => { %>
                            <a href="<%= n.link || '#' %>" class="notification-item <%= n.is_read ? '' : 'unread' %>" style="display: block; padding: 0.9rem 1.2rem; border-radius: 10px; border: 1px solid <%= n.is_read ? 'var(--border-color)' : 'rgba(99, 102, 241, 0.3)' %>; background: <%= n.is_read ? 'rgba(255,255,255,0.01)' : 'rgba(99, 102, 241, 0.05)' %>; text-decoration: none; color: var(--text-primary); transition: all 0.2s;">
                                <div style="font-size: 0.88rem; line-height: 1.4;"><%= n.message %></div>
                                <div style="font-size: 0.75rem; color: var(--text-secondary); margin-top: 0.4rem; display: flex; justify-content: space-between; align-items: center;">
                                    <span><%= new Date(n.created_at).toLocaleString('vi-VN', { hour: '2-digit', minute: '2-digit', day: '2-digit', month: '2-digit' }) %></span>
                                    <% if (!n.is_read) { %>
                                        <span style="width: 8px; height: 8px; background: var(--accent-color); border-radius: 50%;"></span>
                                    <% } %>
                                </div>
                            </a>
                        <% }) %>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Profile Hover and Focus Styles */
    .avatar-wrapper:hover .avatar-overlay {
        opacity: 1 !important;
    }
    .display-name-input:focus {
        border-color: var(--accent-color) !important;
        outline: none;
        box-shadow: 0 0 10px rgba(99, 102, 241, 0.3) !important;
    }
    .achievement-card:hover {
        transform: translateY(-3px);
        border-color: rgba(99, 102, 241, 0.4) !important;
        box-shadow: 0 8px 24px rgba(99, 102, 241, 0.1);
    }
    .notification-item:hover {
        background: rgba(255,255,255,0.03) !important;
        border-color: var(--accent-color) !important;
    }
    /* Scrollbar */
    .notifications-list::-webkit-scrollbar {
        width: 6px;
    }
    .notifications-list::-webkit-scrollbar-track {
        background: transparent;
    }
    .notifications-list::-webkit-scrollbar-thumb {
        background: rgba(255,255,255,0.1);
        border-radius: 3px;
    }
    
    @media (max-width: 768px) {
        .profile-container {
            padding: 0.5rem !important;
        }
        .profile-grid {
            grid-template-columns: 1fr !important;
            gap: 1rem !important;
        }
        .profile-container > div:first-child {
            padding: 1rem !important;
            flex-direction: column !important;
            text-align: center !important;
            gap: 1rem !important;
        }
        /* Reduce avatar size */
        .profile-container > div:first-child .avatar-frame {
            width: 70px !important;
            height: 70px !important;
        }
        .display-name-input {
            text-align: center;
            max-width: 100% !important;
            font-size: 1rem !important;
            padding: 0.4rem 1.8rem 0.4rem 0.6rem !important;
        }
        form > div {
            justify-content: center;
        }
        /* Reduce padding inside cards */
        .profile-grid > div > div {
            padding: 1rem !important;
        }
        h3 {
            font-size: 1.1rem !important;
            margin-bottom: 0.8rem !important;
        }
        .achievement-card {
            padding: 0.8rem !important;
        }
        /* Make tags wrap tighter */
        form > div:last-child {
            gap: 0.5rem !important;
        }
        form > div:last-child span, form > div:last-child a {
            font-size: 0.75rem !important;
            padding: 0.2rem 0.6rem !important;
        }
    }
</style>

<script>
    async function equipItem(id, action) {
        try {
            const resp = await fetch(`/shop/equip/${id}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ action })
            });
            const data = await resp.json();
            
            if (data.success) {
                location.reload();
            } else {
                alert(data.error || 'Lỗi khi thao tác trang bị.');
            }
        } catch (err) {
            console.error(err);
            alert('Lỗi hệ thống khi trang bị.');
        }
    }

    async function equipAchievement(name, action) {
        try {
            const resp = await fetch('/profile/equip-achievement', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name, action })
            });
            const data = await resp.json();
            
            if (data.success) {
                location.reload();
            } else {
                alert(data.error || 'Lỗi khi thao tác trang bị.');
            }
        } catch (err) {
            console.error(err);
            alert('Lỗi hệ thống.');
        }
    }

    async function readAllNotifications() {
        try {
            const resp = await fetch('/notifications/read-all', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            });
            const data = await resp.json();
            if (data.success) {
                location.reload();
            }
        } catch (e) {
            console.error(e);
        }
    }
</script>

<%- include('partials/footer') %>
