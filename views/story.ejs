<%- include('partials/header') %>

<div style="margin-bottom: 1.5rem;">
    <a href="/" style="color: var(--text-secondary); font-size: 0.9rem;">&larr; Quay lại trang chủ</a>
</div>

<div class="story-detail-header">
    <img src="<%= story.cover_url %>" alt="<%= story.title %>" class="story-detail-cover">
    
    <div class="story-detail-info">
        <h1 class="story-detail-title"><%= story.title %></h1>
        <div class="story-detail-author">Tác giả: <strong><%= story.author %></strong></div>
        
        <div class="story-detail-meta" style="margin-bottom: 1.2rem;">
            <!-- Hiển thị thể loại dạng Flexwrap tránh đè chữ -->
            <div style="display: flex; align-items: center; flex-wrap: wrap; gap: 0.5rem; line-height: 1.8;">
                <span style="color: var(--text-secondary); font-weight: 500;">Thể loại:</span>
                <% if (genres && genres.length > 0) { %>
                    <% genres.forEach(genre => { %>
                        <a href="/genre/<%= genre.slug %>" class="detail-genre-tag" style="padding: 0.25rem 0.75rem; font-size: 0.8rem; border-radius: 12px; display: inline-flex; align-items: center; border: 1px solid var(--border-color); background: var(--bg-secondary); color: var(--text-primary); text-decoration: none; font-weight: 500; transition: all 0.2s;">
                            <%= genre.name %>
                        </a>
                    <% }) %>
                <% } else { %>
                    <span style="color: var(--text-secondary);">Chưa phân loại</span>
                <% } %>
            </div>
        </div>

        <!-- ĐÁNH GIÁ TRUYỆN (SAO/ĐIỂM) -->
        <div style="margin-bottom: 1rem; display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;">
            <div>
                ⭐ <strong><%= typeof avgScore !== 'undefined' && avgScore ? avgScore : 'Chưa có' %></strong><% if (typeof avgScore !== 'undefined' && avgScore) { %>/10<% } %>
                <span style="color: var(--text-secondary); font-size: 0.85rem;">(<%= typeof ratingCount !== 'undefined' ? ratingCount : 0 %> lượt đánh giá)</span>
            </div>

            <% if (typeof user !== 'undefined' && user) { %>
                <div id="rating-widget" data-story-id="<%= story.id %>" style="display: flex; gap: 0.2rem; cursor: pointer;">
                    <% for (let i = 1; i <= 10; i++) { %>
                        <span class="rate-star" data-score="<%= i %>" style="font-size: 1.1rem; color: <%= (typeof myRating !== 'undefined' && myRating && i <= myRating) ? '#f59e0b' : 'var(--border-color)' %>;">★</span>
                    <% } %>
                </div>
            <% } %>
        </div>

        <!-- HIỂN THỊ THÔNG TIN NGƯỜI ĐẶT TRUYỆN NẾU CÓ -->
        <% if (story.commissioned_by) { %>
            <div style="margin-bottom: 1.5rem; background: rgba(59, 130, 246, 0.15); border: 1px solid rgba(59, 130, 246, 0.3); border-radius: 8px; padding: 0.8rem 1.2rem; display: flex; align-items: center; gap: 0.5rem; max-width: fit-content;">
                <span>👑</span>
                <span>Truyện viết theo yêu cầu của độc giả: <strong><%= story.commissioned_by %></strong></span>
            </div>
        <% } %>

        <div class="story-detail-desc">
            <h3>Tóm tắt truyện:</h3>
            <p><%= story.description || 'Nội dung bộ truyện đang được cập nhật...' %></p>
        </div>

        <div style="display: flex; gap: 0.8rem; flex-wrap: wrap; align-items: center;">
            <% if (chapters && chapters.length > 0) { %>
                <% if (typeof readingProgress !== 'undefined' && readingProgress) { %>
                    <a href="/story/<%= story.id %>/chapter/<%= readingProgress %>" class="btn btn-primary" style="padding: 0.8rem 2rem;">TIẾP TỤC ĐỌC (Chương <%= readingProgress %>)</a>
                <% } else { %>
                    <a href="/story/<%= story.id %>/chapter/<%= chapters[0].chapter_number %>" class="btn btn-primary" style="padding: 0.8rem 2rem;">ĐỌC TỪ ĐẦU</a>
                <% } %>
            <% } %>

            <% if (typeof user !== 'undefined' && user) { %>
                <button id="bookmark-btn" data-story-id="<%= story.id %>" data-bookmarked="<%= bookmarkStatus ? 'true' : 'false' %>" class="btn <%= bookmarkStatus ? 'btn-secondary' : 'btn-primary' %>" style="padding: 0.8rem 1.8rem; border-radius: 8px; font-weight: 600; display: flex; align-items: center; gap: 0.5rem;">
                    <%= bookmarkStatus ? '💔 Bỏ theo dõi' : '❤️ Theo dõi' %>
                </button>
            <% } %>
        </div>
    </div>
</div>

<script>
    // Xử lý click sao đánh giá truyện
    const ratingWidget = document.getElementById('rating-widget');
    if (ratingWidget) {
        const stars = ratingWidget.querySelectorAll('.rate-star');
        stars.forEach(star => {
            star.addEventListener('click', async () => {
                const score = star.dataset.score;
                const storyId = ratingWidget.dataset.storyId;
                try {
                    const resp = await fetch(`/rate/${storyId}`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ score })
                    });
                    const data = await resp.json();
                    if (data.success) {
                        stars.forEach(s => {
                            s.style.color = parseInt(s.dataset.score) <= parseInt(score) ? '#f59e0b' : 'var(--border-color)';
                        });
                        location.reload();
                    } else {
                        alert('Lỗi: ' + data.error);
                    }
                } catch (err) {
                    alert('Có lỗi xảy ra: ' + err.message);
                }
            });
        });
    }

    const bookmarkBtn = document.getElementById('bookmark-btn');
    if (bookmarkBtn) {
        bookmarkBtn.addEventListener('click', async () => {
            const storyId = bookmarkBtn.dataset.storyId;
            const isBookmarked = bookmarkBtn.dataset.bookmarked === 'true';
            try {
                const resp = await fetch(`/bookmark/${storyId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(isBookmarked ? { remove: true } : { status: 'reading' })
                });
                const data = await resp.json();
                if (data.success) {
                    if (isBookmarked) {
                        bookmarkBtn.dataset.bookmarked = 'false';
                        bookmarkBtn.className = 'btn btn-primary';
                        bookmarkBtn.innerHTML = '❤️ Theo dõi';
                    } else {
                        bookmarkBtn.dataset.bookmarked = 'true';
                        bookmarkBtn.className = 'btn btn-secondary';
                        bookmarkBtn.innerHTML = '💔 Bỏ theo dõi';
                    }
                    location.reload();
                } else {
                    alert('Lỗi: ' + data.error);
                }
            } catch (err) {
                alert('Có lỗi xảy ra: ' + err.message);
            }
        });
    }
</script>

<div class="chapters-container">
    <h2 class="section-title">Danh sách chương</h2>
    
    <% if (!chapters || chapters.length === 0) { %>
        <p style="color: var(--text-secondary); text-align: center; padding: 2rem 0;">Truyện hiện tại chưa có chương nào. Vui lòng quay lại sau!</p>
    <% } else { %>
        <ul class="chapters-list">
            <% chapters.forEach(chapter => { %>
                <li>
                    <a href="/story/<%= story.id %>/chapter/<%= chapter.chapter_number %>" class="chapter-item" style="display: flex; justify-content: space-between; align-items: center; gap: 1rem;">
                        <span style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap; flex: 1;">
                            <strong>Chương <%= chapter.chapter_number %></strong>: <%= chapter.title %>
                        </span>
                        <span style="font-size: 0.8rem; color: var(--text-secondary); display: flex; align-items: center; gap: 0.3rem; flex-shrink: 0;" title="Lượt xem chương">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="opacity: 0.7;"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                            <%= chapter.views || 0 %>
                        </span>
                    </a>
                </li>
            <% }) %>
        </ul>
    <% } %>
</div>

<div class="chapters-container" style="margin-top: 3rem;">
    <h2 class="section-title" style="margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem; font-size: 1.3rem;">
        💬 Bình luận (<%= comments.length %>)
    </h2>

    <% if (typeof user !== 'undefined' && user) { %>
        <!-- New Comment Form -->
        <form id="comment-form" style="display: flex; flex-direction: column; gap: 0.8rem; margin-bottom: 2rem;">
            <textarea id="comment-textarea" placeholder="Viết bình luận của bạn ở đây... Nhắc tên ai đó bằng cách gõ @Tên hiển thị" required style="width: 100%; min-height: 80px; padding: 0.8rem 1rem; border-radius: 10px; border: 1px solid var(--border-color); background: var(--bg-primary); color: var(--text-primary); font-size: 0.9rem; line-height: 1.5; resize: vertical; transition: border-color 0.3s;"></textarea>
            <button type="submit" class="btn btn-primary" style="align-self: flex-end; padding: 0.5rem 1.5rem; font-size: 0.88rem; border-radius: 8px;">Đăng bình luận</button>
        </form>
    <% } else { %>
        <p style="background: rgba(255,255,255,0.02); border: 1px dashed var(--border-color); border-radius: 10px; padding: 1rem; text-align: center; color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 2rem;">
            Vui lòng <a href="/auth/login" style="color: var(--accent-color); font-weight: bold; text-decoration: none;">Đăng nhập</a> để tham gia bình luận.
        </p>
    <% } %>

    <div class="comments-list" style="display: flex; flex-direction: column; gap: 1.5rem;">
        <% if (comments.length === 0) { %>
            <p style="color: var(--text-secondary); text-align: center; padding: 1.5rem 0; font-size: 0.92rem;">Chưa có bình luận nào. Hãy là người đầu tiên chia sẻ cảm nghĩ!</p>
        <% } else { %>
            <!-- Phân tách bình luận gốc và phản hồi -->
            <% 

               const topLevelComments = comments.filter(c => !c.parent_id); 
            %>
            <% topLevelComments.forEach(comment => { %>
                <div class="comment-item" id="comment-<%= comment.id %>" style="display: flex; gap: 1rem; border-bottom: 1px solid rgba(255,255,255,0.03); padding-bottom: 1rem;">
                    <div style="display: flex; flex-direction: column; align-items: center; gap: 0.3rem; flex-shrink: 0; min-width: 60px;">
                        <a href="/user/<%= comment.user_id %>" style="display: inline-block; position: relative;">
                            <% const cFrameClass = (comment.users && comment.users.equipped_frame) ? comment.users.equipped_frame : 'default-frame'; %>
                            <div class="avatar-frame <%= cFrameClass %>" style="width: 42px; height: 42px; padding: 2px; transition: transform 0.2s;" onmouseover="this.style.transform='scale(1.08)'" onmouseout="this.style.transform='scale(1)'">
                                <div class="avatar-glow"></div>
                                <img src="<%= comment.users ? comment.users.avatar : '/css/silly_duck.png' %>" alt="avatar" class="avatar-img" style="border-width: 1px;">
                            </div>
                        </a>
                        <% if (comment.users && comment.users.equipped_badge) { %>
                            <% const badgeText = comment.users.equipped_badge.replace(/^([\uD800-\uDBFF][\uDC00-\uDFFF]|\S)\s*/, ''); %>
                            <span class="game-title <%= getTitleRarityClass(comment.users.equipped_badge) %>" style="font-size: 0.55rem; padding: 2px 6px; transform: scale(0.75); z-index: 2; margin-top: -6px; white-space: nowrap;"><%= badgeText %></span>
                        <% } %>
                    </div>
                    
                    <div style="flex: 1;">
                        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.3rem;">
                            <span style="font-weight: 600; font-size: 0.92rem;">
                                <a href="/user/<%= comment.user_id %>" style="text-decoration: none; color: inherit; transition: color 0.2s;" onmouseover="this.style.color='var(--accent-color)'" onmouseout="this.style.color='inherit'">
                                    <%= comment.users ? comment.users.display_name : 'Độc giả ẩn danh' %>
                                </a>

                            </span>
                            <span style="font-size: 0.78rem; color: var(--text-secondary);"><%= new Date(comment.created_at).toLocaleDateString('vi-VN', { hour: '2-digit', minute: '2-digit' }) %></span>
                        </div>
                        
                        <!-- Nội dung comment có hightlight tags -->
                        <div class="comment-content" style="font-size: 0.9rem; line-height: 1.6; color: var(--text-primary); white-space: pre-wrap; margin-bottom: 0.6rem;"><%- comment.content.replace(/@([a-zA-Z0-9_\sà-ỹÀ-Ỹ]+)/g, '<span style="color:var(--accent-color); font-weight:600;">@$1</span>') %></div>
                        
                        <!-- Action buttons -->
                        <div style="display: flex; align-items: center; gap: 1.2rem; font-size: 0.8rem; color: var(--text-secondary);">
                            <button onclick="likeComment(<%= comment.id %>)" class="like-btn" style="background: none; border: none; color: <%= comment.user_liked ? 'var(--accent-color)' : 'var(--text-secondary)' %>; cursor: pointer; display: flex; align-items: center; gap: 0.3rem; font-size: 0.8rem; padding: 0;">
                                ❤️ <span class="likes-count"><%= comment.likes_count %></span> Thích
                            </button>
                            <% if (typeof user !== 'undefined' && user) { %>
                                <button onclick="showReplyForm(<%= comment.id %>, '<%= comment.users ? comment.users.display_name : '' %>')" style="background: none; border: none; color: var(--text-secondary); cursor: pointer; padding: 0; font-size: 0.8rem;">
                                    💬 Trả lời
                                </button>
                            <% } %>
                            <% if (typeof user !== 'undefined' && user && (user.id === comment.user_id || user.role === 'admin')) { %>
                                <button onclick="deleteComment(<%= comment.id %>)" style="background: none; border: none; color: #ef4444; cursor: pointer; padding: 0; font-size: 0.8rem; display: flex; align-items: center; gap: 0.2rem;">
                                    🗑️ Xóa
                                </button>
                            <% } %>
                        </div>

                        <!-- Danh sách phản hồi lồng nhau -->
                        <% const replies = comments.filter(c => c.parent_id === comment.id); %>
                        <% if (replies.length > 0) { %>
                            <div class="replies-container" style="margin-top: 1rem; padding-left: 1rem; border-left: 2px solid var(--border-color); display: flex; flex-direction: column; gap: 1rem;">
                                <% replies.forEach(reply => { %>
                                    <div class="comment-item" id="comment-<%= reply.id %>" style="display: flex; gap: 0.8rem;">
                                        <div style="display: flex; flex-direction: column; align-items: center; gap: 0.2rem; flex-shrink: 0; min-width: 45px;">
                                            <a href="/user/<%= reply.user_id %>" style="display: inline-block; position: relative;">
                                                <% const rFrameClass = (reply.users && reply.users.equipped_frame) ? reply.users.equipped_frame : 'default-frame'; %>
                                                <div class="avatar-frame <%= rFrameClass %>" style="width: 32px; height: 32px; padding: 2px; transition: transform 0.2s;" onmouseover="this.style.transform='scale(1.08)'" onmouseout="this.style.transform='scale(1)'">
                                                    <div class="avatar-glow"></div>
                                                    <img src="<%= reply.users ? reply.users.avatar : '/css/silly_duck.png' %>" alt="avatar" class="avatar-img" style="border-width: 1px;">
                                                </div>
                                            </a>
                                            <% if (reply.users && reply.users.equipped_badge) { %>
                                                <% const rBadgeText = reply.users.equipped_badge.replace(/^([\uD800-\uDBFF][\uDC00-\uDFFF]|\S)\s*/, ''); %>
                                                <span class="game-title <%= getTitleRarityClass(reply.users.equipped_badge) %>" style="font-size: 0.5rem; padding: 2px 4px; transform: scale(0.65); z-index: 2; margin-top: -5px; white-space: nowrap;"><%= rBadgeText %></span>
                                            <% } %>
                                        </div>
                                        <div style="flex: 1;">
                                            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.2rem;">
                                                <span style="font-weight: 600; font-size: 0.88rem;">
                                                    <a href="/user/<%= reply.user_id %>" style="text-decoration: none; color: inherit; transition: color 0.2s;" onmouseover="this.style.color='var(--accent-color)'" onmouseout="this.style.color='inherit'">
                                                        <%= reply.users ? reply.users.display_name : 'Độc giả ẩn danh' %>
                                                    </a>

                                                </span>
                                                <span style="font-size: 0.75rem; color: var(--text-secondary);"><%= new Date(reply.created_at).toLocaleDateString('vi-VN', { hour: '2-digit', minute: '2-digit' }) %></span>
                                            </div>
                                            <div class="comment-content" style="font-size: 0.86rem; line-height: 1.5; color: var(--text-primary); white-space: pre-wrap; margin-bottom: 0.4rem;"><%- reply.content.replace(/@([a-zA-Z0-9_\sà-ỹÀ-Ỹ]+)/g, '<span style="color:var(--accent-color); font-weight:600;">@$1</span>') %></div>
                                            <div style="display: flex; align-items: center; gap: 1rem;">
                                                <button onclick="likeComment(<%= reply.id %>)" class="like-btn" style="background: none; border: none; color: <%= reply.user_liked ? 'var(--accent-color)' : 'var(--text-secondary)' %>; cursor: pointer; display: flex; align-items: center; gap: 0.2rem; font-size: 0.75rem; padding: 0;">
                                                    ❤️ <span class="likes-count"><%= reply.likes_count %></span> Thích
                                                </button>
                                                <% if (typeof user !== 'undefined' && user && (user.id === reply.user_id || user.role === 'admin')) { %>
                                                    <button onclick="deleteComment(<%= reply.id %>)" style="background: none; border: none; color: #ef4444; cursor: pointer; padding: 0; font-size: 0.75rem; display: flex; align-items: center; gap: 0.2rem;">
                                                        🗑️ Xóa
                                                    </button>
                                                <% } %>
                                            </div>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        <% } %>

                        <!-- Form trả lời ẩn -->
                        <div id="reply-form-<%= comment.id %>" style="display: none; margin-top: 1rem; background: rgba(0,0,0,0.15); border-radius: 8px; padding: 0.8rem;">
                            <textarea id="reply-textarea-<%= comment.id %>" placeholder="Viết câu trả lời của bạn..." required style="width: 100%; min-height: 60px; padding: 0.5rem 0.8rem; border-radius: 6px; border: 1px solid var(--border-color); background: var(--bg-primary); color: var(--text-primary); font-size: 0.85rem; line-height: 1.4; resize: vertical; margin-bottom: 0.5rem;"></textarea>
                            <div style="display: flex; justify-content: flex-end; gap: 0.5rem;">
                                <button onclick="cancelReply(<%= comment.id %>)" class="btn btn-secondary" style="font-size: 0.75rem; padding: 0.3rem 0.8rem; border-radius: 6px;">Hủy</button>
                                <button onclick="submitReply(<%= comment.id %>)" class="btn btn-primary" style="font-size: 0.75rem; padding: 0.3rem 0.8rem; border-radius: 6px;">Trả lời</button>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } %>
    </div>
</div>

<script>
    // Xử lý gửi bình luận chính
    const commentForm = document.getElementById('comment-form');
    if (commentForm) {
        commentForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const textarea = document.getElementById('comment-textarea');
            const content = textarea.value;
            const storyId = '<%= story.id %>';

            try {
                const resp = await fetch(`/story/${storyId}/comment`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        content,
                        chapter_number: null
                    })
                });
                const data = await resp.json();
                if (data.success) {
                    location.reload();
                } else {
                    alert('Lỗi: ' + data.error);
                }
            } catch (err) {
                alert('Lỗi hệ thống: ' + err.message);
            }
        });
    }

    // Like bình luận
    async function likeComment(commentId) {
        try {
            const resp = await fetch(`/comment/${commentId}/like`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            });
            const data = await resp.json();
            if (data.success) {
                const commentItem = document.getElementById(`comment-${commentId}`);
                const likeBtn = commentItem.querySelector('.like-btn');
                const likesCountSpan = likeBtn.querySelector('.likes-count');
                
                likesCountSpan.textContent = data.likesCount;
                likeBtn.style.color = data.liked ? 'var(--accent-color)' : 'var(--text-secondary)';
            }
        } catch (err) {
            console.error('Lỗi khi like bình luận:', err);
        }
    }

    // Hiển thị khung trả lời bình luận
    function showReplyForm(commentId, displayName) {
        document.querySelectorAll('[id^="reply-form-"]').forEach(f => f.style.display = 'none');
        
        const form = document.getElementById(`reply-form-${commentId}`);
        const textarea = document.getElementById(`reply-textarea-${commentId}`);
        if (form && textarea) {
            form.style.display = 'block';
            textarea.value = `@${displayName} `;
            textarea.focus();
        }
    }

    function cancelReply(commentId) {
        const form = document.getElementById(`reply-form-${commentId}`);
        if (form) form.style.display = 'none';
    }

    // Gửi phản hồi bình luận
    async function submitReply(parentCommentId) {
        const textarea = document.getElementById(`reply-textarea-${parentCommentId}`);
        const content = textarea.value;
        const storyId = '<%= story.id %>';

        if (!content || !content.trim()) {
            alert('Vui lòng điền nội dung phản hồi.');
            return;
        }

        try {
            const resp = await fetch(`/story/${storyId}/comment`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    content,
                    chapter_number: null,
                    parent_id: parentCommentId
                })
            });
            const data = await resp.json();
            if (data.success) {
                location.reload();
            } else {
                alert('Lỗi: ' + data.error);
            }
        } catch (err) {
            alert('Lỗi: ' + err.message);
        }
    }

    // Xóa bình luận
    async function deleteComment(commentId) {
        if (!confirm('Bạn có chắc chắn muốn xóa bình luận này?')) return;
        try {
            const resp = await fetch(`/comment/${commentId}/delete`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            });
            const data = await resp.json();
            if (data.success) {
                const commentEl = document.getElementById(`comment-${commentId}`);
                if (commentEl) {
                    commentEl.remove();
                } else {
                    location.reload();
                }
            } else {
                alert(data.error || 'Lỗi khi xóa bình luận.');
            }
        } catch (err) {
            console.error('Lỗi khi xóa bình luận:', err);
            alert('Lỗi hệ thống khi xóa bình luận.');
        }
    }
</script>

<%- include('partials/footer') %>
