    </main>
    <footer>
        <p>&copy; 2026 TruyenApp. Thiết kế với sự cao cấp và tối ưu hóa tốt nhất.</p>
        <p style="margin-top: 0.5rem;"><a href="/donate" style="color: var(--accent-color);">☕ Ủng hộ Admin</a></p>
    </footer>
    <script src="/js/main.js"></script>
    <div id="avatar-zoom-modal" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.85); z-index: 9999; justify-content: center; align-items: center; cursor: zoom-out;">
        <img id="avatar-zoom-img" style="width: 400px; height: 400px; max-width: 90vw; max-height: 90vw; border-radius: 50%; box-shadow: 0 0 40px rgba(255,255,255,0.2); object-fit: cover;">
    </div>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const modal = document.getElementById('avatar-zoom-modal');
            const modalImg = document.getElementById('avatar-zoom-img');
            
            document.body.addEventListener('click', (e) => {
                if (e.target.classList.contains('avatar-zoomable')) {
                    e.preventDefault(); 
                    modalImg.src = e.target.src;
                    modal.style.display = 'flex';
                }
                if (e.target.id === 'avatar-zoom-modal' || e.target.id === 'avatar-zoom-img') {
                    modal.style.display = 'none';
                }
            });
        });
    </script>
</body>
</html>
