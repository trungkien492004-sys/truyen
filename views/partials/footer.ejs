    </main>
    <footer>
        <p>&copy; 2026 TruyenApp. Thiết kế với sự cao cấp và tối ưu hóa tốt nhất.</p>
        <p style="margin-top: 0.5rem;"><a href="/donate" style="color: var(--accent-color);">☕ Ủng hộ Admin</a></p>
    </footer>
    <script src="/js/main.js"></script>
    <div id="avatar-zoom-modal" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.85); z-index: 9999; justify-content: center; align-items: center; cursor: zoom-out;">
        <img id="avatar-zoom-img" style="width: 400px; height: 400px; max-width: 90vw; max-height: 90vw; border-radius: 50%; box-shadow: 0 0 40px rgba(255,255,255,0.2); object-fit: cover;">
    </div>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const modal = document.getElementById('avatar-zoom-modal');
            const modalImg = document.getElementById('avatar-zoom-img');

            document.body.addEventListener('click', (e) => {
                if (e.target.classList.contains('avatar-zoomable')) {
                    e.preventDefault();
                    modalImg.src = e.target.src;
                    modal.style.display = 'flex';
                }
                if (e.target.id === 'avatar-zoom-modal' || e.target.id === 'avatar-zoom-img') {
                    modal.style.display = 'none';
                }
            });

            // Tự động thu nhỏ font-size của huy hiệu (.game-title-autofit) cho đến khi chữ
            // vừa khít trong khung - GIỮ NGUYÊN VẸN toàn bộ chữ (không cắt bớt, không xuống dòng),
            // chỉ giảm cỡ chữ dần từng bước nhỏ cho tới khi hết tràn.
            document.querySelectorAll('.game-title-autofit').forEach(el => {
                const maxWidth = el.parentElement ? el.parentElement.clientWidth || 78 : 78;
                let fontSize = parseFloat(getComputedStyle(el).fontSize);
                let guard = 0;
                // Dùng setProperty với 'important' vì class CSS .game-title-sidebar-scale khai báo
                // font-size với !important - inline style thường (el.style.fontSize = ...) không
                // thể thắng !important nên bị vô hiệu hoàn toàn, khiến scrollWidth không đổi dù đã set.
                while (el.scrollWidth > maxWidth && fontSize > 7.5 && guard < 40) {
                    fontSize -= 0.5;
                    el.style.setProperty('font-size', fontSize + 'px', 'important');
                    guard++;
                }
            });
        });
    </script>
</body>
</html>
