<%
    const frameClass = user.equipped_frame || 'default-frame';
    const avatarSrc = user.avatar || '/css/silly_duck.png';
    const badge = user.equipped_badge;
    const chaptersRead = user.chapters_read || 0;
    
    // Default to large (Profile) which uses native CSS values
    let containerStyle = "display: flex; flex-direction: column; align-items: center; gap: 0.6rem;";
    let frameStyle = "";
    let cornerStyle = "position: absolute; top: -5px; right: -5px; font-size: 1.2rem; background: rgba(0,0,0,0.7); border-radius: 50%; padding: 4px; z-index: 10; border: 2px solid gold; display: flex; justify-content: center; align-items: center; width: 28px; height: 28px;";
    let titleContainerStyle = "display: flex; flex-direction: column; align-items: center;";
    let titleStyle = "";
    let titleExtraClass = "";
    let starClass = "rank-stars";
    let starStyle = "";

    // Small (Leaderboard) applies inline styles to scale down
    if (size === 'small') {
        containerStyle = "position: relative; display: flex; flex-direction: column; align-items: center; gap: 0.3rem; max-width: 78px;";
        frameStyle = "width: 56px; height: 56px; padding: 2px;";
        cornerStyle = "position: absolute; top: -4px; right: -4px; font-size: 0.8rem; background: rgba(0,0,0,0.6); border-radius: 50%; padding: 2px; z-index: 10; border: 1px solid gold; display: flex; justify-content: center; align-items: center; width: 18px; height: 18px;";
        titleContainerStyle = "display: flex; flex-direction: column; align-items: center; margin-top: 2px; z-index: 2; line-height: 1.1; max-width: 78px;";
        // KHÔNG ép font-size cứng ở đây nữa (gây bug to nhỏ lẫn lộn giữa các tầng rarity) -
        // dùng class .game-title-sidebar-scale (định nghĩa trong style.css) để CSS class tự
        // quyết định size theo đúng tầng rarity, chỉ giới hạn overflow để không tràn ra ngoài.
        titleStyle = "white-space: nowrap; max-width: 78px; display: inline-flex;";
        titleExtraClass = "game-title-sidebar-scale game-title-autofit";
        starClass = "";
        starStyle = "color: #ffd700; font-size: 0.65rem; letter-spacing: 1px; text-shadow: 0 0 2px rgba(255,255,255,0.3); margin-top: 2px;";
    }
%>

<div style="<%= containerStyle %>">
    <a href="/user/<%= user.id %>" style="text-decoration: none; display: inline-block;">
        <div class="avatar-frame <%= frameClass %>" style="<%= frameStyle %>">
            <div class="avatar-glow"></div>
            <img src="<%= avatarSrc %>" class="avatar-img avatar-zoomable" alt="avatar" style="border-width: 1px;">
            <% if (badge) { %>
                <div class="avatar-corner" style="<%= cornerStyle %>">
                    <%= getBadgeIcon(badge) %>
                </div>
            <% } %>
        </div>
    </a>
    <% if (badge) { %>
        <div style="<%= titleContainerStyle %>">
            <div class="game-title <%= getTitleRarityClass(badge) %> <%= titleExtraClass %>" style="<%= titleStyle %>"><%= badge %></div>
            <div class="<%= starClass %>" style="<%= starStyle %>"><%= getStarsByChapters(chaptersRead) %></div>
        </div>
    <% } %>
</div>
