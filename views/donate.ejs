<%- include('partials/header') %>

<div class="form-container" style="max-width: 550px; text-align: center;">
    <h2 class="section-title" style="margin-bottom: 0.5rem;">☕ Ủng Hộ Admin</h2>
    <p style="color: var(--text-secondary); margin-bottom: 2rem; font-size: 0.95rem;">
