<%- include('partials/header') %>

<div style="margin-bottom: 1.5rem;">
    <a href="/" style="color: var(--text-secondary); font-size: 0.9rem;">&larr; Quay lại trang chủ</a>
</div>

<h2 class="section-title">📚 Tủ truyện của tôi (<%= stories.length %>)</h2>

<% if (stories.length === 0) { %>
    <p style="color: var(--text-secondary); text-align: center; padding: 3rem 0; font-size: 1rem;">Bạn chưa theo dõi bộ truyện nào. Hãy ấn Theo dõi để lưu truyện tại đây nhé!</p>
<% } else { %>
    <div class="stories-grid">
        <% stories.forEach(story => { %>
            <div class="story-card">
                <a href="/story/<%= story.id %>">
                    <img src="<%= story.cover_url %>" alt="<%= story.title %>" class="story-cover">
                </a>
                <div class="story-info">
                    <a href="/story/<%= story.id %>" class="story-title" title="<%= story.title %>">
                        <%= story.title %>
                    </a>
                    <span class="story-author">Tác giả: <%= story.author %></span>
                    <% if (story.lastReadChapter) { %>
                        <p class="story-desc-short" style="color: var(--accent-color); font-weight: 500; margin-bottom: 0.8rem;">📖 Đang đọc: Chương <%= story.lastReadChapter %></p>
                    <% } %>
                    <a href="/story/<%= story.id %><%= story.lastReadChapter ? '/chapter/' + story.lastReadChapter : '' %>" class="btn btn-secondary btn-primary" style="margin-top: auto; font-size: 0.85rem; padding: 0.5rem;"><%= story.lastReadChapter ? 'Đọc tiếp' : 'Đọc ngay' %></a>
                </div>
            </div>
        <% }) %>
    </div>
<% } %>

<%- include('partials/footer') %>
