<%- include('partials/header') %>

<div class="read-container" style="max-width: 800px; margin: 0 auto; padding: 2rem 1rem;">
    <div style="margin-bottom: 1.5rem;">
        <a href="/" style="color: var(--text-secondary); font-size: 0.9rem;">&larr; Quay lại trang chủ</a>
    </div>

    <div style="background: linear-gradient(135deg, rgba(30, 41, 59, 0.7) 0%, rgba(15, 23, 42, 0.9) 100%); border: 1px solid var(--border-color); border-radius: 16px; padding: 2rem; margin-bottom: 2rem; box-shadow: 0 10px 30px rgba(0,0,0,0.3); backdrop-filter: blur(10px); text-align: center;">
        <h2 style="margin: 0 0 0.5rem 0; font-size: 2rem; background: linear-gradient(90deg, #3b82f6 0%, #8b5cf6 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; font-weight: bold;">🏆 Bảng Xếp Hạng</h2>
        <p style="color: var(--text-secondary); font-size: 0.95rem; margin: 0;">Vinh danh những cá nhân xuất sắc nhất của thư viện!</p>
    </div>

    <!-- TABS -->
    <div style="display: flex; gap: 1rem; margin-bottom: 1.5rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; flex-wrap: wrap;">
        <button class="tab-btn active" onclick="switchTab('readers')" style="background: none; border: none; color: var(--text-primary); font-size: 1.05rem; font-weight: bold; cursor: pointer; padding: 0.5rem 0.8rem; border-bottom: 3px solid var(--accent-color); transition: all 0.2s;">👑 Độc Giả</button>
        <button class="tab-btn" onclick="switchTab('comics')" style="background: none; border: none; color: var(--text-secondary); font-size: 1.05rem; font-weight: bold; cursor: pointer; padding: 0.5rem 0.8rem; border-bottom: 3px solid transparent; transition: all 0.2s;">🖼️ Truyện Tranh Top</button>
        <button class="tab-btn" onclick="switchTab('novels')" style="background: none; border: none; color: var(--text-secondary); font-size: 1.05rem; font-weight: bold; cursor: pointer; padding: 0.5rem 0.8rem; border-bottom: 3px solid transparent; transition: all 0.2s;">📄 Truyện Chữ Top</button>
        <button class="tab-btn" onclick="switchTab('authors')" style="background: none; border: none; color: var(--text-secondary); font-size: 1.05rem; font-weight: bold; cursor: pointer; padding: 0.5rem 0.8rem; border-bottom: 3px solid transparent; transition: all 0.2s;">✍️ Tác Giả</button>
    </div>

    <!-- TAB ĐỘC GIẢ -->
    <div id="tab-readers" class="tab-content" style="display: block;">
        <div style="background: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: 16px; padding: 1.5rem; box-shadow: 0 4px 20px rgba(0,0,0,0.15); overflow-x: auto;">
            <table class="leaderboard-table" style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.95rem;">
            <thead>
                <tr style="border-bottom: 2px solid var(--border-color); color: var(--text-secondary); font-weight: bold;">
                    <th style="padding: 1rem 0.8rem; text-align: center; width: 80px;">Hạng</th>
                    <th style="padding: 1rem 0.8rem;">Độc giả</th>
                    <th style="padding: 1rem 0.8rem;">Huy hiệu</th>
                    <th style="padding: 1rem 0.8rem; text-align: right; width: 120px;">Số chương</th>
                    <th style="padding: 1rem 0.8rem; text-align: center;">Cấp độ</th>
                    <th style="padding: 1rem 0.8rem; text-align: right; width: 100px;">EXP</th>
                </tr>
            </thead>
            <tbody>
                <% if (leaderboard.length === 0) { %>
                    <tr>
                        <td colspan="6" style="padding: 2rem; text-align: center; color: var(--text-secondary);">Chưa có dữ liệu độc giả nào. Hãy bắt đầu đọc chương để ghi danh!</td>
                    </tr>
                <% } else { %>
                    <% leaderboard.forEach((reader, index) => { %>
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.03); transition: background-color 0.2s;" class="leaderboard-row">
                            <td data-label="Hạng" style="padding: 1rem 0.8rem; text-align: center;">
                                <% if (index === 0) { %>
                                    <span style="font-size: 1.4rem;" title="Quán quân">🥇</span>
                                <% } else if (index === 1) { %>
                                    <span style="font-size: 1.4rem;" title="Á quân">🥈</span>
                                <% } else if (index === 2) { %>
                                    <span style="font-size: 1.4rem;" title="Hạng ba">🥉</span>
                                <% } else { %>
                                    <span style="font-weight: bold; color: var(--text-secondary);"><%= index + 1 %></span>
                                <% } %>
                            </td>
                            <td data-label="Độc giả" style="padding: 0.8rem 0.8rem; display: flex; align-items: center; gap: 0.8rem;">
                                <%- include('partials/avatar', { user: reader, size: 'small' }) %>
                                <span style="font-weight: 600;">
                                    <a href="/user/<%= reader.id %>" style="text-decoration: none; color: inherit; transition: color 0.2s;" onmouseover="this.style.color='var(--accent-color)'" onmouseout="this.style.color='inherit'">
                                        <%= reader.display_name %>
                                    </a>
                                </span>
                            </td>
                            <td data-label="Huy hiệu" style="padding: 0.8rem 0.8rem;">
                                <div style="display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap;">
                                    <!-- Rank (Tu vi / Cảnh giới) -->
                                    <%
                                        let calculatedRank = 'Người mới';
                                        if (typeof rankSettings !== 'undefined' && rankSettings) {
                                            const found = rankSettings.find(r => (reader.chapters_read || 0) >= r.count);
                                            if (found) calculatedRank = found.label;
                                        }
                                    %>
                                    <span style="font-size: 0.8rem; background: rgba(99, 102, 241, 0.1); color: var(--accent-color); padding: 0.25rem 0.6rem; border-radius: 12px; font-weight: 500; border: 1px solid rgba(99, 102, 241, 0.2); white-space: nowrap;">
                                        <%= calculatedRank %>
                                    </span>
                                </div>
                            </td>
                            <td data-label="Số chương" style="padding: 1rem 0.8rem; text-align: right; font-weight: 500;">
                                <%= reader.chapters_read || 0 %>
                            </td>
                            <td data-label="Cấp độ" style="padding: 1rem 0.8rem; text-align: center; font-weight: bold; color: #10b981;">
                                Lvl <%= Math.floor((reader.exp || 0) / 100) + 1 %>
                            </td>
                            <td data-label="EXP" style="padding: 1rem 0.8rem; text-align: right; font-weight: bold; color: var(--accent-color);">
                                <%= reader.exp || 0 %>
                            </td>
                        </tr>
                    <% }) %>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

    <!-- TAB TRUYỆN TRANH TOP - có sub-tab lọc theo ngày/tuần/tháng/đánh giá/theo dõi, dữ liệu
         đã được route index.js chuẩn bị sẵn (topComicDaily, topComicWeekly, topComicMonthly,
         topComicRated, topComicBookmarks) nhưng trước đây view chỉ hiển thị mỗi bản daily. -->
    <div id="tab-comics" class="tab-content" style="display: none;">
        <div style="display: flex; gap: 0.4rem; margin-bottom: 1rem; flex-wrap: wrap;">
            <button class="sub-tab-btn active" data-scope="comic" data-period="daily" onclick="switchLbSubTab(this)" style="padding: 0.35rem 0.8rem; font-size: 0.82rem; font-weight: 600; border-radius: 8px; border: 1px solid var(--border-color); cursor: pointer; background: var(--accent-color); color: white;">📅 Hôm nay</button>
            <button class="sub-tab-btn" data-scope="comic" data-period="weekly" onclick="switchLbSubTab(this)" style="padding: 0.35rem 0.8rem; font-size: 0.82rem; font-weight: 600; border-radius: 8px; border: 1px solid var(--border-color); cursor: pointer; background: transparent; color: var(--text-secondary);">🗓️ Tuần này</button>
            <button class="sub-tab-btn" data-scope="comic" data-period="monthly" onclick="switchLbSubTab(this)" style="padding: 0.35rem 0.8rem; font-size: 0.82rem; font-weight: 600; border-radius: 8px; border: 1px solid var(--border-color); cursor: pointer; background: transparent; color: var(--text-secondary);">📆 Tháng này</button>
            <button class="sub-tab-btn" data-scope="comic" data-period="rated" onclick="switchLbSubTab(this)" style="padding: 0.35rem 0.8rem; font-size: 0.82rem; font-weight: 600; border-radius: 8px; border: 1px solid var(--border-color); cursor: pointer; background: transparent; color: var(--text-secondary);">⭐ Đánh giá cao</button>
            <button class="sub-tab-btn" data-scope="comic" data-period="bookmarks" onclick="switchLbSubTab(this)" style="padding: 0.35rem 0.8rem; font-size: 0.82rem; font-weight: 600; border-radius: 8px; border: 1px solid var(--border-color); cursor: pointer; background: transparent; color: var(--text-secondary);">❤️ Theo dõi nhiều</button>
        </div>
        <%
            const comicScopes = [
                { period: 'daily', data: typeof topComicDaily !== 'undefined' ? topComicDaily : [] },
                { period: 'weekly', data: typeof topComicWeekly !== 'undefined' ? topComicWeekly : [] },
                { period: 'monthly', data: typeof topComicMonthly !== 'undefined' ? topComicMonthly : [] },
                { period: 'rated', data: typeof topComicRated !== 'undefined' ? topComicRated : [] },
                { period: 'bookmarks', data: typeof topComicBookmarks !== 'undefined' ? topComicBookmarks : [] }
            ];
        %>
        <% comicScopes.forEach((scope, scopeIdx) => { %>
            <div class="lb-sub-content" data-scope="comic" data-period="<%= scope.period %>" style="<%= scopeIdx === 0 ? '' : 'display: none;' %>">
                <div style="background: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: 16px; padding: 1.5rem; box-shadow: 0 4px 20px rgba(0,0,0,0.15); overflow-x: auto;">
                    <table class="leaderboard-table" style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.95rem;">
                        <thead>
                            <tr style="border-bottom: 2px solid var(--border-color); color: var(--text-secondary); font-weight: bold;">
                                <th style="padding: 1rem 0.8rem; text-align: center; width: 80px;">Hạng</th>
                                <th style="padding: 1rem 0.8rem;">Bộ Truyện Tranh</th>
                                <th style="padding: 1rem 0.8rem;">Tác giả</th>
                                <th style="padding: 1rem 0.8rem; text-align: right;">
                                    <% if (scope.period === 'rated') { %>Điểm<% } else if (scope.period === 'bookmarks') { %>Theo dõi<% } else { %>Lượt xem<% } %>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (!scope.data || scope.data.length === 0) { %>
                                <tr><td colspan="4" style="padding: 2rem; text-align: center; color: var(--text-secondary);">Chưa có dữ liệu.</td></tr>
                            <% } else { %>
                                <% scope.data.forEach((story, index) => { %>
                                    <tr style="border-bottom: 1px solid rgba(255,255,255,0.03);" class="leaderboard-row">
                                        <td style="padding: 1rem 0.8rem; text-align: center;">
                                            <% if (index === 0) { %>🥇<% } else if (index === 1) { %>🥈<% } else if (index === 2) { %>🥉<% } else { %><%= index + 1 %><% } %>
                                        </td>
                                        <td style="padding: 0.8rem; display: flex; align-items: center; gap: 0.8rem;">
                                            <img src="<%= story.cover_url %>" style="width: 38px; height: 50px; object-fit: cover; border-radius: 4px;">
                                            <a href="/story/<%= story.id %>" style="font-weight: 600; color: var(--text-primary); text-decoration: none;"><%= story.title %></a>
                                        </td>
                                        <td style="padding: 0.8rem; color: var(--text-secondary);"><%= story.author || 'Chưa rõ' %></td>
                                        <td style="padding: 0.8rem; text-align: right; font-weight: bold; color: var(--accent-color);">
                                            <% if (scope.period === 'rated') { %>⭐ <%= parseFloat(story.avg_score || 0).toFixed(1) %>
                                            <% } else if (scope.period === 'bookmarks') { %>❤️ <%= story.bookmark_count || 0 %>
                                            <% } else { %>👁️ <%= story.view_count || 0 %><% } %>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        <% }) %>
    </div>

    <!-- TAB TRUYỆN CHỮ TOP - cùng cấu trúc sub-tab như Truyện Tranh Top ở trên -->
    <div id="tab-novels" class="tab-content" style="display: none;">
        <div style="display: flex; gap: 0.4rem; margin-bottom: 1rem; flex-wrap: wrap;">
            <button class="sub-tab-btn active" data-scope="novel" data-period="daily" onclick="switchLbSubTab(this)" style="padding: 0.35rem 0.8rem; font-size: 0.82rem; font-weight: 600; border-radius: 8px; border: 1px solid var(--border-color); cursor: pointer; background: var(--accent-color); color: white;">📅 Hôm nay</button>
            <button class="sub-tab-btn" data-scope="novel" data-period="weekly" onclick="switchLbSubTab(this)" style="padding: 0.35rem 0.8rem; font-size: 0.82rem; font-weight: 600; border-radius: 8px; border: 1px solid var(--border-color); cursor: pointer; background: transparent; color: var(--text-secondary);">🗓️ Tuần này</button>
            <button class="sub-tab-btn" data-scope="novel" data-period="monthly" onclick="switchLbSubTab(this)" style="padding: 0.35rem 0.8rem; font-size: 0.82rem; font-weight: 600; border-radius: 8px; border: 1px solid var(--border-color); cursor: pointer; background: transparent; color: var(--text-secondary);">📆 Tháng này</button>
            <button class="sub-tab-btn" data-scope="novel" data-period="rated" onclick="switchLbSubTab(this)" style="padding: 0.35rem 0.8rem; font-size: 0.82rem; font-weight: 600; border-radius: 8px; border: 1px solid var(--border-color); cursor: pointer; background: transparent; color: var(--text-secondary);">⭐ Đánh giá cao</button>
            <button class="sub-tab-btn" data-scope="novel" data-period="bookmarks" onclick="switchLbSubTab(this)" style="padding: 0.35rem 0.8rem; font-size: 0.82rem; font-weight: 600; border-radius: 8px; border: 1px solid var(--border-color); cursor: pointer; background: transparent; color: var(--text-secondary);">❤️ Theo dõi nhiều</button>
        </div>
        <%
            const novelScopes = [
                { period: 'daily', data: typeof topNovelDaily !== 'undefined' ? topNovelDaily : [] },
                { period: 'weekly', data: typeof topNovelWeekly !== 'undefined' ? topNovelWeekly : [] },
                { period: 'monthly', data: typeof topNovelMonthly !== 'undefined' ? topNovelMonthly : [] },
                { period: 'rated', data: typeof topNovelRated !== 'undefined' ? topNovelRated : [] },
                { period: 'bookmarks', data: typeof topNovelBookmarks !== 'undefined' ? topNovelBookmarks : [] }
            ];
        %>
        <% novelScopes.forEach((scope, scopeIdx) => { %>
            <div class="lb-sub-content" data-scope="novel" data-period="<%= scope.period %>" style="<%= scopeIdx === 0 ? '' : 'display: none;' %>">
                <div style="background: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: 16px; padding: 1.5rem; box-shadow: 0 4px 20px rgba(0,0,0,0.15); overflow-x: auto;">
                    <table class="leaderboard-table" style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.95rem;">
                        <thead>
                            <tr style="border-bottom: 2px solid var(--border-color); color: var(--text-secondary); font-weight: bold;">
                                <th style="padding: 1rem 0.8rem; text-align: center; width: 80px;">Hạng</th>
                                <th style="padding: 1rem 0.8rem;">Bộ Truyện Chữ</th>
                                <th style="padding: 1rem 0.8rem;">Tác giả</th>
                                <th style="padding: 1rem 0.8rem; text-align: right;">
                                    <% if (scope.period === 'rated') { %>Điểm<% } else if (scope.period === 'bookmarks') { %>Theo dõi<% } else { %>Lượt xem<% } %>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (!scope.data || scope.data.length === 0) { %>
                                <tr><td colspan="4" style="padding: 2rem; text-align: center; color: var(--text-secondary);">Chưa có dữ liệu.</td></tr>
                            <% } else { %>
                                <% scope.data.forEach((story, index) => { %>
                                    <tr style="border-bottom: 1px solid rgba(255,255,255,0.03);" class="leaderboard-row">
                                        <td style="padding: 1rem 0.8rem; text-align: center;">
                                            <% if (index === 0) { %>🥇<% } else if (index === 1) { %>🥈<% } else if (index === 2) { %>🥉<% } else { %><%= index + 1 %><% } %>
                                        </td>
                                        <td style="padding: 0.8rem; display: flex; align-items: center; gap: 0.8rem;">
                                            <img src="<%= story.cover_url %>" style="width: 38px; height: 50px; object-fit: cover; border-radius: 4px;">
                                            <a href="/story/<%= story.id %>" style="font-weight: 600; color: var(--text-primary); text-decoration: none;"><%= story.title %></a>
                                        </td>
                                        <td style="padding: 0.8rem; color: var(--text-secondary);"><%= story.author || 'Chưa rõ' %></td>
                                        <td style="padding: 0.8rem; text-align: right; font-weight: bold; color: var(--accent-color);">
                                            <% if (scope.period === 'rated') { %>⭐ <%= parseFloat(story.avg_score || 0).toFixed(1) %>
                                            <% } else if (scope.period === 'bookmarks') { %>❤️ <%= story.bookmark_count || 0 %>
                                            <% } else { %>👁️ <%= story.view_count || 0 %><% } %>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        <% }) %>
    </div>

<!-- TAB TÁC GIẢ -->
<div id="tab-authors" class="tab-content" style="display: none;">
    <div style="background: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: 16px; padding: 1.5rem; box-shadow: 0 4px 20px rgba(0,0,0,0.15); overflow-x: auto;">
        <table class="leaderboard-table" style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.95rem;">
            <thead>
                <tr style="border-bottom: 2px solid var(--border-color); color: var(--text-secondary); font-weight: bold;">
                    <th style="padding: 1rem 0.8rem; text-align: center; width: 80px;">Hạng</th>
                    <th style="padding: 1rem 0.8rem;">Tác giả</th>
                    <th style="padding: 1rem 0.8rem; text-align: center;">Truyện hot nhất</th>
                    <th style="padding: 1rem 0.8rem; text-align: right;">Tổng lượt xem</th>
                </tr>
            </thead>
            <tbody>
                <% if (typeof topAuthors === 'undefined' || topAuthors.length === 0) { %>
                    <tr>
                        <td colspan="4" style="padding: 2rem; text-align: center; color: var(--text-secondary);">Chưa có dữ liệu tác giả nào.</td>
                    </tr>
                <% } else { %>
                    <% topAuthors.forEach((author, index) => { %>
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.03); transition: background-color 0.2s;" class="leaderboard-row">
                            <td style="padding: 1rem 0.8rem; text-align: center;">
                                <% if (index === 0) { %>
                                    <span style="font-size: 1.4rem;" title="Quán quân">🥇</span>
                                <% } else if (index === 1) { %>
                                    <span style="font-size: 1.4rem;" title="Á quân">🥈</span>
                                <% } else if (index === 2) { %>
                                    <span style="font-size: 1.4rem;" title="Hạng ba">🥉</span>
                                <% } else { %>
                                    <span style="font-weight: bold; color: var(--text-secondary);"><%= index + 1 %></span>
                                <% } %>
                            </td>
                            <td style="padding: 1rem 0.8rem; font-weight: 600; color: var(--text-primary);">
                                <a href="/author/<%= encodeURIComponent(author.author || '') %>" style="color: var(--text-primary); text-decoration: none; hover: underline;"><%= author.author %></a>
                            </td>
                            <td style="padding: 1rem 0.8rem; text-align: center; color: var(--text-secondary); font-size: 0.88rem;">
                                <strong><%= author.hottestStoryName %></strong>
                                <span style="font-size: 0.75rem; color: var(--accent-color); margin-left: 0.3rem;">(<%= author.hottestStoryViews %> view)</span>
                            </td>
                            <td style="padding: 1rem 0.8rem; text-align: right; font-weight: bold; color: var(--accent-color);">
                                <%= author.totalViews.toLocaleString('vi-VN') %>
                            </td>
                        </tr>
                    <% }) %>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<style>
    .leaderboard-row:hover {
        background-color: rgba(255, 255, 255, 0.02);
    }
    
    @media (max-width: 768px) {
        /* Keep it as a table but hide less important columns */
        .leaderboard-table th:nth-child(3),
        .leaderboard-table td:nth-child(3), /* Huy hiệu */
        .leaderboard-table th:nth-child(5),
        .leaderboard-table td:nth-child(5), /* Cấp độ */
        .leaderboard-table th:nth-child(6),
        .leaderboard-table td:nth-child(6) { /* EXP */
            display: none !important;
        }
        
        .leaderboard-table th, .leaderboard-table td {
            padding: 0.8rem 0.4rem !important;
            font-size: 0.85rem !important;
        }
        
        .leaderboard-table td[data-label="Độc giả"] {
            display: flex;
            align-items: center;
            gap: 0.5rem !important;
        }
        
        .leaderboard-row {
            cursor: pointer;
            position: relative;
        }
        .leaderboard-row::after {
            content: "❯";
            position: absolute;
            right: 10px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-secondary);
            font-size: 0.8rem;
            opacity: 0.5;
        }
        .leaderboard-table td:last-child {
            padding-right: 25px !important; /* Make room for arrow */
        }
    }
</style>
<script>
    function switchTab(tabName) {
        document.querySelectorAll('.tab-content').forEach(el => el.style.display = 'none');
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.style.color = 'var(--text-secondary)';
            btn.style.borderBottomColor = 'transparent';
        });

        document.getElementById('tab-' + tabName).style.display = 'block';
        const activeBtn = event.currentTarget || document.querySelector(`.tab-btn[onclick*="${tabName}"]`);
        activeBtn.style.color = 'var(--text-primary)';
        activeBtn.style.borderBottomColor = 'var(--accent-color)';
    }

    // Chuyển sub-tab lọc (Hôm nay/Tuần này/Tháng này/Đánh giá cao/Theo dõi nhiều) bên trong
    // tab "Truyện Tranh Top" / "Truyện Chữ Top" - dữ liệu đã được render sẵn ở server (tất cả
    // 5 khoảng thời gian cùng lúc), JS chỉ ẩn/hiện đúng khối tương ứng, không cần gọi thêm API.
    function switchLbSubTab(btn) {
        const scope = btn.dataset.scope;
        const period = btn.dataset.period;

        document.querySelectorAll(`.sub-tab-btn[data-scope="${scope}"]`).forEach(b => {
            b.classList.remove('active');
            b.style.background = 'transparent';
            b.style.color = 'var(--text-secondary)';
        });
        btn.classList.add('active');
        btn.style.background = 'var(--accent-color)';
        btn.style.color = 'white';

        document.querySelectorAll(`.lb-sub-content[data-scope="${scope}"]`).forEach(el => {
            el.style.display = (el.dataset.period === period) ? 'block' : 'none';
        });
    }

    document.addEventListener('DOMContentLoaded', () => {
        if (window.innerWidth <= 768) {
            const rows = document.querySelectorAll('#tab-readers .leaderboard-row');
            rows.forEach(row => {
                row.addEventListener('click', () => {
                    const link = row.querySelector('a');
                    if (link && link.href) window.location.href = link.href;
                });
            });
        }
    });
</script>

