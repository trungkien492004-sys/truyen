<%- include('partials/header') %>

<div class="read-container" style="max-width: 800px; margin: 0 auto; padding: 2rem 1rem;">
    <div style="margin-bottom: 1.5rem;">
        <a href="/" style="color: var(--text-secondary); font-size: 0.9rem;">&larr; Quay lại trang chủ</a>
    </div>

    <div style="background: linear-gradient(135deg, rgba(30, 41, 59, 0.7) 0%, rgba(15, 23, 42, 0.9) 100%); border: 1px solid var(--border-color); border-radius: 16px; padding: 2rem; margin-bottom: 2rem; box-shadow: 0 10px 30px rgba(0,0,0,0.3); backdrop-filter: blur(10px); text-align: center;">
        <h2 style="margin: 0 0 0.5rem 0; font-size: 2rem; background: linear-gradient(90deg, #3b82f6 0%, #8b5cf6 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; font-weight: bold;">🏆 Bảng Xếp Hạng</h2>
        <p style="color: var(--text-secondary); font-size: 0.95rem; margin: 0;">Vinh danh những cá nhân xuất sắc nhất của thư viện!</p>
    </div>

    <!-- TABS -->
    <div style="display: flex; gap: 1rem; margin-bottom: 1.5rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem;">
        <button class="tab-btn active" onclick="switchTab('readers')" style="background: none; border: none; color: var(--text-primary); font-size: 1.1rem; font-weight: bold; cursor: pointer; padding: 0.5rem 1rem; border-bottom: 3px solid var(--accent-color); transition: all 0.2s;">Độc Giả</button>
        <button class="tab-btn" onclick="switchTab('authors')" style="background: none; border: none; color: var(--text-secondary); font-size: 1.1rem; font-weight: bold; cursor: pointer; padding: 0.5rem 1rem; border-bottom: 3px solid transparent; transition: all 0.2s;">Tác Giả</button>
    </div>

    <!-- TAB ĐỘC GIẢ -->
    <div id="tab-readers" class="tab-content" style="display: block;">
        <div style="background: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: 16px; padding: 1.5rem; box-shadow: 0 4px 20px rgba(0,0,0,0.15); overflow-x: auto;">
            <table class="leaderboard-table" style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.95rem;">
            <thead>
                <tr style="border-bottom: 2px solid var(--border-color); color: var(--text-secondary); font-weight: bold;">
                    <th style="padding: 1rem 0.8rem; text-align: center; width: 80px;">Hạng</th>
                    <th style="padding: 1rem 0.8rem;">Độc giả</th>
                    <th style="padding: 1rem 0.8rem;">Huy hiệu</th>
                    <th style="padding: 1rem 0.8rem; text-align: right; width: 120px;">Số chương</th>
                    <th style="padding: 1rem 0.8rem; text-align: center;">Cấp độ</th>
                    <th style="padding: 1rem 0.8rem; text-align: right; width: 100px;">EXP</th>
                </tr>
            </thead>
            <tbody>
                <% if (leaderboard.length === 0) { %>
                    <tr>
                        <td colspan="6" style="padding: 2rem; text-align: center; color: var(--text-secondary);">Chưa có dữ liệu độc giả nào. Hãy bắt đầu đọc chương để ghi danh!</td>
                    </tr>
                <% } else { %>
                    <% leaderboard.forEach((reader, index) => { %>
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.03); transition: background-color 0.2s;" class="leaderboard-row">
                            <td data-label="Hạng" style="padding: 1rem 0.8rem; text-align: center;">
                                <% if (index === 0) { %>
                                    <span style="font-size: 1.4rem;" title="Quán quân">🥇</span>
                                <% } else if (index === 1) { %>
                                    <span style="font-size: 1.4rem;" title="Á quân">🥈</span>
                                <% } else if (index === 2) { %>
                                    <span style="font-size: 1.4rem;" title="Hạng ba">🥉</span>
                                <% } else { %>
                                    <span style="font-weight: bold; color: var(--text-secondary);"><%= index + 1 %></span>
                                <% } %>
                            </td>
                            <td data-label="Độc giả" style="padding: 0.8rem 0.8rem; display: flex; align-items: center; gap: 0.8rem;">
                                <div style="position: relative; display: flex; flex-direction: column; align-items: center; gap: 0.3rem;">
                                    <a href="/user/<%= reader.id %>" style="text-decoration: none; display: inline-block;">
                                        <% const readerFrame = reader.equipped_frame || 'default-frame' %>
                                        <div class="avatar-frame <%= readerFrame %>" style="width: 44px; height: 44px; padding: 2px;">
                                            <div class="avatar-glow"></div>
                                            <img src="<%= reader.avatar || '/css/silly_duck.png' %>" class="avatar-img" alt="avatar" style="border-width: 1px;">
                                            <% if (reader.equipped_badge) { %>
                                                <div class="avatar-corner" style="position: absolute; top: -4px; right: -4px; font-size: 0.8rem; background: rgba(0,0,0,0.6); border-radius: 50%; padding: 2px; z-index: 10; border: 1px solid gold; display: flex; justify-content: center; align-items: center; width: 18px; height: 18px;">
                                                    <%= getBadgeIcon(reader.equipped_badge) %>
                                                </div>
                                            <% } %>
                                        </div>
                                    </a>
                                    <% if (reader.equipped_badge) { %>
                                        <div style="display: flex; flex-direction: column; align-items: center; margin-top: -6px; z-index: 2; line-height: 1.1;">
                                            <span class="game-title <%= getTitleRarityClass(reader.equipped_badge) %>" style="font-size: 0.5rem; padding: 2px 12px; transform: scale(0.65); white-space: nowrap;"><%= reader.equipped_badge %></span>
                                            <span style="font-size: 0.45rem; letter-spacing: 1px; text-shadow: 0 0 2px rgba(255,255,255,0.3); transform: scale(0.65); margin-top: -6px;"><%= getStarsByChapters(reader.chapters_read) %></span>
                                        </div>
                                    <% } %>
                                </div>
                                <span style="font-weight: 600;">
                                    <a href="/user/<%= reader.id %>" style="text-decoration: none; color: inherit; transition: color 0.2s;" onmouseover="this.style.color='var(--accent-color)'" onmouseout="this.style.color='inherit'">
                                        <%= reader.display_name %>
                                    </a>
                                </span>
                            </td>
                            <td data-label="Huy hiệu" style="padding: 0.8rem 0.8rem;">
                                <div style="display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap;">
                                    <!-- Rank (Tu vi / Cảnh giới) -->
                                    <span style="font-size: 0.8rem; background: rgba(99, 102, 241, 0.1); color: var(--accent-color); padding: 0.25rem 0.6rem; border-radius: 12px; font-weight: 500; border: 1px solid rgba(99, 102, 241, 0.2); white-space: nowrap;">
                                        <%= reader.equipped_badge ? reader.equipped_badge : 'Người mới' %>
                                    </span>
                                </div>
                            </td>
                            <td data-label="Số chương" style="padding: 1rem 0.8rem; text-align: right; font-weight: 500;">
                                <%= reader.chapters_read || 0 %>
                            </td>
                            <td data-label="Cấp độ" style="padding: 1rem 0.8rem; text-align: center; font-weight: bold; color: #10b981;">
                                Lvl <%= Math.floor((reader.exp || 0) / 100) + 1 %>
                            </td>
                            <td data-label="EXP" style="padding: 1rem 0.8rem; text-align: right; font-weight: bold; color: var(--accent-color);">
                                <%= reader.exp || 0 %>
                            </td>
                        </tr>
                    <% }) %>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<!-- TAB TÁC GIẢ -->
<div id="tab-authors" class="tab-content" style="display: none;">
    <div style="background: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: 16px; padding: 1.5rem; box-shadow: 0 4px 20px rgba(0,0,0,0.15); overflow-x: auto;">
        <table class="leaderboard-table" style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.95rem;">
            <thead>
                <tr style="border-bottom: 2px solid var(--border-color); color: var(--text-secondary); font-weight: bold;">
                    <th style="padding: 1rem 0.8rem; text-align: center; width: 80px;">Hạng</th>
                    <th style="padding: 1rem 0.8rem;">Tác giả</th>
                    <th style="padding: 1rem 0.8rem; text-align: right;">Số lượng truyện</th>
                </tr>
            </thead>
            <tbody>
                <% if (typeof topAuthors === 'undefined' || topAuthors.length === 0) { %>
                    <tr>
                        <td colspan="3" style="padding: 2rem; text-align: center; color: var(--text-secondary);">Chưa có dữ liệu tác giả nào.</td>
                    </tr>
                <% } else { %>
                    <% topAuthors.forEach((author, index) => { %>
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.03); transition: background-color 0.2s;" class="leaderboard-row">
                            <td style="padding: 1rem 0.8rem; text-align: center;">
                                <% if (index === 0) { %>
                                    <span style="font-size: 1.4rem;" title="Quán quân">🥇</span>
                                <% } else if (index === 1) { %>
                                    <span style="font-size: 1.4rem;" title="Á quân">🥈</span>
                                <% } else if (index === 2) { %>
                                    <span style="font-size: 1.4rem;" title="Hạng ba">🥉</span>
                                <% } else { %>
                                    <span style="font-weight: bold; color: var(--text-secondary);"><%= index + 1 %></span>
                                <% } %>
                            </td>
                            <td style="padding: 1rem 0.8rem; font-weight: 600; color: var(--text-primary);">
                                <%= author.author %>
                            </td>
                            <td style="padding: 1rem 0.8rem; text-align: right; font-weight: bold; color: var(--accent-color);">
                                <%= author.story_count %>
                            </td>
                        </tr>
                    <% }) %>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<style>
    .leaderboard-row:hover {
        background-color: rgba(255, 255, 255, 0.02);
    }
    
    @media (max-width: 768px) {
        /* Keep it as a table but hide less important columns */
        .leaderboard-table th:nth-child(3),
        .leaderboard-table td:nth-child(3), /* Huy hiệu */
        .leaderboard-table th:nth-child(5),
        .leaderboard-table td:nth-child(5), /* Cấp độ */
        .leaderboard-table th:nth-child(6),
        .leaderboard-table td:nth-child(6) { /* EXP */
            display: none !important;
        }
        
        .leaderboard-table th, .leaderboard-table td {
            padding: 0.8rem 0.4rem !important;
            font-size: 0.85rem !important;
        }
        
        .leaderboard-table td[data-label="Độc giả"] {
            display: flex;
            align-items: center;
            gap: 0.5rem !important;
        }
        
        .leaderboard-row {
            cursor: pointer;
            position: relative;
        }
        .leaderboard-row::after {
            content: "❯";
            position: absolute;
            right: 10px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-secondary);
            font-size: 0.8rem;
            opacity: 0.5;
        }
        .leaderboard-table td:last-child {
            padding-right: 25px !important; /* Make room for arrow */
        }
    }
</style>
<script>
    function switchTab(tabName) {
        document.querySelectorAll('.tab-content').forEach(el => el.style.display = 'none');
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.style.color = 'var(--text-secondary)';
            btn.style.borderBottomColor = 'transparent';
        });

        document.getElementById('tab-' + tabName).style.display = 'block';
        const activeBtn = event.currentTarget || document.querySelector(`.tab-btn[onclick*="${tabName}"]`);
        activeBtn.style.color = 'var(--text-primary)';
        activeBtn.style.borderBottomColor = 'var(--accent-color)';
    }

    document.addEventListener('DOMContentLoaded', () => {
        if (window.innerWidth <= 768) {
            const rows = document.querySelectorAll('#tab-readers .leaderboard-row');
            rows.forEach(row => {
                row.addEventListener('click', () => {
                    const link = row.querySelector('a');
                    if (link && link.href) window.location.href = link.href;
                });
            });
        }
    });
</script>

<%- include('partials/footer') %>
