<style>
    .type-tab-btn {
        padding: 0.5rem 1.1rem;
        border-radius: 20px;
        border: 1px solid var(--border-color);
        background: var(--bg-secondary);
        color: var(--text-secondary);
        font-size: 0.88rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    .type-tab-btn:hover {
        border-color: var(--accent-color);
        color: var(--text-primary);
    }
    .type-tab-btn.active {
        background: var(--accent-color);
        color: white;
        border-color: var(--accent-color);
    }
</style>
<script>
    function filterBxhType(type, evt) {
        // Cập nhật trạng thái active cho nút bấm
        document.querySelectorAll('.bxh-type-btn').forEach(btn => {
            btn.classList.remove('active');
            btn.style.background = 'transparent';
            btn.style.color = 'var(--text-secondary)';
        });

        const activeBtn = (evt && evt.currentTarget) || (window.event && window.event.currentTarget) || document.querySelector(`.bxh-type-btn[onclick*="${type}"]`);
        if (activeBtn) {
            activeBtn.classList.add('active');
            activeBtn.style.background = 'var(--accent-color)';
            activeBtn.style.color = 'white';
        }

        // Ẩn/Hiện các subset tương ứng trong mỗi list bxh
        document.querySelectorAll('.bxh-subset').forEach(sub => {
            if (sub.dataset.type === type) {
                sub.style.display = 'flex';
            } else {
                sub.style.display = 'none';
            }
        });
    }
</script>

