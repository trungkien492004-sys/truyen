                                    <div class="rank-number"><%= index + 1 %></div>
                                    <img src="<%= item.cover_url %>" alt="<%= item.title %>" class="ranking-cover">
                                    <div class="ranking-info">
                                        <div class="ranking-title"><%= item.title %></div>
                                        <div class="ranking-views" style="<%= period.metricKey === 'avg_score' ? 'color:#fbbf24;' : '' %>">
                                            <%= period.metricLabel %>
                                            <%= period.metricKey === 'avg_score' ? parseFloat(item[period.metricKey] || 5).toFixed(1) : item[period.metricKey] %>
                                            <%= period.metricSuffix %>
                                        </div>
                                    </div>
                                </a>
                            <% }) %>
                        <% } %>
                    </div>
                <% }) %>

                <a href="/leaderboard" style="display:block;text-align:center;margin-top:0.8rem;font-size:0.8rem;color:var(--accent-color);opacity:0.8;text-decoration:none;transition:opacity 0.2s;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.8'">Xem BXH Ä‘áº§y Ä‘á»§ â†’</a>
            </div>

            <!-- === BXH Äá»˜C GIáº¢ + TÃC GIáº¢ (cÃ¹ng hÃ ng, compact) === -->
            <% if ((typeof topReaders !== 'undefined' && topReaders.length > 0) || (typeof topAuthors !== 'undefined' && topAuthors.length > 0)) { %>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem;">

                <!-- BXH Äá»™c Giáº£ (compact) -->
                <% if (typeof topReaders !== 'undefined' && topReaders.length > 0) { %>
                <div class="rankings-container" style="position: relative !important; top: auto !important; padding: 0.8rem;">
                    <h4 style="font-size: 0.85rem; font-weight: 700; margin: 0 0 0.6rem; color: var(--text-primary); display:flex; align-items:center; gap:0.3rem;">ðŸ¥‡ Äá»™c Giáº£ <a href="/leaderboard#readers" style="font-size:0.65rem; color:var(--accent-color); margin-left:auto; text-decoration:none; font-weight:400;">Xem thÃªm</a></h4>
                    <% topReaders.slice(0, 5).forEach((reader, index) => { %>
                        <a href="/user/<%= reader.id %>" style="display:flex; align-items:center; gap:0.4rem; padding:0.3rem 0; border-bottom:1px solid rgba(255,255,255,0.04); text-decoration:none; color:inherit; transition:opacity 0.15s;" onmouseover="this.style.opacity='0.75'" onmouseout="this.style.opacity='1'">
                            <span style="font-size:0.75rem; font-weight:700; color:var(--accent-color); width:14px; text-align:center; flex-shrink:0;"><%= index + 1 %></span>
                            <img src="<%= reader.avatar || '/css/silly_duck.png' %>" alt="" style="width:22px; height:22px; border-radius:50%; object-fit:cover; flex-shrink:0; border:1px solid rgba(255,255,255,0.15);">
                            <div style="flex:1; min-width:0;">
                                <div style="font-size:0.75rem; font-weight:600; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"><%= reader.display_name %></div>
                                <div style="font-size:0.65rem; color:var(--text-secondary);">â­ <%= reader.exp %> EXP</div>
                            </div>
                        </a>
                    <% }) %>
                </div>
                <% } %>

                <!-- Top TÃ¡c Giáº£ (compact) -->
                <% if (typeof topAuthors !== 'undefined' && topAuthors.length > 0) { %>
                <div class="rankings-container" style="position: relative !important; top: auto !important; padding: 0.8rem;">
                    <h4 style="font-size: 0.85rem; font-weight: 700; margin: 0 0 0.6rem; color: var(--text-primary); display:flex; align-items:center; gap:0.3rem;">âœï¸ TÃ¡c Giáº£</h4>
                    <% topAuthors.slice(0, 5).forEach((author, index) => { %>
                        <a href="/author/<%= encodeURIComponent(author.author || '') %>" style="display:flex; align-items:center; gap:0.4rem; padding:0.3rem 0; border-bottom:1px solid rgba(255,255,255,0.04); text-decoration:none; color:inherit; transition:opacity 0.15s;" onmouseover="this.style.opacity='0.75'" onmouseout="this.style.opacity='1'">
                            <span style="font-size:0.75rem; font-weight:700; color:var(--accent-color); width:14px; text-align:center; flex-shrink:0;"><%= index + 1 %></span>
                            <div style="flex:1; min-width:0;">
                                <div style="font-size:0.75rem; font-weight:600; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"><%= author.author %></div>
                                <div style="font-size:0.65rem; color:var(--text-secondary);">ðŸ“š <%= author.story_count %> truyá»‡n</div>
                            </div>
                        </a>
                    <% }) %>
                </div>
                <% } %>
            </div>
            <% } %>

            <!-- BÃŒNH LUáº¬N Má»šI NHáº¤T -->
            <% if (typeof recentComments !== 'undefined' && recentComments.length > 0) { %>
                <div class="rankings-container" style="position: relative !important; top: auto !important;">
                    <h3 class="section-title" style="font-size: 1.1rem; margin-bottom: 0.8rem;">ðŸ’¬ BÃ¬nh Luáº­n Má»›i</h3>
                    <% recentComments.forEach(comment => { %>
                        <a href="/story/<%= comment.story_id %><%= comment.chapter_id ? '/chapter/' + comment.chapter_id : '' %>" class="ranking-item" style="text-decoration: none; color: inherit; display: flex; align-items: flex-start; transition: transform 0.2s; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 0.8rem; margin-bottom: 0.8rem;">
                            <div style="display: flex; flex-direction: column; align-items: center; margin-right: 0.8rem; flex-shrink: 0; width: 45px;">
                                <% const cFrameClass = (comment.users && comment.users.equipped_frame) ? comment.users.equipped_frame : 'default-frame'; %>
                                <div class="avatar-frame <%= cFrameClass %>" style="width: 36px; height: 36px; padding: 2px;">
                                    <div class="avatar-glow"></div>
                                    <img src="<%= (comment.users && comment.users.avatar) ? comment.users.avatar : '/css/silly_duck.png' %>" alt="avatar" class="avatar-img" style="border-width: 1px;">
