<%- include('partials/header') %>

<!-- Phần quảng cáo / Giới thiệu và tìm kiếm -->
<div class="hero-section">
    <h1 class="hero-title">Tìm Kiếm Câu Chuyện Của Bạn</h1>
    <p class="hero-desc">Thế giới tiên hiệp, kiếm hiệp, truyện tranh và tiểu thuyết đặc sắc đang chờ đón bạn.</p>
    
    <!-- BANNER SLIDER CAROUSEL -->
    <% if (typeof banners !== 'undefined' && banners && banners.length > 0) { %>
        <style>
            .banner-carousel-container {
                position: relative;
                max-width: 1000px;
                margin: 2rem auto;
                border-radius: 20px;
                overflow: hidden;
                border: 1px solid rgba(255, 255, 255, 0.08);
                box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4);
                background: #0f172a;
            }
            .banner-slides {
                display: flex;
                transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
                width: 100%;
            }
            .banner-slide {
                min-width: 100%;
                box-sizing: border-box;
                position: relative;
                display: flex;
                align-items: center;
                justify-content: center;
                background: #090d16;
                min-height: 400px;
                overflow: hidden;
            }
            
            /* Background Glow Blur */
            .banner-bg-blur {
                position: absolute;
                top: -10%;
                left: -10%;
                width: 120%;
                height: 120%;
                background-size: cover;
                background-position: center;
                filter: blur(40px) brightness(0.25) saturate(1.2);
                opacity: 0.65;
                z-index: 1;
                pointer-events: none;
            }
            
            /* Split Container */
            .banner-split-container {
                position: relative;
                z-index: 3;
                display: flex;
                width: 100%;
                align-items: center;
                box-sizing: border-box;
                min-height: 400px;
                transition: all 0.3s ease;
            }
            
            .banner-info-panel {
                flex: 1.2;
                padding: 2.5rem 3rem 2.5rem 4.5rem;
                text-align: left;
                display: flex;
                flex-direction: column;
                justify-content: center;
                z-index: 3;
                box-sizing: border-box;
            }
            .banner-info-text-group {
                display: flex;
                flex-direction: column;
            }
            .banner-tag {
                display: inline-block;
                align-self: flex-start;
                padding: 0.35rem 0.9rem;
                background: linear-gradient(135deg, #3b82f6, #8b5cf6);
                color: white;
                border-radius: 20px;
                font-size: 0.72rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 1.5px;
                margin-bottom: 1.2rem;
                box-shadow: 0 4px 15px rgba(139, 92, 246, 0.4);
            }
            .banner-desc-content {
                color: #e2e8f0;
                font-size: 0.98rem;
                font-weight: 500;
                line-height: 1.6;
                white-space: pre-wrap;
                word-break: break-word;
                margin-bottom: 1.2rem;
                text-shadow: 0 2px 8px rgba(0, 0, 0, 0.75);
                max-height: 280px;
                overflow-y: auto;
                scrollbar-width: thin;
                scrollbar-color: rgba(99, 102, 241, 0.4) transparent;
            }
            .banner-cta-btn {
                align-self: flex-start;
                padding: 0.75rem 2rem;
                background: linear-gradient(135deg, #3b82f6, #1d4ed8);
                color: white;
                border-radius: 10px;
                font-size: 0.9rem;
                font-weight: 600;
                text-decoration: none;
                display: inline-flex;
                align-items: center;
                gap: 0.6rem;
                transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
                box-shadow: 0 4px 20px rgba(37, 99, 235, 0.4);
                border: 1px solid rgba(255, 255, 255, 0.1);
            }
            .banner-cta-btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 25px rgba(37, 99, 235, 0.6);
                filter: brightness(1.1);
            }
            
            /* Media panels */
            .banner-media-panel {
                flex: 0.8;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 2rem 3rem 2rem 0;
                z-index: 3;
                box-sizing: border-box;
            }
            .banner-media-card {
                position: relative;
                width: 100%;
                height: 320px;
                border-radius: 16px;
                overflow: hidden;
                border: 1px solid rgba(255, 255, 255, 0.15);
                box-shadow: 0 15px 40px rgba(0, 0, 0, 0.6);
                background: rgba(15, 23, 42, 0.6);
                backdrop-filter: blur(10px);
                -webkit-backdrop-filter: blur(10px);
                display: flex;
                align-items: center;
                justify-content: center;
                transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            }
            .banner-media-card:hover {
                transform: translateY(-5px) scale(1.02);
                border-color: rgba(59, 130, 246, 0.5);
                box-shadow: 0 20px 45px rgba(59, 130, 246, 0.35);
            }
            .banner-media-card img {
                max-width: 95%;
                max-height: 95%;
                object-fit: contain;
                border-radius: 8px;
                transition: transform 0.5s ease;
            }
            .banner-media-card:hover img {
                transform: scale(1.03);
            }
            
            /* Full Image View (No Description) */
            .banner-full-container {
                position: relative;
                z-index: 3;
                width: 100%;
                height: 400px;
                box-sizing: border-box;
            }
            .banner-full-container img, .banner-full-container video {
                width: 100%;
                height: 100%;
                object-fit: contain;
                display: block;
                background-color: #090d16;
            }
            
            /* Navigation elements */
            .banner-arrow {
                position: absolute;
                top: 50%;
                transform: translateY(-50%);
                background: rgba(15, 23, 42, 0.7);
                border: 1px solid rgba(255, 255, 255, 0.1);
                color: rgba(255, 255, 255, 0.8);
                width: 44px;
                height: 44px;
                border-radius: 50%;
                cursor: pointer;
                font-size: 1.2rem;
                z-index: 10;
                display: flex;
                align-items: center;
                justify-content: center;
                transition: all 0.3s ease;
                backdrop-filter: blur(8px);
                -webkit-backdrop-filter: blur(8px);
            }
            .banner-arrow:hover {
                background: linear-gradient(135deg, #3b82f6, #8b5cf6);
                color: white;
                border-color: transparent;
                box-shadow: 0 4px 15px rgba(139, 92, 246, 0.4);
            }
            .arrow-left { left: 15px; }
            .arrow-right { right: 15px; }
            
            .banner-dots-container {
                position: absolute;
                bottom: 20px;
                left: 50%;
                transform: translateX(-50%);
                display: flex;
                gap: 0.6rem;
                z-index: 10;
                background: rgba(15, 23, 42, 0.5);
                padding: 6px 12px;
                border-radius: 20px;
                backdrop-filter: blur(8px);
                -webkit-backdrop-filter: blur(8px);
                border: 1px solid rgba(255, 255, 255, 0.05);
            }
            .banner-dot {
                width: 8px;
                height: 8px;
                border-radius: 50%;
                background: rgba(255, 255, 255, 0.3);
                cursor: pointer;
                transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
            }
            .banner-dot.active {
                background: #3b82f6;
                width: 24px;
                border-radius: 4px;
            }

            /* LAYOUT MODIFIERS */
            
            /* 1. Landscape (Wide Horizontal Banner) on PC: Text BELOW the Image */
            .banner-slide.layout-landscape .banner-split-container {
                flex-direction: column-reverse;
                min-height: 400px;
            }
            .banner-slide.layout-landscape .banner-media-panel {
                flex: none;
                width: 100%;
                height: 250px;
                padding: 1rem 1rem 0 1rem;
            }
            .banner-slide.layout-landscape .banner-media-card {
                height: 100%;
                background: transparent;
                border: none;
                box-shadow: none;
                backdrop-filter: none;
                -webkit-backdrop-filter: none;
            }
            .banner-slide.layout-landscape .banner-media-card img,
            .banner-slide.layout-landscape .banner-media-card video {
                max-height: 100%;
                object-fit: contain;
            }
            .banner-slide.layout-landscape .banner-info-panel {
                flex: none;
                width: 100%;
                height: auto !important;
                min-height: 120px;
                padding: 1rem 3rem 2.5rem 4.5rem;
                flex-direction: row;
                align-items: center;
                justify-content: space-between;
                background: rgba(15, 23, 42, 0.85);
                backdrop-filter: blur(8px);
                -webkit-backdrop-filter: blur(8px);
                border-top: 1px solid rgba(255, 255, 255, 0.05);
            }
            .banner-slide.layout-landscape .banner-info-text-group {
                max-width: 70%;
                gap: 0.3rem;
            }
            .banner-slide.layout-landscape .banner-tag {
                margin-bottom: 0.3rem;
            }
            .banner-slide.layout-landscape .banner-desc-content {
                margin-bottom: 0;
                max-height: none !important;
                font-size: 1rem;
            }
            .banner-slide.layout-landscape .banner-cta-btn {
                align-self: center;
                margin-top: 0;
            }

            /* 2. Portrait (Vertical/Square Banner) on PC: Text on the LEFT, Image Card on the RIGHT */
            .banner-slide.layout-portrait .banner-media-panel {
                display: flex !important;
                flex: 0.8;
            }
            .banner-slide.layout-portrait .banner-info-panel {
                flex: 1.2;
                flex-direction: column;
                justify-content: center;
                padding: 2.5rem 3rem 2.5rem 4.5rem;
            }
            .banner-slide.layout-portrait .banner-tag {
                margin-bottom: 1.2rem;
            }
            .banner-slide.layout-portrait .banner-desc-content {
                margin-bottom: 1.8rem;
            }
            
            /* 3. No Description */
            .banner-slide.no-desc .banner-bg-blur,
            .banner-slide.no-desc .banner-media-panel,
            .banner-slide.no-desc .banner-info-panel {
                display: none !important;
            }
            .banner-slide.no-desc .banner-full-container {
                display: block;
                width: 100%;
                height: 400px;
            }

            /* MOBILE RESPONSIVE STYLING */
            @media (max-width: 768px) {
                .banner-carousel-container {
                    margin: 1rem;
                    border-radius: 16px;
                }
                .banner-slide {
                    min-height: auto;
                }
                
                /* Both portrait and landscape stack image-on-top, text-below on mobile */
                .banner-split-container {
                    flex-direction: column-reverse !important;
                    min-height: auto !important;
                    padding: 0 !important;
                }
                
                .banner-media-panel {
                    width: 100% !important;
                    padding: 1rem 1rem 0.5rem 1rem !important;
                    height: 220px !important;
                    flex: none !important;
                    display: flex !important;
                }
                
                .banner-media-card {
                    height: 100% !important;
                    width: 100% !important;
                    border-radius: 12px !important;
                    background: rgba(15, 23, 42, 0.4) !important;
                    border: 1px solid rgba(255, 255, 255, 0.08) !important;
                    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.4) !important;
                }
                
                .banner-media-card img,
                .banner-media-card video {
                    max-height: 95% !important;
                    max-width: 95% !important;
                    object-fit: contain !important;
                }
                
                .banner-info-panel {
                    width: 100% !important;
                    height: auto !important;
                    padding: 1.5rem 1.5rem 3.5rem 1.5rem !important;
                    flex: none !important;
                    flex-direction: column !important;
                    text-align: center !important;
                    align-items: center !important;
                    background: rgba(15, 23, 42, 0.75) !important;
                    border-top: 1px solid rgba(255, 255, 255, 0.08) !important;
                    backdrop-filter: blur(12px) !important;
                    -webkit-backdrop-filter: blur(12px) !important;
                }
                
                .banner-info-text-group {
                    max-width: 100% !important;
                    align-items: center !important;
                    text-align: center !important;
                }
                
                .banner-tag {
                    align-self: center !important;
                    margin-bottom: 0.8rem !important;
                    padding: 0.3rem 0.8rem !important;
                    font-size: 0.68rem !important;
                }
                
                .banner-desc-content {
                    font-size: 0.88rem !important;
                    line-height: 1.4 !important;
                    margin-bottom: 1rem !important;
                    text-align: center !important;
                    max-height: none !important;
                    overflow-y: visible !important;
                }
                
                .banner-cta-btn {
                    align-self: center !important;
                    padding: 0.65rem 1.8rem !important;
                    font-size: 0.85rem !important;
                    margin-top: 0.2rem !important;
                }
                
                .banner-arrow {
                    display: none !important;
                }
                
                .banner-dots-container {
                    bottom: 10px;
                    top: auto !important;
                    padding: 4px 8px;
                }
                
                .banner-full-container {
                    height: 250px !important;
                }
            }

            /* Bảng "Đột Phá Cảnh Giới Hôm Nay" - nằm chung carousel banner admin, dùng chung cơ chế trượt */
            .rankup-board-slide {
                background: linear-gradient(135deg, #1a1530 0%, #0d0a1a 55%, #1a1530 100%);
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 1rem;
            }
            .rankup-board {
                width: 100%;
                max-width: 900px;
                border: 2px solid #d4af37;
                border-radius: 16px;
                box-shadow: 0 0 25px rgba(212,175,55,0.35), inset 0 0 30px rgba(212,175,55,0.05);
                padding: 0.9rem 1.2rem;
                max-height: 100%;
                overflow-y: auto;
            }
            .rankup-board-header {
                display: flex;
                justify-content: space-between;
                align-items: center;
                flex-wrap: wrap;
                gap: 0.4rem;
                margin-bottom: 0.6rem;
                padding-bottom: 0.5rem;
                border-bottom: 1px solid rgba(212,175,55,0.3);
            }
            .rankup-board-title {
                font-family: 'Outfit', sans-serif;
                font-weight: 800;
                font-size: 1rem;
                letter-spacing: 1px;
                color: #f5d576;
                text-shadow: 0 0 10px rgba(245,213,118,0.5);
                text-transform: uppercase;
            }
            .rankup-board-count {
                font-size: 0.8rem;
                color: #f59e0b;
                font-weight: 700;
                white-space: nowrap;
            }
            .rankup-board-rows {
                display: flex;
                flex-direction: column;
                gap: 0.4rem;
            }
            .rankup-row {
                display: flex;
                align-items: center;
                gap: 0.7rem;
                padding: 0.4rem 0.2rem;
                border-bottom: 1px solid rgba(255,255,255,0.04);
            }
            .rankup-row:last-child {
                border-bottom: none;
            }
            .rankup-row-medal {
                font-size: 1.1rem;
                width: 26px;
                text-align: center;
                flex-shrink: 0;
                color: #d4af37;
                font-weight: 700;
            }
            .rankup-row-avatar {
                width: 30px;
                height: 30px;
                border-radius: 50%;
                object-fit: cover;
                border: 2px solid #d4af37;
                flex-shrink: 0;
            }
            .rankup-row-name {
                font-weight: 700;
                color: #fff;
                font-size: 0.85rem;
                min-width: 90px;
                max-width: 140px;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }
            .rankup-row-realm {
                font-size: 0.8rem;
                flex: 1;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }
            .rankup-row-realm .from {
                color: #94a3b8;
            }
            .rankup-row-realm .to {
                background: linear-gradient(90deg, #f5d576, #d4af37);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                font-weight: 700;
            }
            .rankup-row-time {
                font-size: 0.72rem;
                color: #94a3b8;
                flex-shrink: 0;
                white-space: nowrap;
            }
            @media (max-width: 600px) {
                .rankup-row-realm { display: none; }
                .rankup-row-name { max-width: 100px; }
            }
        </style>
        <div class="banner-carousel-container">
            <div class="banner-slides">
                <% banners.forEach((banner, index) => { %>
                    <% if (banner.type === 'rankup_board') { %>
                        <div class="banner-slide no-desc rankup-board-slide" id="slide-<%= index %>">
                            <div class="rankup-board">
                                <div class="rankup-board-header">
                                    <div class="rankup-board-title">🏆 Đột Phá Cảnh Giới Hôm Nay</div>
                                    <div class="rankup-board-count">🔥 <%= rankUpEventsToday.length %> lần đột phá hôm nay</div>
                                </div>
                                <div class="rankup-board-rows">
                                    <% const medals = ['🥇', '🥈', '🥉']; %>
                                    <% rankUpEventsToday.forEach((ev, rowIdx) => { %>
                                        <div class="rankup-row">
                                            <span class="rankup-row-medal"><%= medals[rowIdx] || ('#' + (rowIdx + 1)) %></span>
                                            <img src="<%= (ev.users && ev.users.avatar) ? ev.users.avatar : '/css/silly_duck.png' %>" alt="avatar" class="rankup-row-avatar">
                                            <span class="rankup-row-name"><%= ev.users ? ev.users.display_name : 'Độc giả' %></span>
                                            <span class="rankup-row-realm">
                                                <span class="from"><%= ev.from_rank %></span> ➜ <span class="to">🏅 <%= ev.to_rank %></span>
                                            </span>
                                            <span class="rankup-row-time" data-timestamp="<%= ev.created_at %>">vừa xong</span>
                                        </div>
                                    <% }) %>
                                </div>
                            </div>
                        </div>
                    <% } else { %>
                    <div class="banner-slide" id="slide-<%= index %>">
                        <!-- Portrait Blur Background Glow -->
                        <div class="banner-bg-blur" style="background-image: url('<%= banner.media_url %>');"></div>

                        <% if (banner.description) { %>
                            <div class="banner-split-container">
                                <div class="banner-info-panel">
                                    <div class="banner-info-text-group">
                                        <div class="banner-tag">Nổi bật</div>
                                        <div class="banner-desc-content"><%= banner.description %></div>
                                    </div>
                                    <% if (banner.link_url) { %>
                                        <a href="<%= banner.link_url %>" class="banner-cta-btn">
                                            <span>Khám phá ngay</span>
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                                        </a>
                                    <% } %>
                                </div>
                                <div class="banner-media-panel">
                                    <div class="banner-media-card">
                                        <% if (banner.link_url) { %>
                                            <a href="<%= banner.link_url %>" style="display: flex; width: 100%; height: 100%; align-items: center; justify-content: center;">
                                        <% } %>
                                        <% if (banner.media_type === 'video') { %>
                                            <video data-src="<%= banner.media_url %>" loop muted playsinline style="width: 100%; height: 100%; object-fit: contain;"></video>
                                        <% } else { %>
                                            <img src="<%= banner.media_url %>" alt="Banner">
                                        <% } %>
                                        <% if (banner.link_url) { %>
                                            </a>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        <% } else { %>
                            <div class="banner-full-container">
                                <% if (banner.link_url) { %>
                                    <a href="<%= banner.link_url %>" style="display: block; width: 100%; height: 100%;">
                                <% } %>
                                <% if (banner.media_type === 'video') { %>
                                    <video data-src="<%= banner.media_url %>" loop muted playsinline style="width: 100%; height: 100%; object-fit: contain;"></video>
                                <% } else { %>
                                    <img src="<%= banner.media_url %>" alt="Banner">
                                <% } %>
                                <% if (banner.link_url) { %>
                                    </a>
                                <% } %>
                            </div>
                        <% } %>
                    </div>
                    <% } %>
                <% }) %>
            </div>

            <% if (banners.length > 1) { %>
                <button type="button" onclick="prevBanner()" class="banner-arrow arrow-left">&lt;</button>
                <button type="button" onclick="nextBanner()" class="banner-arrow arrow-right">&gt;</button>
                <div class="banner-dots-container">
                    <% banners.forEach((_, idx) => { %>
                        <span class="banner-dot <%= idx === 0 ? 'active' : '' %>" onclick="currentBanner(<%= idx %>)"></span>
                    <% }) %>
                </div>
            <% } %>
        </div>

        <script>
            let currentSlideIndex = 0;
            const totalSlides = <%= banners.length %>;
            const slideContainer = document.querySelector('.banner-slides');
            const dots = document.querySelectorAll('.banner-dot');
            let bannerTimer = null;

            function updateSlidePosition() {
                if (!slideContainer) return;
                slideContainer.style.transform = `translateX(-${currentSlideIndex * 100}%)`;
                dots.forEach((dot, idx) => {
                    if (idx === currentSlideIndex) {
                        dot.classList.add('active');
                    } else {
                        dot.classList.remove('active');
                    }
                });

                // Tải và chạy video động để tránh kích hoạt trợ lý video hệ thống (Video Assistant) trên điện thoại
                const slides = document.querySelectorAll('.banner-slide');
                slides.forEach((slide, idx) => {
                    const video = slide.querySelector('video');
                    if (video) {
                        if (idx === currentSlideIndex) {
                            const src = video.getAttribute('data-src');
                            if (src && !video.src) {
                                video.src = src;
                            }
                            video.play().catch(e => console.log('Autoplay blocked:', e));
                        } else {
                            video.pause();
                            video.src = '';
                            video.load();
                        }
                    }
                });
            }

            function nextBanner() {
                currentSlideIndex = (currentSlideIndex + 1) % totalSlides;
                updateSlidePosition();
                resetBannerInterval();
            }

            function prevBanner() {
                currentSlideIndex = (currentSlideIndex - 1 + totalSlides) % totalSlides;
                updateSlidePosition();
                resetBannerInterval();
            }

            function currentBanner(index) {
                currentSlideIndex = index;
                updateSlidePosition();
                resetBannerInterval();
            }

            function startBannerInterval() {
                if (totalSlides > 1) {
                    bannerTimer = setInterval(nextBanner, 10000); // 10s auto-slide
                }
            }

            function resetBannerInterval() {
                if (bannerTimer) {
                    clearInterval(bannerTimer);
                    startBannerInterval();
                }
            }

            // Touch Swipe Support for Mobile
            let touchStartX = 0;
            let touchEndX = 0;

            function handleSwipe() {
                const SWIPE_THRESHOLD = 50;
                if (touchEndX < touchStartX - SWIPE_THRESHOLD) {
                    nextBanner();
                }
                if (touchEndX > touchStartX + SWIPE_THRESHOLD) {
                    prevBanner();
                }
            }

            if (slideContainer) {
                slideContainer.addEventListener('touchstart', e => {
                    touchStartX = e.changedTouches[0].screenX;
                }, {passive: true});

                slideContainer.addEventListener('touchend', e => {
                    touchEndX = e.changedTouches[0].screenX;
                    handleSwipe();
                }, {passive: true});
            }

            document.addEventListener('DOMContentLoaded', () => {
                <% banners.forEach((banner, index) => { %>
                    <% if (banner.type !== 'rankup_board') { %>
                    (function() {
                        const imgUrl = '<%= banner.media_url %>';
                        const isVideo = '<%= banner.media_type %>' === 'video';
                        const slideId = 'slide-<%= index %>';
                        const slide = document.getElementById(slideId);
                        const hasDesc = <%= banner.description ? 'true' : 'false' %>;

                        if (!hasDesc) {
                            slide.classList.add('no-desc');
                            return;
                        }

                        if (isVideo) {
                            slide.classList.add('layout-portrait');
                            return;
                        }

                        const img = new Image();
                        img.src = imgUrl;
                        img.onload = function() {
                            const ratio = this.naturalWidth / this.naturalHeight;
                            if (ratio > 1.25) {
                                slide.classList.add('layout-landscape');
                            } else {
                                slide.classList.add('layout-portrait');
                            }
                        };
                        img.onerror = function() {
                            slide.classList.add('layout-portrait');
                        };
                    })();
                    <% } %>
                <% }) %>
                updateSlidePosition();
                startBannerInterval();

                // Tính "X phút trước" cho bảng Đột Phá Cảnh Giới ngay trên trình duyệt người dùng,
                // tránh lệch giờ server/cache và tự cập nhật mà không cần reload trang.
                function updateRankupTimes() {
                    document.querySelectorAll('.rankup-row-time').forEach(el => {
                        const ts = el.getAttribute('data-timestamp');
                        if (!ts) return;
                        const diffMs = Date.now() - new Date(ts).getTime();
                        const diffMin = Math.floor(diffMs / 60000);
                        if (diffMin < 1) {
                            el.textContent = 'vừa xong';
                        } else if (diffMin < 60) {
                            el.textContent = `${diffMin} phút trước`;
                        } else {
                            const diffHour = Math.floor(diffMin / 60);
                            el.textContent = `${diffHour} giờ trước`;
                        }
                    });
                }
                updateRankupTimes();
                setInterval(updateRankupTimes, 30000);
            });
        </script>
    <% } %>

    <form action="/search" method="GET" class="search-bar" style="position: relative;">
        <input type="text" id="search-input" name="q" placeholder="Nhập tên truyện hoặc tên tác giả..." value="<%= searchQuery || '' %>" autocomplete="off">
        <button type="submit" class="btn btn-primary">Tìm kiếm</button>
        <div id="search-suggestions" style="display: none; position: absolute; top: 100%; left: 0; right: 0; background: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: 8px; margin-top: 0.5rem; max-height: 350px; overflow-y: auto; z-index: 999; box-shadow: 0 10px 25px rgba(0,0,0,0.5); padding: 0.5rem 0;"></div>
    </form>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const searchInput = document.getElementById('search-input');
            const suggestionsBox = document.getElementById('search-suggestions');
            let debounceTimer;

            if (searchInput && suggestionsBox) {
                searchInput.addEventListener('input', () => {
                    clearTimeout(debounceTimer);
                    const query = searchInput.value.trim();
                    
                    if (query.length < 2) {
                        suggestionsBox.style.display = 'none';
                        suggestionsBox.innerHTML = '';
                        return;
                    }

                    debounceTimer = setTimeout(async () => {
                        try {
                            const response = await fetch(`/api/search-suggestions?q=${encodeURIComponent(query)}`);
                            const data = await response.json();
                            
                            if (data.success && data.results.length > 0) {
                                suggestionsBox.innerHTML = data.results.map(item => `
                                    <a href="/story/${item.id}" style="display: flex; align-items: center; gap: 0.8rem; padding: 0.6rem 1rem; text-decoration: none; color: var(--text-primary); transition: background 0.2s; border-bottom: 1px solid rgba(255,255,255,0.03);" onmouseover="this.style.background='rgba(255,255,255,0.05)'" onmouseout="this.style.background='transparent'">
                                        <img src="${item.cover_url || '/css/silly_duck.png'}" style="width: 35px; height: 48px; border-radius: 4px; object-fit: cover; flex-shrink: 0;">
                                        <div style="flex: 1; min-width: 0; text-align: left;">
                                            <div style="font-weight: 600; font-size: 0.9rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">${item.title}</div>
                                            <div style="font-size: 0.75rem; color: var(--text-secondary); margin-top: 0.15rem;">✍️ Tác giả: ${item.author || 'Chưa rõ'}</div>
                                        </div>
                                    </a>
                                `).join('');
                                suggestionsBox.style.display = 'block';
                            } else {
                                suggestionsBox.style.display = 'none';
                                suggestionsBox.innerHTML = '';
                            }
                        } catch (err) {
                            console.error('Lỗi gợi ý tìm kiếm:', err);
                        }
                    }, 300);
                });

                document.addEventListener('click', (e) => {
                    if (!searchInput.contains(e.target) && !suggestionsBox.contains(e.target)) {
                        suggestionsBox.style.display = 'none';
                    }
                });

                searchInput.addEventListener('focus', () => {
                    if (suggestionsBox.children.length > 0) {
                        suggestionsBox.style.display = 'block';
                    }
                });
            }
        });
    </script>

    <!-- BẠN ĐANG ĐỌC (LỊCH SỬ ĐỌC GẦN NHẤT) -->
    <% if (typeof lastRead !== 'undefined' && lastRead) { %>
        <div class="last-read-banner" style="margin: 1.5rem auto 0 auto; max-width: 600px; display: flex; align-items: center; justify-content: center; gap: 0.6rem; padding: 0.8rem 1.2rem; background: linear-gradient(135deg, rgba(59, 130, 246, 0.15) 0%, rgba(147, 51, 234, 0.15) 100%); border: 1px solid rgba(59, 130, 246, 0.4); border-radius: 12px; font-size: 0.92rem; box-shadow: 0 4px 20px rgba(59, 130, 246, 0.2); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);">
            <span style="position: relative; display: inline-flex; align-items: center; justify-content: center; width: 18px; height: 18px; margin-right: 2px;">
                <span style="position: absolute; display: inline-flex; width: 100%; height: 100%; background: #3b82f6; border-radius: 50%; opacity: 0.6; animation: ping 2s cubic-bezier(0, 0, 0.2, 1) infinite;"></span>
                <span style="font-size: 1.15rem; position: relative; line-height: 1;">📖</span>
            </span>
            <span style="color: var(--text-secondary); font-weight: 500;">Bạn đang đọc dở:</span>
            <a href="/story/<%= lastRead.story_id %>/chapter/<%= lastRead.chapter_number %>" style="color: #60a5fa; font-weight: 700; text-decoration: none; transition: all 0.2s; display: flex; align-items: center; gap: 0.3rem;" onmouseover="this.style.color='#93c5fd'; this.style.transform='translateX(2px)';" onmouseout="this.style.color='#60a5fa'; this.style.transform='translateX(0)';">
                <%= lastRead.story_title %> - Chương <%= lastRead.chapter_number %>
                <span style="font-size: 0.95rem; font-weight: bold; transition: transform 0.2s;">&rarr;</span>
            </a>
        </div>
    <% } %>

    <!-- BỘ LỌC NÂNG CAO: kết hợp trạng thái + số chương + sắp xếp (chọn thể loại dùng danh sách pill bên dưới) -->
    <form action="/search" method="GET" style="display: flex; flex-wrap: wrap; gap: 0.6rem; justify-content: center; margin-top: 1rem;">
        <input type="hidden" name="q" value="<%= searchQuery || '' %>">
        <input type="hidden" name="genre" value="<%= (typeof filters !== 'undefined' && filters.genre) ? filters.genre : (activeGenre ? activeGenre.slug : '') %>">

        <select name="status" onchange="this.form.submit()" style="padding: 0.5rem 0.8rem; border-radius: 8px; border: 1px solid var(--border-color); background: var(--bg-primary); color: var(--text-primary); font-size: 0.85rem;">
            <option value="">Mọi trạng thái</option>
            <option value="ongoing" <%= (typeof filters !== 'undefined' && filters.status === 'ongoing') ? 'selected' : '' %>>Đang tiến hành</option>
            <option value="completed" <%= (typeof filters !== 'undefined' && filters.status === 'completed') ? 'selected' : '' %>>Đã hoàn thành</option>
        </select>

        <select name="min_chapters" onchange="this.form.submit()" style="padding: 0.5rem 0.8rem; border-radius: 8px; border: 1px solid var(--border-color); background: var(--bg-primary); color: var(--text-primary); font-size: 0.85rem;">
            <option value="">Số chương bất kỳ</option>
            <option value="50" <%= (typeof filters !== 'undefined' && filters.minChapters === '50') ? 'selected' : '' %>>Từ 50 chương</option>
            <option value="100" <%= (typeof filters !== 'undefined' && filters.minChapters === '100') ? 'selected' : '' %>>Từ 100 chương</option>
            <option value="200" <%= (typeof filters !== 'undefined' && filters.minChapters === '200') ? 'selected' : '' %>>Từ 200 chương</option>
        </select>

        <select name="year" onchange="this.form.submit()" style="padding: 0.5rem 0.8rem; border-radius: 8px; border: 1px solid var(--border-color); background: var(--bg-primary); color: var(--text-primary); font-size: 0.85rem;">
            <option value="">Mọi năm</option>
            <% const currentYear = new Date().getFullYear(); %>
            <% for (let y = currentYear; y >= 2020; y--) { %>
                <option value="<%= y %>" <%= (typeof filters !== 'undefined' && filters.year == y) ? 'selected' : '' %>><%= y %></option>
            <% } %>
        </select>

        <select name="sort" onchange="this.form.submit()" style="padding: 0.5rem 0.8rem; border-radius: 8px; border: 1px solid var(--border-color); background: var(--bg-primary); color: var(--text-primary); font-size: 0.85rem;">
            <option value="newest" <%= (typeof filters === 'undefined' || filters.sort === 'newest') ? 'selected' : '' %>>Mới cập nhật</option>
            <option value="oldest" <%= (typeof filters !== 'undefined' && filters.sort === 'oldest') ? 'selected' : '' %>>Cũ nhất</option>
            <option value="most_chapters" <%= (typeof filters !== 'undefined' && filters.sort === 'most_chapters') ? 'selected' : '' %>>Nhiều chương nhất</option>
            <option value="title_az" <%= (typeof filters !== 'undefined' && filters.sort === 'title_az') ? 'selected' : '' %>>Tên A-Z</option>
        </select>

        <select name="view_sort" onchange="this.form.submit()" style="padding: 0.5rem 0.8rem; border-radius: 8px; border: 1px solid var(--border-color); background: var(--bg-primary); color: var(--text-primary); font-size: 0.85rem;">
            <option value="">Lượt xem: Mặc định</option>
            <option value="daily" <%= (typeof filters !== 'undefined' && filters.view_sort === 'daily') ? 'selected' : '' %>>Lượt xem: Hôm nay</option>
            <option value="monthly" <%= (typeof filters !== 'undefined' && filters.view_sort === 'monthly') ? 'selected' : '' %>>Lượt xem: Tháng này</option>
            <option value="all" <%= (typeof filters !== 'undefined' && filters.view_sort === 'all') ? 'selected' : '' %>>Lượt xem: Mọi thời điểm</option>
        </select>

        <a href="/random" class="btn btn-secondary" style="font-size: 0.85rem;">🎲 Hôm nay đọc gì?</a>
    </form>
</div>

<!-- Lọc theo thể loại -->
<div class="genre-list">
    <a href="/" class="genre-tag <%= !activeGenre ? 'active' : '' %>">Tất cả</a>
    <% genres.forEach(genre => { %>
        <a href="/genre/<%= genre.slug %>" class="genre-tag <%= (activeGenre && activeGenre.id === genre.id) ? 'active' : '' %>">
            <%= genre.name %>
        </a>
    <% }) %>
</div>

<div class="content-grid">
    <!-- Cột trái: Danh sách truyện -->
    <div>
        <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; margin-bottom: 1.5rem; border-bottom: 2px solid var(--border-color); padding-bottom: 0.5rem;">
            <h2 class="section-title" style="margin-bottom: 0; border-bottom: none; padding-bottom: 0;">
                <% if (searchQuery) { %>
                    🔍 Kết quả tìm kiếm cho "<%= searchQuery %>"
                <% } else if (activeGenre) { %>
                    📚 Thể loại: <%= activeGenre.name %>
                <% } else { %>
                    ✨ Truyện mới cập nhật
                <% } %>
            </h2>
            
            <% if (!searchQuery && !activeGenre) { %>
                <div style="display: flex; gap: 0.4rem;">
                    <a href="/" class="btn <%= (!filters || !filters.status) ? 'btn-primary' : 'btn-secondary' %>" style="font-size: 0.8rem; padding: 0.35rem 0.8rem; border-radius: 8px; font-weight: 500;">Tất cả</a>
                    <a href="/?status=ongoing" class="btn <%= (filters && filters.status === 'ongoing') ? 'btn-primary' : 'btn-secondary' %>" style="font-size: 0.8rem; padding: 0.35rem 0.8rem; border-radius: 8px; font-weight: 500;">🔄 Đang ra</a>
                    <a href="/?status=completed" class="btn <%= (filters && filters.status === 'completed') ? 'btn-primary' : 'btn-secondary' %>" style="font-size: 0.8rem; padding: 0.35rem 0.8rem; border-radius: 8px; font-weight: 500;">✅ Trọn bộ</a>
                </div>
            <% } %>
        </div>

        <!-- Tab lọc Truyện chữ / Truyện tranh - lọc THẬT ở tầng database (routes/index.js dùng
             cột story_type để .eq() ngay trong query), mỗi tab có phân trang riêng tách biệt
             hoàn toàn, không phải ẩn/hiện client-side (cách cũ bị lỗi rỗng khi 1 trang toàn
             1 loại truyện). -->
        <% const activeType = (typeof storyType !== 'undefined' && storyType === 'comic') ? 'comic' : 'novel'; %>
        <% if (!searchQuery && !activeGenre) { %>
        <div class="type-tabs" style="display: flex; gap: 0.5rem; margin-bottom: 1.2rem;">
            <a href="/?type=novel<%= (filters && filters.status) ? '&status=' + filters.status : '' %>" class="type-tab-btn <%= activeType === 'novel' ? 'active' : '' %>">📖 Truyện chữ</a>
            <a href="/?type=comic<%= (filters && filters.status) ? '&status=' + filters.status : '' %>" class="type-tab-btn <%= activeType === 'comic' ? 'active' : '' %>">🖼️ Truyện tranh</a>
        </div>
        <% } %>

        <% if (stories.length === 0) { %>
            <p style="color: var(--text-secondary); text-align: center; margin-top: 3rem;">Chưa có truyện nào được đăng tải trong danh mục này<% if (!searchQuery && !activeGenre) { %> ở mục <%= activeType === 'comic' ? 'Truyện tranh' : 'Truyện chữ' %><% } %>.</p>
        <% } else { %>
            <div class="stories-grid" id="stories-grid">
                <% stories.forEach(story => { %>
                    <div class="story-card">
                        <a href="/story/<%= story.id %>">
                            <img src="<%= story.cover_url %>" alt="<%= story.title %>" class="story-cover">
                        </a>
                        <div class="story-info">
                            <a href="/story/<%= story.id %>" class="story-title" title="<%= story.title %>">
                                <%= story.title %>
                            </a>
                            <span class="story-author">Tác giả: <a href="/author/<%= encodeURIComponent(story.author || '') %>" style="color: var(--accent-color); text-decoration: none;"><%= story.author %></a></span>
                            <div style="font-size: 0.78rem; color: var(--text-secondary); margin: 0.25rem 0;">
                                <% if (story.last_chapter_number) { %>
                                    <span style="color: var(--accent-color); font-weight: 600;">Mới: Chương <%= story.last_chapter_number %></span>
                                <% } else { %>
                                    <span>Chưa có chương</span>
                                <% } %>
                                <% if (story.status === 'completed') { %> · <span style="color: #22c55e;">✅ Hoàn thành</span><% } else { %> · <span style="color: #f59e0b;">🔄 Đang tiến hành</span><% } %>
                            </div>
                            <!-- Đánh giá truyện -->
                            <div style="font-size: 0.78rem; color: #f59e0b; font-weight: 600; margin-bottom: 0.25rem; display: flex; align-items: center; gap: 0.2rem;">
                                🌟 <span><%= story.avg_score || '0' %></span>
                                <span style="color: var(--text-secondary); font-weight: normal;">(<%= story.rating_count || 0 %> lượt đánh giá)</span>
                            </div>
                            <% if (story.last_update_at) { %>
                                <div style="font-size: 0.72rem; color: var(--text-secondary); margin-bottom: 0.5rem;">
                                    🕒 Cập nhật: <%= new Date(story.last_update_at).toLocaleDateString('vi-VN', { hour: '2-digit', minute: '2-digit', day: '2-digit', month: '2-digit' }) %>
                                </div>
                            <% } %>
                            <p class="story-desc-short"><%= story.description || 'Chưa có tóm tắt nội dung.' %></p>
                            
                            <% if (story.commissioned_by) { %>
                                <div style="font-size: 0.8rem; background: rgba(59, 130, 246, 0.1); border-left: 2px solid var(--accent-color); padding: 0.3rem 0.5rem; margin-bottom: 0.8rem; border-radius: 0 4px 4px 0;">
                                    👑 Người đặt truyện: <strong><%= story.commissioned_by %></strong>
                                </div>
                            <% } %>

                            <a href="/story/<%= story.id %>" class="btn btn-secondary btn-primary" style="margin-top: auto; font-size: 0.85rem; padding: 0.5rem;">Đọc ngay</a>
                        </div>
                    </div>
                <% }) %>
            </div>

            <!-- Phân trang trang chủ -->
            <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
                <div class="pagination" style="display: flex; justify-content: center; align-items: center; gap: 0.5rem; margin-top: 2rem;">
                    <%
                      let urlParams = '';
                      if (filters && filters.status) {
                          urlParams += `status=${filters.status}&`;
                      }
                      if (typeof storyType !== 'undefined' && storyType) {
                          urlParams += `type=${storyType}&`;
                      }
                    %>
                    <% if (currentPage > 1) { %>
                        <a href="/?<%= urlParams %>page=<%= currentPage - 1 %>" class="btn btn-secondary" style="padding: 0.4rem 0.8rem; font-size: 0.85rem; border-radius: 8px;">&larr; Trước</a>
                    <% } %>
                    
                    <% for (let i = 1; i <= totalPages; i++) { %>
                        <% if (i === currentPage) { %>
                            <span class="btn btn-primary" style="padding: 0.4rem 0.8rem; font-size: 0.85rem; border-radius: 8px; font-weight: bold; pointer-events: none;"><%= i %></span>
                        <% } else { %>
                            <a href="/?<%= urlParams %>page=<%= i %>" class="btn btn-secondary" style="padding: 0.4rem 0.8rem; font-size: 0.85rem; border-radius: 8px;"><%= i %></a>
                        <% } %>
                    <% } %>
                    
                    <% if (currentPage < totalPages) { %>
                        <a href="/?<%= urlParams %>page=<%= currentPage + 1 %>" class="btn btn-secondary" style="padding: 0.4rem 0.8rem; font-size: 0.85rem; border-radius: 8px;">Sau &rarr;</a>
                    <% } %>
                </div>
            <% } %>
        <% } %>
    </div>

    <!-- Cột phải: Bảng xếp hạng (Chỉ hiển thị ở trang chủ mặc định) -->
    <% if (!searchQuery && !activeGenre) { %>
        <div style="position: sticky; top: 100px; display: flex; flex-direction: column; gap: 1.5rem;">
            <div class="rankings-container" style="position: relative !important; top: auto !important;">
                
                <!-- TIÊU ĐỀ + CHUYỂN LOẠI THÔNG MINH -->
                <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.8rem; flex-wrap: wrap; gap: 0.5rem;">
                    <h3 class="section-title" style="font-size: 1.25rem; margin: 0; border: none; padding: 0;">🏆 Bảng Xếp Hạng</h3>
                    <div style="display: flex; gap: 0.2rem; background: rgba(0,0,0,0.3); padding: 0.2rem; border-radius: 8px; border: 1px solid var(--border-color);">
                        <button class="bxh-type-btn active" onclick="filterBxhType('all', event)" style="padding: 0.25rem 0.6rem; font-size: 0.72rem; font-weight: 700; border-radius: 5px; border: none; cursor: pointer; background: var(--accent-color); color: white; transition: all 0.2s;">✨ Tất cả</button>
                        <button class="bxh-type-btn" onclick="filterBxhType('comic', event)" style="padding: 0.25rem 0.6rem; font-size: 0.72rem; font-weight: 700; border-radius: 5px; border: none; cursor: pointer; background: transparent; color: var(--text-secondary); transition: all 0.2s;">🖼️ Tranh</button>
                        <button class="bxh-type-btn" onclick="filterBxhType('novel', event)" style="padding: 0.25rem 0.6rem; font-size: 0.72rem; font-weight: 700; border-radius: 5px; border: none; cursor: pointer; background: transparent; color: var(--text-secondary); transition: all 0.2s;">📄 Chữ</button>
