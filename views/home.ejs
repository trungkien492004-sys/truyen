                    <div class="bxh-subset" data-type="all" style="display: flex; flex-direction: column; gap: 1rem;">
                        <% if (topDaily.length === 0) { %><p style="font-size: 0.82rem; color: var(--text-secondary); text-align: center; padding: 0.8rem 0;">Chưa có dữ liệu.</p><% } else { %>
                            <% topDaily.slice(0, 5).forEach((item, index) => { %>
                                <a href="/story/<%= item.id %>" class="ranking-item"><div class="rank-number"><%= index + 1 %></div><img src="<%= item.cover_url %>" alt="" class="ranking-cover"><div class="ranking-info"><div class="ranking-title"><%= item.title %></div><div class="ranking-views">👁️ <%= item.view_count %></div></div></a>
                            <% }) %>
                        <% } %>
                    </div>
                    <!-- COMIC -->
                    <div class="bxh-subset" data-type="comic" style="display: none; flex-direction: column; gap: 1rem;">
                        <% if (topComicDaily.length === 0) { %><p style="font-size: 0.82rem; color: var(--text-secondary); text-align: center; padding: 0.8rem 0;">Chưa có dữ liệu truyện tranh.</p><% } else { %>
                            <% topComicDaily.slice(0, 5).forEach((item, index) => { %>
                                <a href="/story/<%= item.id %>" class="ranking-item"><div class="rank-number"><%= index + 1 %></div><img src="<%= item.cover_url %>" alt="" class="ranking-cover"><div class="ranking-info"><div class="ranking-title"><%= item.title %></div><div class="ranking-views">👁️ <%= item.view_count %></div></div></a>
                            <% }) %>
                        <% } %>
                    </div>
