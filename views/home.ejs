                                    <span style="font-weight: 600; font-size: 0.85rem; color: var(--accent-color);"><%= (comment.users && comment.users.display_name) ? comment.users.display_name : 'Äá»™c giáº£' %></span>
                                    <span style="font-size: 0.7rem; color: var(--text-secondary);"><%= new Date(comment.created_at).toLocaleDateString('vi-VN') %></span>
                                </div>
                                <div style="font-size: 0.85rem; color: var(--text-primary); line-height: 1.4; margin-bottom: 0.3rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis; word-break: break-word;">
                                    <%- comment.content.replace(/<[^>]*>?/gm, '').substring(0, 100) %>...
                                </div>
                                <div style="font-size: 0.75rem; color: var(--text-secondary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                    ðŸ“– <%= comment.stories ? comment.stories.title : 'Truyá»‡n' %>
                                </div>
                            </div>
                        </a>
                    <% }) %>
                </div>
            <% } %>

        </div>
    <% } %>

</div>

<script>
    // === BXH TYPE SWITCHER (Tranh / Chá»¯) ===
    let currentBxhType = 'comic';
    let currentBxhPeriod = 'daily';

    function switchBxhType(type) {
        currentBxhType = type;
        // Cáº­p nháº­t nÃºt
        document.querySelectorAll('.bxh-type-btn').forEach(btn => {
            const isActive = btn.id === 'bxh-type-' + type;
            btn.style.background = isActive ? 'var(--accent-color)' : 'transparent';
            btn.style.color = isActive ? 'white' : 'var(--text-secondary)';
        });
        // Hiá»‡n Ä‘Ãºng panel
        updateBxhPanel();
    }

    function updateBxhPanel() {
        // áº¨n táº¥t cáº£ panel
        document.querySelectorAll('.bxh-panel').forEach(p => {
            p.style.display = 'none';
            p.classList.remove('bxh-active');
        });
        // Hiá»‡n Ä‘Ãºng panel (type + period)
        const target = document.getElementById('bxh-' + currentBxhType + '-' + currentBxhPeriod);
        if (target) {
            target.style.display = 'block';
            target.classList.add('bxh-active');
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        // === Sub-tabs BXH ===
        const subtabs = document.querySelectorAll('#bxh-subtabs .ranking-tab');
        subtabs.forEach(tab => {
            tab.addEventListener('click', function() {
                subtabs.forEach(t => t.classList.remove('active'));
                this.classList.add('active');
                currentBxhPeriod = this.dataset.bxh;
                updateBxhPanel();
            });
        });

        // Khá»Ÿi táº¡o: áº©n táº¥t cáº£ panel trá»« comic-daily
        document.querySelectorAll('.bxh-panel').forEach(p => {
            if (!p.classList.contains('bxh-active')) {
                p.style.display = 'none';
            }
        });
    });
</script>

