        <script>
            let currentSlideIndex = 0;
            const totalSlides = <%= banners.length %>;
            const slideContainer = document.querySelector('.banner-slides');
            const dots = document.querySelectorAll('.banner-dot');
            let bannerTimer = null;

            function updateSlidePosition() {
                if (!slideContainer) return;
                slideContainer.style.transform = `translateX(-${currentSlideIndex * 100}%)`;
                dots.forEach((dot, idx) => {
                    if (idx === currentSlideIndex) {
                        dot.classList.add('active');
                    } else {
                        dot.classList.remove('active');
                    }
                });

                // Táº£i vÃ  cháº¡y video Ä‘á»™ng Ä‘á»ƒ trÃ¡nh kÃ­ch hoáº¡t trá»£ lÃ½ video há»‡ thá»‘ng (Video Assistant) trÃªn Ä‘iá»‡n thoáº¡i
                const slides = document.querySelectorAll('.banner-slide');
                slides.forEach((slide, idx) => {
                    const video = slide.querySelector('video');
                    if (video) {
                        if (idx === currentSlideIndex) {
                            const src = video.getAttribute('data-src');
                            if (src && !video.src) {
                                video.src = src;
                            }
                            video.play().catch(e => console.log('Autoplay blocked:', e));
                        } else {
                            video.pause();
                            video.src = '';
                            video.load();
                        }
                    }
                });
            }

            function nextBanner() {
                currentSlideIndex = (currentSlideIndex + 1) % totalSlides;
                updateSlidePosition();
                resetBannerInterval();
            }

            function prevBanner() {
                currentSlideIndex = (currentSlideIndex - 1 + totalSlides) % totalSlides;
                updateSlidePosition();
                resetBannerInterval();
            }

            function currentBanner(index) {
                currentSlideIndex = index;
                updateSlidePosition();
                resetBannerInterval();
            }

            function startBannerInterval() {
                if (totalSlides > 1) {
                    bannerTimer = setInterval(nextBanner, 10000); // 10s auto-slide
                }
            }

            function resetBannerInterval() {
                if (bannerTimer) {
                    clearInterval(bannerTimer);
                    startBannerInterval();
                }
            }

            // Touch Swipe Support for Mobile
            let touchStartX = 0;
            let touchEndX = 0;

            function handleSwipe() {
                const SWIPE_THRESHOLD = 50;
                if (touchEndX < touchStartX - SWIPE_THRESHOLD) {
                    nextBanner();
                }
                if (touchEndX > touchStartX + SWIPE_THRESHOLD) {
                    prevBanner();
                }
            }

            if (slideContainer) {
                slideContainer.addEventListener('touchstart', e => {
                    touchStartX = e.changedTouches[0].screenX;
                }, {passive: true});

                slideContainer.addEventListener('touchend', e => {
                    touchEndX = e.changedTouches[0].screenX;
                    handleSwipe();
                }, {passive: true});
            }

            document.addEventListener('DOMContentLoaded', () => {
                <% banners.forEach((banner, index) => { %>
                    <% if (banner.type !== 'rankup_board') { %>
                    (function() {
                        const imgUrl = '<%= banner.media_url %>';
                        const isVideo = '<%= banner.media_type %>' === 'video';
                        const slideId = 'slide-<%= index %>';
                        const slide = document.getElementById(slideId);
                        const hasDesc = <%= banner.description ? 'true' : 'false' %>;

                        if (!hasDesc) {
                            slide.classList.add('no-desc');
                            return;
                        }

                        if (isVideo) {
                            slide.classList.add('layout-portrait');
                            return;
                        }

                        const img = new Image();
                        img.src = imgUrl;
                        img.onload = function() {
                            const ratio = this.naturalWidth / this.naturalHeight;
                            if (ratio > 1.25) {
                                slide.classList.add('layout-landscape');
                            } else {
                                slide.classList.add('layout-portrait');
                            }
                        };
                        img.onerror = function() {
                            slide.classList.add('layout-portrait');
                        };
                    })();
                    <% } %>
                <% }) %>
                updateSlidePosition();
                startBannerInterval();

                // TÃ­nh "X phÃºt trÆ°á»›c" cho báº£ng Äá»™t PhÃ¡ Cáº£nh Giá»›i ngay trÃªn trÃ¬nh duyá»‡t ngÆ°á»i dÃ¹ng,
                // trÃ¡nh lá»‡ch giá» server/cache vÃ  tá»± cáº­p nháº­t mÃ  khÃ´ng cáº§n reload trang.
                function updateRankupTimes() {
                    document.querySelectorAll('.rankup-row-time').forEach(el => {
                        const ts = el.getAttribute('data-timestamp');
                        if (!ts) return;
                        const diffMs = Date.now() - new Date(ts).getTime();
                        const diffMin = Math.floor(diffMs / 60000);
                        if (diffMin < 1) {
                            el.textContent = 'vá»«a xong';
                        } else if (diffMin < 60) {
                            el.textContent = `${diffMin} phÃºt trÆ°á»›c`;
                        } else {
                            const diffHour = Math.floor(diffMin / 60);
                            el.textContent = `${diffHour} giá» trÆ°á»›c`;
                        }
                    });
                }
                updateRankupTimes();
                setInterval(updateRankupTimes, 30000);
            });
        </script>
    <% } %>

    <form action="/search" method="GET" class="search-bar" style="position: relative;">
        <input type="text" id="search-input" name="q" placeholder="Nháº­p tÃªn truyá»‡n hoáº·c tÃªn tÃ¡c giáº£..." value="<%= searchQuery || '' %>" autocomplete="off">
        <button type="submit" class="btn btn-primary">TÃ¬m kiáº¿m</button>
        <div id="search-suggestions" style="display: none; position: absolute; top: 100%; left: 0; right: 0; background: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: 8px; margin-top: 0.5rem; max-height: 350px; overflow-y: auto; z-index: 999; box-shadow: 0 10px 25px rgba(0,0,0,0.5); padding: 0.5rem 0;"></div>
    </form>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const searchInput = document.getElementById('search-input');
            const suggestionsBox = document.getElementById('search-suggestions');
            let debounceTimer;

            if (searchInput && suggestionsBox) {
                searchInput.addEventListener('input', () => {
                    clearTimeout(debounceTimer);
                    const query = searchInput.value.trim();
                    
                    if (query.length < 2) {
                        suggestionsBox.style.display = 'none';
                        suggestionsBox.innerHTML = '';
                        return;
                    }

                    debounceTimer = setTimeout(async () => {
                        try {
                            const response = await fetch(`/api/search-suggestions?q=${encodeURIComponent(query)}`);
                            const data = await response.json();
                            
                            if (data.success && data.results.length > 0) {
                                suggestionsBox.innerHTML = data.results.map(item => `
                                    <a href="/story/${item.id}" style="display: flex; align-items: center; gap: 0.8rem; padding: 0.6rem 1rem; text-decoration: none; color: var(--text-primary); transition: background 0.2s; border-bottom: 1px solid rgba(255,255,255,0.03);" onmouseover="this.style.background='rgba(255,255,255,0.05)'" onmouseout="this.style.background='transparent'">
                                        <img src="${item.cover_url || '/css/silly_duck.png'}" style="width: 35px; height: 48px; border-radius: 4px; object-fit: cover; flex-shrink: 0;">
                                        <div style="flex: 1; min-width: 0; text-align: left;">
                                            <div style="font-weight: 600; font-size: 0.9rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">${item.title}</div>
                                            <div style="font-size: 0.75rem; color: var(--text-secondary); margin-top: 0.15rem;">âœï¸ TÃ¡c giáº£: ${item.author || 'ChÆ°a rÃµ'}</div>
                                        </div>
                                    </a>
                                `).join('');
                                suggestionsBox.style.display = 'block';
                            } else {
                                suggestionsBox.style.display = 'none';
                                suggestionsBox.innerHTML = '';
                            }
                        } catch (err) {
                            console.error('Lá»—i gá»£i Ã½ tÃ¬m kiáº¿m:', err);
                        }
                    }, 300);
                });

                document.addEventListener('click', (e) => {
                    if (!searchInput.contains(e.target) && !suggestionsBox.contains(e.target)) {
                        suggestionsBox.style.display = 'none';
                    }
                });

                searchInput.addEventListener('focus', () => {
                    if (suggestionsBox.children.length > 0) {
                        suggestionsBox.style.display = 'block';
                    }
                });
            }
        });
    </script>

