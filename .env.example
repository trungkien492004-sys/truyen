# CẤU HÌNH CỔNG CHẠY SERVER
PORT=3000

# CẤU HÌNH KẾT NỐI SUPABASE
# Lấy từ Project Settings -> API trên trang Supabase
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_or_service_role_key_here

# CẤU HÌNH GOOGLE OAUTH
# Đăng ký ứng dụng tại https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# CẤU HÌNH TÀI KHOẢN ADMIN MẶC ĐỊNH
# Điền email Google của bạn ở đây để khi bạn đăng nhập qua Google, 
# tài khoản này sẽ tự động được cấp quyền Admin trong database.
ADMIN_EMAIL=your_email@gmail.com

# EXPRESS SESSION SECRET
SESSION_SECRET=a_very_secret_key_change_me_in_production
